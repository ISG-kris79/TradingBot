                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"/>
                                        <CheckBox x:Name="chkTelegramCloseError"
                                                  Content="청산오류/부분청산 실패 알림 허용"
                                                  Foreground="#FF6B6B"
                                                  IsChecked="True"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="2"
                                               Text="※ 저장 즉시 적용됩니다. 차단된 타입은 Telegram 전송 단계에서 무시됩니다."
