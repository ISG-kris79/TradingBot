<Window x:Class="TradingBot.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경 설정"
        Height="600"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                    Value="True"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#94A3B8"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="46"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#333"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernWindowStyle"
               TargetType="Window">
            <Setter Property="Background"
                    Value="#121212"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="WindowStyle"
                    Value="None"/>
            <Setter Property="ResizeMode"
                    Value="CanResize"/>
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome CaptionHeight="40"
                                  ResizeBorderThickness="5"
                                  GlassFrameThickness="0"
                                  CornerRadius="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#333"
            BorderThickness="1"
            Background="#1E1E1E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="환경 설정"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="—"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMinimize_Click"/>
                    <!-- Maximize is disabled for this fixed-size window -->
                    <Button Content="☐"
                            Style="{StaticResource WindowControlButtonStyle}"
                            IsEnabled="False"/>
                    <Button Content="✕"
                            Click="OnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource WindowControlButtonStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E81123"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Original Content -->
            <Grid Grid.Row="1"
                  Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="⚙️ 매매 설정"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#00E676"
                           Grid.Row="0"
                           Margin="0,0,0,20"/>
                <TabControl Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border"
                                                BorderThickness="0,0,0,2"
                                                BorderBrush="Transparent"
                                                Margin="0,0,10,0"
                                                Padding="10,5"
                                                Cursor="Hand">
                                            <ContentPresenter x:Name="ContentSite"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"
                                                              ContentSource="Header"
                                                              Margin="10,2"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter TargetName="Border"
                                                        Property="BorderBrush"
                                                        Value="#00E676"/>
                                                <Setter Property="Foreground"
                                                        Value="#00E676"/>
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected"
                                                     Value="False">
                                                <Setter Property="Foreground"
                                                        Value="#64748B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="General">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <!-- ─── 공통 설정 (0~7) ─── -->
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <!-- ─── PUMP 전략 전용 (8~19) ─── -->
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <!-- ─── PUMP 추세홀딩 튜닝 (20~23) ─── -->
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <!-- ─── 메이저 코인 전략 전용 (24~33) ─── -->
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <!-- ─── 급변 감지 (34~40) ─── -->
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <!-- 공통 설정 (알트코인 기본값) - rows 0~7                 -->
                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <TextBlock Text="── 공통 기본 설정 ──"
                                               Grid.Row="0"
                                               Grid.ColumnSpan="2"
                                               Foreground="#94A3B8"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               Margin="0,0,0,10"/>

                                    <!-- 기본 마진 -->
                                    <TextBlock Text="기본 마진 (USDT):"
                                               VerticalAlignment="Center"
                                               Grid.Row="1"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtDefaultMargin"
                                             Grid.Row="1"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 레버리지 -->
                                    <TextBlock Text="레버리지 (x):"
                                               VerticalAlignment="Center"
                                               Grid.Row="2"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtLeverage"
                                             Grid.Row="2"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 주요 심볼 -->
                                    <TextBlock Text="주요 심볼:"
                                               VerticalAlignment="Center"
                                               Grid.Row="3"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtSymbols"
                                             Grid.Row="3"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 리스크 비율 -->
                                    <TextBlock Text="리스크 비율 (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="4"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtRisk"
                                             Grid.Row="4"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 알트코인 목표 ROE -->
                                    <TextBlock Text="알트 목표 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="5"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtTargetRoe"
                                             Grid.Row="5"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 알트코인 손절 ROE -->
                                    <TextBlock Text="알트 손절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="6"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtStopLossRoe"
                                             Grid.Row="6"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 시뮬레이션 모드 -->
                                    <TextBlock Text="매매 모드:"
                                               VerticalAlignment="Top"
                                               Grid.Row="7"
                                               Foreground="#94A3B8"
                                               Margin="0,5,0,15"/>
                                    <StackPanel Grid.Row="7"
                                                Grid.Column="1"
                                                Margin="0,0,0,15">
                                        <CheckBox x:Name="chkSimulationMode"
                                                  Foreground="White"
                                                  Content="시뮬레이션 모드 (실제 매매 없음)"
                                                  FontSize="13"
                                                  Checked="chkSimulationMode_Checked"
                                                  Unchecked="chkSimulationMode_Unchecked">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                            <Setter Property="Foreground"
                                                                    Value="#FFB800"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                        <StackPanel x:Name="pnlSimulationBalance"
                                                    Margin="20,10,0,0"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="초기 잔고 (USDT):"
                                                       Foreground="#94A3B8"
                                                       FontSize="12"
                                                       Margin="0,0,0,5"/>
                                            <TextBox x:Name="txtSimulationBalance"
                                                     Text="10000"
                                                     Padding="8"
                                                     Background="#1E2235"
                                                     Foreground="White"
                                                     BorderBrush="#2D3142"
                                                     Width="200"
                                                     HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <!-- PUMP 전략 전용 - rows 8~19                            -->
                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <TextBlock Text="── PUMP 전략 전용 ──"
                                               Grid.Row="8"
                                               Grid.ColumnSpan="2"
                                               Foreground="#FF6B35"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               Margin="0,10,0,10"/>

                                    <!-- PUMP 레버리지 -->
                                    <TextBlock Text="PUMP 레버리지 (x):"
                                               VerticalAlignment="Center"
                                               Grid.Row="9"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpLeverage"
                                             Grid.Row="9"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 증거금 -->
                                    <TextBlock Text="PUMP 증거금 (USDT):"
                                               VerticalAlignment="Center"
                                               Grid.Row="10"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpMargin"
                                             Grid.Row="10"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 본절 ROE -->
                                    <TextBlock Text="PUMP 본절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="11"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpBreakEvenRoe"
                                             Grid.Row="11"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 1차 부분익절 ROE -->
                                    <TextBlock Text="PUMP 1차 부분익절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="12"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpTp1Roe"
                                             Grid.Row="12"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 2차 청산목표 ROE -->
                                    <TextBlock Text="PUMP 2차 청산목표 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="13"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpTp2Roe"
                                             Grid.Row="13"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 트레일링 시작 ROE -->
                                    <TextBlock Text="PUMP 트레일링시작 ROE:"
                                               VerticalAlignment="Center"
                                               Grid.Row="14"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpTrailingStartRoe"
                                             Grid.Row="14"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 트레일링 갭 ROE -->
                                    <TextBlock Text="PUMP 트레일링갭 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="15"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpTrailingGapRoe"
                                             Grid.Row="15"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 손절 ROE -->
                                    <TextBlock Text="PUMP 손절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="16"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpStopLossRoe"
                                             Grid.Row="16"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 시간손절 -->
                                    <TextBlock Text="PUMP 시간손절 (분):"
                                               VerticalAlignment="Center"
                                               Grid.Row="17"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpTimeStopMinutes"
                                             Grid.Row="17"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 손절거리 경고 -->
                                    <TextBlock Text="PUMP 손절거리 경고 (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="18"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpStopWarnPct"
                                             Grid.Row="18"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 손절거리 차단 -->
                                    <TextBlock Text="PUMP 손절거리 차단 (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="19"
                                               Foreground="#FF9966"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpStopBlockPct"
                                             Grid.Row="19"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <!-- PUMP 추세홀딩 튜닝 - rows 20~23                       -->
                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <TextBlock Text="── PUMP 추세홀딩 튜닝 ──"
                                               Grid.Row="20"
                                               Grid.ColumnSpan="2"
                                               Foreground="#FFB86C"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               Margin="0,10,0,10"/>

                                    <TextBlock Text="1차 익절 비중 (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="21"
                                               Foreground="#FFB86C"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpFirstTakeProfitRatioPct"
                                             Grid.Row="21"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="계단식 구간1 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="22"
                                               Foreground="#FFB86C"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpStairStep1Roe"
                                             Grid.Row="22"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <StackPanel Grid.Row="23"
                                                Grid.ColumnSpan="2"
                                                Orientation="Horizontal"
                                                Margin="0,0,0,15">
                                        <TextBlock Text="구간2 / 구간3 ROE (%): "
                                                   VerticalAlignment="Center"
                                                   Foreground="#FFB86C"
                                                   Margin="0,0,8,0"/>
                                        <TextBox x:Name="txtPumpStairStep2Roe"
                                                 Width="120"
                                                 Padding="8"
                                                 Background="#1E2235"
                                                 Foreground="White"
                                                 BorderBrush="#2D3142"
                                                 Margin="0,0,8,0"/>
                                        <TextBox x:Name="txtPumpStairStep3Roe"
                                                 Width="120"
                                                 Padding="8"
                                                 Background="#1E2235"
                                                 Foreground="White"
                                                 BorderBrush="#2D3142"/>
                                    </StackPanel>

                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <!-- 메이저 코인 전략 전용 - rows 24~33                    -->
                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <TextBlock Text="── 메이저 코인 전략 전용 ──"
                                               Grid.Row="24"
                                               Grid.ColumnSpan="2"
                                               Foreground="#00E676"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               Margin="0,10,0,10"/>

                                    <!-- 메이저 추세 프로파일 (메이저 섹션으로 이동) -->
                                    <TextBlock Text="메이저 추세 프로파일:"
                                               VerticalAlignment="Center"
                                               Grid.Row="25"
                                               Foreground="#66FF99"
                                               Margin="0,0,0,15"/>
                                    <ComboBox x:Name="cboMajorTrendProfile"
                                              Grid.Row="25"
                                              Grid.Column="1"
                                              Margin="0,0,0,15"
                                              Height="35"
                                              Padding="8"
                                              Background="#1E2235"
                                              Foreground="White"
                                              BorderBrush="#2D3142"
                                              BorderThickness="1">
                                        <ComboBoxItem Content="균형형 (Balanced)" Tag="Balanced"/>
                                        <ComboBoxItem Content="공격형 (Aggressive)" Tag="Aggressive"/>
                                    </ComboBox>

                                    <!-- 메이저 레버리지 -->
                                    <TextBlock Text="메이저 레버리지 (x):"
                                               VerticalAlignment="Center"
                                               Grid.Row="26"
                                               Foreground="#66FF99"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMajorLeverage"
                                             Grid.Row="26"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 메이저 증거금 비율 -->
                                    <TextBlock Text="메이저 증거금 비율 (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="27"
                                               Foreground="#66FF99"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMajorMargin"
                                             Grid.Row="27"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 메이저 본절 ROE -->
                                    <TextBlock Text="메이저 본절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="28"
