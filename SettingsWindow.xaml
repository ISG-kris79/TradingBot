                    <TabItem Header="Grid Strategy">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 제목 -->
                                    <TextBlock Grid.Row="0"
                                               Text="📊 그리드 전략 설정"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#00E676"
                                               Margin="0,0,0,15"/>

                                    <!-- 설정 -->
                                    <Grid Grid.Row="1"
                                          Margin="0,0,0,15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Grid Levels:"
                                                   VerticalAlignment="Center"
                                                   Grid.Row="0"
                                                   Foreground="#94A3B8"
                                                   Margin="0,0,0,15"/>
                                        <TextBox x:Name="txtGridLevels"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Margin="0,0,0,15"
                                                 Padding="8"
                                                 Background="#1E2235"
                                                 Foreground="White"
                                                 BorderBrush="#2D3142"/>

                                        <TextBlock Text="Spacing (%):"
                                                   VerticalAlignment="Center"
                                                   Grid.Row="1"
                                                   Foreground="#94A3B8"
                                                   Margin="0,0,0,15"/>
                                        <TextBox x:Name="txtGridSpacing"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Margin="0,0,0,15"
                                                 Padding="8"
                                                 Background="#1E2235"
                                                 Foreground="White"
                                                 BorderBrush="#2D3142"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Arbitrage"
                             Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 제목 -->
                                    <TextBlock Grid.Row="0"
                                               Text="💰 차익거래 설정"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#00E676"
                                               Margin="0,0,0,15"/>

                                    <!-- 설정 -->
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="chkAutoHedge"
                                                  Content="Auto Hedge Mode"
                                                  Grid.Column="1"
                                                  Foreground="#94A3B8"
                                                  Margin="0,0,0,15"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- 버튼 -->
            <StackPanel Orientation="Horizontal"
                        Grid.Row="2"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,20">
                <Button x:Name="btnRunBacktest3Y"
                        Content="3년 백테스트"
                        Width="120"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="btnRunBacktest3Y_Click"
                        Background="#7C3AED"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="바이낸스 3년 데이터로 현재 전략 백테스트 실행 (Shift=단일윈도우 최적화)"/>
                <Button x:Name="btnRunWfo"
                        Content="WFO 최적화"
                        Width="120"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="btnRunWfo_Click"
                        Background="#F59E0B"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="워크포워드 최적화: 12개월 IS + 4개월 OOS 롤링 윈도우"/>
                <Button x:Name="btnRunMtf"
                        Content="5분봉 최적화"
                        Width="100"
                        Height="35"
                        Margin="0,0,5,0"
                        Click="btnRunMtf_Click"
                        Background="#EF4444"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="5분봉 모멘텀 스캘핑 자동 최적화"/>
                <Button x:Name="btnRunAI"
                        Content="AI 학습"
                        Width="100"
                        Height="35"
                        Margin="0,0,10,0"
                        Click="btnRunAI_Click"
                        Background="#10B981"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="AI 학습 백테스트: LightGBM 학습 + 승리패턴 스냅샷 매칭 (8종 6개월)"/>
                <Button x:Name="btnSave"
                        Content="저장"
                        Width="100"
                        Height="35"
                        Click="btnSave_Click"
                        Background="#00E676"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button x:Name="btnCancel"
                        Content="취소"
                        Width="100"
                        Height="35"
                        Margin="10,0,0,0"
                        Click="OnClose_Click"
                        Background="#2D3142"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
