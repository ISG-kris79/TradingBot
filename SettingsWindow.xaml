                                             Grid.Row="4"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="LONG 하단 터치 배수:"
                                               VerticalAlignment="Center"
                                               Grid.Row="5"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtTfSidewaysLongLowerTouch"
                                             Grid.Row="5"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="SHORT 상단 터치 배수:"
                                               VerticalAlignment="Center"
                                               Grid.Row="6"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtTfSidewaysShortUpperTouch"
                                             Grid.Row="6"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="LONG 손절 배수:"
                                               VerticalAlignment="Center"
