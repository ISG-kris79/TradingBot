<Window x:Class="TradingBot.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경 설정"
        Height="600"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                    Value="True"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#94A3B8"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="46"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#333"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernWindowStyle"
               TargetType="Window">
            <Setter Property="Background"
                    Value="#121212"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="WindowStyle"
                    Value="None"/>
            <Setter Property="ResizeMode"
                    Value="CanResize"/>
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome CaptionHeight="40"
                                  ResizeBorderThickness="5"
                                  GlassFrameThickness="0"
                                  CornerRadius="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#333"
            BorderThickness="1"
            Background="#1E1E1E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="환경 설정"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="—"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMinimize_Click"/>
                    <!-- Maximize is disabled for this fixed-size window -->
                    <Button Content="☐"
                            Style="{StaticResource WindowControlButtonStyle}"
                            IsEnabled="False"/>
                    <Button Content="✕"
                            Click="OnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource WindowControlButtonStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E81123"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Original Content -->
            <Grid Grid.Row="1"
                  Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="⚙️ 매매 설정"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#00E676"
                           Grid.Row="0"
                           Margin="0,0,0,20"/>
                <TabControl Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border"
                                                BorderThickness="0,0,0,2"
                                                BorderBrush="Transparent"
                                                Margin="0,0,10,0"
                                                Padding="10,5"
                                                Cursor="Hand">
                                            <ContentPresenter x:Name="ContentSite"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"
                                                              ContentSource="Header"
                                                              Margin="10,2"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter TargetName="Border"
                                                        Property="BorderBrush"
                                                        Value="#00E676"/>
                                                <Setter Property="Foreground"
                                                        Value="#00E676"/>
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected"
                                                     Value="False">
                                                <Setter Property="Foreground"
                                                        Value="#64748B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="General">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <!-- 공통 설정 - rows 0~9                                   -->
                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <TextBlock Text="── 공통 기본 설정 ──"
                                               Grid.Row="0"
                                               Grid.ColumnSpan="2"
                                               Foreground="#94A3B8"
                                               FontWeight="Bold"
                                               FontSize="12"
                                               Margin="0,0,0,10"/>

                                    <!-- 기본 마진 (메이저/PUMP 공통) -->
                                    <TextBlock Text="기본 마진 (USDT):"
                                               VerticalAlignment="Center"
                                               Grid.Row="1"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtDefaultMargin"
                                             Grid.Row="1"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- [v5.5.8] 메이저 코인 매매 ON/OFF -->
                                    <TextBlock Text="메이저 코인 매매:"
                                               VerticalAlignment="Center"
                                               Grid.Row="2"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <CheckBox x:Name="chkEnableMajorTrading"
                                              Grid.Row="2" Grid.Column="1"
                                              Content="활성화"
                                              IsChecked="True"
                                              Foreground="#94A3B8"
                                              VerticalAlignment="Center"
                                              Margin="0,0,0,15"/>

                                    <!-- PUMP 증거금 $ -->
                                    <TextBlock Text="PUMP 증거금 ($):"
                                               VerticalAlignment="Center"
                                               Grid.Row="3"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="txtPumpMargin"
                                                 Padding="8" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>
                                        <TextBlock Grid.Column="1" Text="USDT" Foreground="#64748B" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"/>
                                    </Grid>

                                    <!-- 레버리지 -->
                                    <TextBlock Text="레버리지 (x):"
                                               VerticalAlignment="Center"
                                               Grid.Row="4"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtLeverage"
                                             Grid.Row="4"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- [v5.7.9] 메이저/PUMP 슬롯 -->
                                    <TextBlock Text="메이저 슬롯:"
                                               VerticalAlignment="Center" Grid.Row="5"
                                               Foreground="#94A3B8" Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMaxMajorSlots"
                                             Grid.Row="5" Grid.Column="1" Margin="0,0,0,15"
                                             Padding="8" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                                    <TextBlock Text="PUMP 슬롯:"
                                               VerticalAlignment="Center" Grid.Row="6"
                                               Foreground="#94A3B8" Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMaxPumpSlots"
                                             Grid.Row="6" Grid.Column="1" Margin="0,0,0,15"
                                             Padding="8" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                                    <!-- [v5.9.20] 하루 진입 횟수 제한 -->
                                    <TextBlock Text="하루 진입 횟수:"
                                               VerticalAlignment="Center" Grid.Row="7"
                                               Foreground="#94A3B8" Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMaxDailyEntries"
                                             Grid.Row="7" Grid.Column="1" Margin="0,0,0,15"
                                             Padding="8" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                                    <!-- 주요 심볼 -->
                                    <TextBlock Text="주요 심볼:"
                                               VerticalAlignment="Center"
                                               Grid.Row="8"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtSymbols"
                                             Grid.Row="8"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 시뮬레이션 모드 -->
                                    <TextBlock Text="매매 모드:"
                                               VerticalAlignment="Top"
                                               Grid.Row="9"
                                               Foreground="#94A3B8"
                                               Margin="0,5,0,15"/>
                                    <StackPanel Grid.Row="9"
                                                Grid.Column="1"
                                                Margin="0,0,0,15">
                                        <CheckBox x:Name="chkSimulationMode"
                                                  Foreground="White"
                                                  Content="시뮬레이션 모드 (실제 매매 없음)"
                                                  FontSize="13"
                                                  Checked="chkSimulationMode_Checked"
                                                  Unchecked="chkSimulationMode_Unchecked">
                                            <CheckBox.Style>
                                                <Style TargetType="CheckBox">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsChecked"
                                                                 Value="True">
                                                            <Setter Property="Foreground"
                                                                    Value="#FFB800"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </CheckBox.Style>
                                        </CheckBox>
                                        <StackPanel x:Name="pnlSimulationBalance"
                                                    Margin="20,10,0,0"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="초기 잔고 (USDT):"
                                                       Foreground="#94A3B8"
                                                       FontSize="12"
                                                       Margin="0,0,0,5"/>
                                            <TextBox x:Name="txtSimulationBalance"
                                                     Text="10000"
                                                     Padding="8"
                                                     Background="#1E2235"
                                                     Foreground="White"
                                                     BorderBrush="#2D3142"
                                                     Width="200"
                                                     HorizontalAlignment="Left"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- [v3.2.14] PUMP/메이저/급변감지 설정 제거됨 — 소스 하드코딩 -->
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    

                    <TabItem Header="Telegram Messages">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="📨 텔레그램 메시지 타입 허용/차단"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#00E676"
                                               Margin="0,0,0,15"/>

                                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                        <CheckBox x:Name="chkTelegramAlert"
                                                  Content="시스템 경보/중요 알림 허용"
                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8"/>
                                        <CheckBox x:Name="chkTelegramProfit"
                                                  Content="익절/손절/정기 수익 보고 허용"
                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8"/>
                                        <CheckBox x:Name="chkTelegramEntry"
                                                  Content="진입/본절/트레일링 마일스톤 허용"
                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8"/>
                                        <CheckBox x:Name="chkTelegramAiGate"
                                                  Content="AI 관제탑(게이트 요약) 허용"
                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8"/>
                                        <CheckBox x:Name="chkTelegramLog"
                                                  Content="저중요 로그/하트비트 허용"
                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"/>
                                        <CheckBox x:Name="chkTelegramCloseError"
                                                  Content="청산오류/부분청산 실패 알림 허용"
                                                  Foreground="#FF6B6B"
                                                  IsChecked="True"
                                                  Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <TextBlock Grid.Row="2"
                                               Text="※ 저장 즉시 적용됩니다. 차단된 타입은 Telegram 전송 단계에서 무시됩니다."
                                               Foreground="#94A3B8"
                                               TextWrapping="Wrap"
                                               Margin="0,10,0,0"/>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    

                    
                </TabControl>
            </Grid>

            <!-- 버튼 -->
            <StackPanel Orientation="Horizontal"
                        Grid.Row="2"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,20">
                <Button x:Name="btnSave"
                        Content="저장"
                        Width="100"
                        Height="35"
                        Click="btnSave_Click"
                        Background="#00E676"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button x:Name="btnCancel"
                        Content="취소"
                        Width="100"
                        Height="35"
                        Margin="10,0,0,0"
                        Click="OnClose_Click"
                        Background="#2D3142"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
