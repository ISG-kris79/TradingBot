                                             Grid.Row="2"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="횡보 SHORT RSI 최소:"
                                               VerticalAlignment="Center"
                                               Grid.Row="3"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
