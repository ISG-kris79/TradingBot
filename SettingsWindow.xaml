<Window x:Class="TradingBot.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경 설정" Height="600" Width="600" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" 
        Background="#0F111A" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Text="⚙️ 매매 설정" FontSize="18" FontWeight="Bold" Foreground="#00E676" 
                   Grid.Row="0" Margin="0,0,0,20"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="General" Foreground="Black">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 거래소 선택 -->
                    <TextBlock Text="거래소 선택:" VerticalAlignment="Center" Grid.Row="0" Margin="0,0,0,15"/>
                    <ComboBox x:Name="cboExchange" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15" Padding="5"
                              SelectionChanged="cboExchange_SelectionChanged">
                        <ComboBoxItem Content="Binance" Tag="Binance"/>
                        <ComboBoxItem Content="Bybit" Tag="Bybit"/>
                        <ComboBoxItem Content="Bitget" Tag="Bitget"/>
                    </ComboBox>

                    <!-- API Key 안내 -->
                    <StackPanel x:Name="pnlApiKeys" Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                        <StackPanel x:Name="pnlBinance" Visibility="Collapsed">
                            <TextBlock Text="Binance API Key (설정 파일)" Foreground="Gray" FontSize="10"/>
                        </StackPanel>
                        <StackPanel x:Name="pnlBybit" Visibility="Collapsed">
                            <TextBlock Text="Bybit API Key (설정 파일)" Foreground="Gray" FontSize="10"/>
                        </StackPanel>
                        <StackPanel x:Name="pnlBitget" Visibility="Collapsed">
                            <TextBlock Text="Bitget API Key &amp; Passphrase (설정 파일)" Foreground="Gray" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- DB 연결 문자열 -->
                    <TextBlock Text="DB 연결 문자열:" VerticalAlignment="Center" Grid.Row="2" Margin="0,0,0,15"/>
                    <TextBox x:Name="txtConnectionString" Grid.Row="2" Grid.Column="1" Margin="0,0,0,15" Padding="8" 
                             Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                    <!-- 레버리지 -->
                    <TextBlock Text="레버리지 (x):" VerticalAlignment="Center" Grid.Row="3" Margin="0,0,0,15"/>
                    <TextBox x:Name="txtLeverage" Grid.Row="3" Grid.Column="1" Margin="0,0,0,15" Padding="8" 
                             Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                    <!-- 주요 심볼 -->
                    <TextBlock Text="주요 심볼:" VerticalAlignment="Center" Grid.Row="4" Margin="0,0,0,15"/>
                    <TextBox x:Name="txtSymbols" Grid.Row="4" Grid.Column="1" Margin="0,0,0,15" Padding="8" 
                             Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                    <!-- 리스크 비율 -->
                    <TextBlock Text="리스크 비율 (%):" VerticalAlignment="Center" Grid.Row="5" Margin="0,0,0,15"/>
                    <TextBox x:Name="txtRisk" Grid.Row="5" Grid.Column="1" Margin="0,0,0,15" Padding="8" 
                             Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                    <!-- 목표 수익률 -->
                    <TextBlock Text="목표 ROE (%):" VerticalAlignment="Center" Grid.Row="6" Margin="0,0,0,15"/>
                    <TextBox x:Name="txtTargetRoe" Grid.Row="6" Grid.Column="1" Margin="0,0,0,15" Padding="8" 
                             Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                    <!-- 손절 비율 -->
                    <TextBlock Text="손절 ROE (%):" VerticalAlignment="Center" Grid.Row="7" Margin="0,0,0,15"/>
                    <TextBox x:Name="txtStopLossRoe" Grid.Row="7" Grid.Column="1" Margin="0,0,0,15" Padding="8" 
                             Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>
                </Grid>
            </TabItem>

            <TabItem Header="Grid Strategy" Foreground="Black">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Grid Levels:" VerticalAlignment="Center" Grid.Row="0" Margin="0,0,0,15"/>
                    <TextBox x:Name="txtGridLevels" Grid.Row="0" Grid.Column="1" Margin="0,0,0,15" Padding="8" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

                    <TextBlock Text="Spacing (%):" VerticalAlignment="Center" Grid.Row="1" Margin="0,0,0,15"/>
                    <TextBox x:Name="txtGridSpacing" Grid.Row="1" Grid.Column="1" Margin="0,0,0,15" Padding="8" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>
                </Grid>
            </TabItem>

            <TabItem Header="Arbitrage" Foreground="Black">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="chkAutoHedge" Content="Auto Hedge Mode" Grid.Row="0" Grid.Column="1" Foreground="White" Margin="0,0,0,15"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 버튼 -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="btnSave" Content="저장" Width="100" Height="35" Click="btnSave_Click" 
                    Background="#00E676" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="btnCancel" Content="취소" Width="100" Height="35" Margin="10,0,0,0" Click="btnCancel_Click"
                    Background="#2D3142" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>