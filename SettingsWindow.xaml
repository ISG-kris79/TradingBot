                                             Grid.Row="3"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="횡보 거래량비 최대:"
                                               VerticalAlignment="Center"
                                               Grid.Row="4"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
