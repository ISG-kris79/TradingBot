                    <TabItem Header="Telegram Messages">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="📨 텔레그램 메시지 타입 허용/차단"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#00E676"
                                               Margin="0,0,0,15"/>

                                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                        <CheckBox x:Name="chkTelegramAlert"
                                                  Content="시스템 경보/중요 알림 허용"
                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8"/>
                                        <CheckBox x:Name="chkTelegramProfit"
                                                  Content="익절/손절/정기 수익 보고 허용"
                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8"/>
                                        <CheckBox x:Name="chkTelegramEntry"
                                                  Content="진입/본절/트레일링 마일스톤 허용"
                                                  Foreground="#E2E8F0"
                                                  IsChecked="True"
                                                  Margin="0,0,0,8"/>
