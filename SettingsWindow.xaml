                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 메이저 1차 부분익절 ROE -->
                                    <TextBlock Text="메이저 Tp1 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="29"
                                               Foreground="#66FF99"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMajorTp1Roe"
