<Window x:Class="TradingBot.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="환경 설정"
        Height="600"
        Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                    Value="True"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#94A3B8"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="46"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#333"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernWindowStyle"
               TargetType="Window">
            <Setter Property="Background"
                    Value="#121212"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="WindowStyle"
                    Value="None"/>
            <Setter Property="ResizeMode"
                    Value="CanResize"/>
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome CaptionHeight="40"
                                  ResizeBorderThickness="5"
                                  GlassFrameThickness="0"
                                  CornerRadius="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#333"
            BorderThickness="1"
            Background="#1E1E1E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="환경 설정"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="—"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMinimize_Click"/>
                    <!-- Maximize is disabled for this fixed-size window -->
                    <Button Content="☐"
                            Style="{StaticResource WindowControlButtonStyle}"
                            IsEnabled="False"/>
                    <Button Content="✕"
                            Click="OnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource WindowControlButtonStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E81123"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Original Content -->
            <Grid Grid.Row="1"
                  Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="⚙️ 매매 설정"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#00E676"
                           Grid.Row="0"
                           Margin="0,0,0,20"/>
                <TabControl Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border"
                                                BorderThickness="0,0,0,2"
                                                BorderBrush="Transparent"
                                                Margin="0,0,10,0"
                                                Padding="10,5"
                                                Cursor="Hand">
                                            <ContentPresenter x:Name="ContentSite"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Center"
                                                              ContentSource="Header"
                                                              Margin="10,2"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter TargetName="Border"
                                                        Property="BorderBrush"
                                                        Value="#00E676"/>
                                                <Setter Property="Foreground"
                                                        Value="#00E676"/>
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected"
                                                     Value="False">
                                                <Setter Property="Foreground"
                                                        Value="#64748B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <TabItem Header="General">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 거래소 선택 -->
                                    <TextBlock Text="거래소 선택:"
                                               VerticalAlignment="Center"
                                               Grid.Row="0"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <ComboBox x:Name="cboExchange"
                                              Grid.Row="0"
                                              Grid.Column="1"
                                              Margin="0,0,0,15"
                                              Height="35"
                                              Padding="8"
                                              Background="#1E2235"
                                              Foreground="White"
                                              BorderBrush="#2D3142"
                                              BorderThickness="1"
                                              SelectionChanged="cboExchange_SelectionChanged">
                                        <ComboBox.Resources>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background"
                                                        Value="#1E2235"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Setter Property="Padding"
                                                        Value="8"/>
                                                <Setter Property="Height"
                                                        Value="35"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                             Value="True">
                                                        <Setter Property="Background"
                                                                Value="#2D3142"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected"
                                                             Value="True">
                                                        <Setter Property="Background"
                                                                Value="#00E676"/>
                                                        <Setter Property="Foreground"
                                                                Value="Black"/>
                                                        <Setter Property="FontWeight"
                                                                Value="Bold"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ComboBox.Resources>
                                        <ComboBoxItem Content="Binance"
                                                      Tag="Binance"/>
                                        <ComboBoxItem Content="Bybit"
                                                      Tag="Bybit"/>
                                    </ComboBox>

                                    <!-- API Key 안내 -->
                                    <StackPanel x:Name="pnlApiKeys"
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Margin="0,0,0,15">
                                        <StackPanel x:Name="pnlBinance"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="Binance API Key (설정 파일)"
                                                       Foreground="#64748B"
                                                       FontSize="10"/>
                                        </StackPanel>
                                        <StackPanel x:Name="pnlBybit"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="Bybit API Key (설정 파일)"
                                                       Foreground="#64748B"
                                                       FontSize="10"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 기본 마진 -->
                                    <TextBlock Text="기본 마진 (USDT):"
                                               VerticalAlignment="Center"
                                               Grid.Row="2"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtDefaultMargin"
                                             Grid.Row="2"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 레버리지 -->
                                    <TextBlock Text="레버리지 (x):"
                                               VerticalAlignment="Center"
                                               Grid.Row="3"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtLeverage"
                                             Grid.Row="3"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 주요 심볼 -->
                                    <TextBlock Text="주요 심볼:"
                                               VerticalAlignment="Center"
                                               Grid.Row="4"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtSymbols"
                                             Grid.Row="4"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 리스크 비율 -->
                                    <TextBlock Text="리스크 비율 (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="5"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtRisk"
                                             Grid.Row="5"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 목표 수익률 -->
                                    <TextBlock Text="목표 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="6"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtTargetRoe"
                                             Grid.Row="6"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 손절 비율 -->
                                    <TextBlock Text="손절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="7"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtStopLossRoe"
                                             Grid.Row="7"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 시뮬레이션 모드 -->
                                    <TextBlock Text="매매 모드:"
                                               VerticalAlignment="Center"
                                               Grid.Row="8"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <CheckBox x:Name="chkSimulationMode"
                                              Grid.Row="8"
                                              Grid.Column="1"
                                              Margin="0,0,0,15"
                                              VerticalAlignment="Center"
                                              Foreground="White"
                                              Content="시뮬레이션 모드 (실제 매매 없음)"
                                              FontSize="13">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox">
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked"
                                                             Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="#FFB800"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>

                                    <!-- PUMP 1차 익절 ROE -->
                                    <TextBlock Text="PUMP 1차 익절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="9"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpTp1Roe"
                                             Grid.Row="9"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 2차 익절 ROE -->
                                    <TextBlock Text="PUMP 2차 익절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="10"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpTp2Roe"
                                             Grid.Row="10"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 시간 손절 -->
                                    <TextBlock Text="PUMP 시간손절 (분):"
                                               VerticalAlignment="Center"
                                               Grid.Row="11"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpTimeStopMinutes"
                                             Grid.Row="11"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 손절거리 경고 -->
                                    <TextBlock Text="PUMP 손절거리 경고(%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="12"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpStopWarnPct"
                                             Grid.Row="12"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- PUMP 손절거리 차단 -->
                                    <TextBlock Text="PUMP 손절거리 차단(%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="13"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtPumpStopBlockPct"
                                             Grid.Row="13"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Grid Strategy">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 제목 -->
                                    <TextBlock Grid.Row="0"
                                               Text="📊 그리드 전략 설정"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#00E676"
                                               Margin="0,0,0,15"/>

                                    <!-- 설정 -->
                                    <Grid Grid.Row="1"
                                          Margin="0,0,0,15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Grid Levels:"
                                                   VerticalAlignment="Center"
                                                   Grid.Row="0"
                                                   Foreground="#94A3B8"
                                                   Margin="0,0,0,15"/>
                                        <TextBox x:Name="txtGridLevels"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Margin="0,0,0,15"
                                                 Padding="8"
                                                 Background="#1E2235"
                                                 Foreground="White"
                                                 BorderBrush="#2D3142"/>

                                        <TextBlock Text="Spacing (%):"
                                                   VerticalAlignment="Center"
                                                   Grid.Row="1"
                                                   Foreground="#94A3B8"
                                                   Margin="0,0,0,15"/>
                                        <TextBox x:Name="txtGridSpacing"
                                                 Grid.Row="1"
                                                 Grid.Column="1"
                                                 Margin="0,0,0,15"
                                                 Padding="8"
                                                 Background="#1E2235"
                                                 Foreground="White"
                                                 BorderBrush="#2D3142"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Arbitrage"
                             Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 제목 -->
                                    <TextBlock Grid.Row="0"
                                               Text="💰 차익거래 설정"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               Foreground="#00E676"
                                               Margin="0,0,0,15"/>

                                    <!-- 설정 -->
                                    <Grid Grid.Row="1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox x:Name="chkAutoHedge"
                                                  Content="Auto Hedge Mode"
                                                  Grid.Column="1"
                                                  Foreground="#94A3B8"
                                                  Margin="0,0,0,15"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- 버튼 -->
            <StackPanel Orientation="Horizontal"
                        Grid.Row="2"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,20">
                <Button x:Name="btnSave"
                        Content="저장"
                        Width="100"
                        Height="35"
                        Click="btnSave_Click"
                        Background="#00E676"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <Button x:Name="btnCancel"
                        Content="취소"
                        Width="100"
                        Height="35"
                        Margin="10,0,0,0"
                        Click="OnClose_Click"
                        Background="#2D3142"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
