                                    <TextBlock Text="메이저 목표익절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="30"
                                               Foreground="#66FF99"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMajorTp2Roe"
                                             Grid.Row="30"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 메이저 트레일링 시작 ROE -->
                                    <TextBlock Text="메이저 트레일링시작 ROE:"
                                               VerticalAlignment="Center"
                                               Grid.Row="31"
                                               Foreground="#66FF99"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMajorTrailingStartRoe"
                                             Grid.Row="31"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 메이저 트레일링 갭 ROE -->
                                    <TextBlock Text="메이저 트레일링갭 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="32"
                                               Foreground="#66FF99"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMajorTrailingGapRoe"
                                             Grid.Row="32"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- 메이저 손절 ROE -->
                                    <TextBlock Text="메이저 손절 ROE (%):"
                                               VerticalAlignment="Center"
                                               Grid.Row="33"
                                               Foreground="#66FF99"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtMajorStopLossRoe"
                                             Grid.Row="33"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <!-- 급변 감지 (CRASH/PUMP) - rows 34~40                   -->
                                    <!-- ══════════════════════════════════════════════════════ -->
                                    <TextBlock Text="── 급변 감지 (CRASH/PUMP) ──"
                                               Grid.Row="34"
                                               Grid.ColumnSpan="2"
                                               Foreground="#FF6B6B"
                                               FontWeight="Bold"
                                               Margin="0,10,0,8"/>

                                    <CheckBox x:Name="chkCrashDetectorEnabled"
                                              Grid.Row="35"
                                              Grid.ColumnSpan="2"
                                              Content="급변 감지 활성화 (CRASH 긴급 청산 + 리버스 진입)"
                                              Foreground="#FF6B6B"
                                              IsChecked="True"
                                              Margin="0,0,0,8"/>

                                    <TextBlock Text="CRASH 임계값 (%):"
                                               Grid.Row="36"
                                               Foreground="#E2E8F0"/>
                                    <TextBox x:Name="txtCrashThreshold"
                                             Grid.Row="36"
                                             Grid.Column="1"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="PUMP 임계값 (%):"
                                               Grid.Row="37"
                                               Foreground="#E2E8F0"/>
                                    <TextBox x:Name="txtPumpDetectThreshold"
                                             Grid.Row="37"
                                             Grid.Column="1"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="최소 동시 코인 수:"
                                               Grid.Row="38"
                                               Foreground="#E2E8F0"/>
                                    <TextBox x:Name="txtCrashMinCoinCount"
                                             Grid.Row="38"
                                             Grid.Column="1"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="리버스 사이즈 (%):"
                                               Grid.Row="39"
                                               Foreground="#E2E8F0"/>
                                    <TextBox x:Name="txtCrashReverseSize"
                                             Grid.Row="39"
                                             Grid.Column="1"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="쿨다운 (초):"
                                               Grid.Row="40"
                                               Foreground="#E2E8F0"/>
                                    <TextBox x:Name="txtCrashCooldown"
                                             Grid.Row="40"
                                             Grid.Column="1"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>
                                </Grid>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Transformer">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Background="#161925"
                                    CornerRadius="10"
                                    Padding="20"
                                    Margin="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="210"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="ADX Period:"
                                               VerticalAlignment="Center"
                                               Grid.Row="0"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
                                    <TextBox x:Name="txtTfAdxPeriod"
                                             Grid.Row="0"
                                             Grid.Column="1"
                                             Margin="0,0,0,15"
                                             Padding="8"
                                             Background="#1E2235"
                                             Foreground="White"
                                             BorderBrush="#2D3142"/>

                                    <TextBlock Text="ADX 횡보 임계값:"
                                               VerticalAlignment="Center"
                                               Grid.Row="1"
                                               Foreground="#94A3B8"
                                               Margin="0,0,0,15"/>
