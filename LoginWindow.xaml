<Window x:Class="TradingBot.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TradingBot Login" Height="600" Width="350" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="Transparent">
    
    <Border CornerRadius="20" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 상단 바 (드래그 이동 가능하게 하려면 코드 비하인드 추가 필요) -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Right" Orientation="Horizontal" Margin="10">
                <Button Content="✕" Width="30" Height="30" Background="Transparent" Foreground="Gray" BorderThickness="0" FontSize="16" Click="btnClose_Click" Cursor="Hand"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
                <StackPanel VerticalAlignment="Top" Margin="40,10,40,40">
                    <!-- 로고 이미지 -->
                    <Image Source="trading_bot.ico" Width="64" Height="64" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="QUANTUM BOT" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="Sign in to continue" Foreground="#888" FontSize="12" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                
                    <TextBlock Text="Username" Foreground="#AAA" FontSize="12" Margin="0,0,0,5"/>
                    <Border CornerRadius="5" Background="#2D2D2D" Height="35" Margin="0,0,0,15">
                        <TextBox x:Name="txtUsername" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                    </Border>
                
                    <TextBlock Text="Password" Foreground="#AAA" FontSize="12" Margin="0,0,0,5"/>
                    <Border CornerRadius="5" Background="#2D2D2D" Height="35" Margin="0,0,0,15">
                        <PasswordBox x:Name="txtPassword" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" Padding="10,0"/>
                    </Border>
                
                    <CheckBox x:Name="chkAutoLogin" Content="Remember me" Foreground="#AAA" FontSize="12" Margin="0,0,0,20"/>
                
                    <Button x:Name="btnLogin" Content="LOGIN" Height="40" Margin="0,0,0,15" IsDefault="True"
                            Background="#00E676" Foreground="Black" FontWeight="Bold" BorderThickness="0" Click="btnLogin_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock Text="Don't have an account?" Foreground="#666" FontSize="12"/>
                            <Button x:Name="btnSignUp" Content="Sign Up" Margin="5,0,0,0" FontSize="12"
                                    Background="Transparent" Foreground="#00E676" BorderThickness="0" Click="btnSignUp_Click" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" TextDecorations="Underline"/>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                        
                        <Button x:Name="btnForgotPassword" Content="Forgot Password?" FontSize="11"
                                Background="Transparent" Foreground="#888" BorderThickness="0" Click="btnForgotPassword_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>