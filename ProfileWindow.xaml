<Window x:Class="TradingBot.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="정보 수정" Height="550" Width="450" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#0F111A" Foreground="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="🔑 API 키 관리" FontSize="18" FontWeight="Bold" Foreground="#00E676" Margin="0,0,0,20"/>

            <TextBlock Text="Binance API Key" Margin="0,5"/>
            <PasswordBox x:Name="txtBinanceKey" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>
            <TextBlock Text="Binance Secret Key" Margin="0,5"/>
            <PasswordBox x:Name="txtBinanceSecret" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

            <Separator Background="#2D3142" Margin="0,15"/>

            <TextBlock Text="Bybit API Key" Margin="0,5"/>
            <PasswordBox x:Name="txtBybitKey" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>
            <TextBlock Text="Bybit Secret Key" Margin="0,5"/>
            <PasswordBox x:Name="txtBybitSecret" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

            <Separator Background="#2D3142" Margin="0,15"/>

            <TextBlock Text="Bitget API Key" Margin="0,5"/>
            <PasswordBox x:Name="txtBitgetKey" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>
            <TextBlock Text="Bitget Secret Key" Margin="0,5"/>
            <PasswordBox x:Name="txtBitgetSecret" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>
            <TextBlock Text="Bitget Passphrase" Margin="0,5"/>
            <PasswordBox x:Name="txtBitgetPassphrase" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

            <Separator Background="#2D3142" Margin="0,15"/>

            <TextBlock Text="Telegram Bot Token" Margin="0,5"/>
            <TextBox x:Name="txtBotToken" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>
            <TextBlock Text="Telegram Chat ID" Margin="0,5"/>
            <TextBox x:Name="txtChatId" Height="30" Background="#1E2235" Foreground="White" BorderBrush="#2D3142"/>

            <Button x:Name="btnSave" Content="저장하기" Height="40" Margin="0,20,0,0" 
                    Background="#00E676" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="btnSave_Click"/>
        </StackPanel>
    </ScrollViewer>
</Window>