<Window x:Class="TradingBot.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="정보 수정"
        Height="550"
        Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStyle="None">
        <WindowChrome.WindowChrome>
                <WindowChrome CaptionHeight="40"
                                ResizeBorderThickness="5"
                              GlassFrameThickness="0"
                                CornerRadius="0"/>
        </WindowChrome.WindowChrome>
        <Window.Resources>
                <Style x:Key="WindowControlButtonStyle"
                                TargetType="Button">
                        <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                                        Value="True"/>
                        <Setter Property="Background"
                                        Value="Transparent"/>
                        <Setter Property="Foreground"
                                        Value="#94A3B8"/>
                        <Setter Property="BorderThickness"
                                        Value="0"/>
                        <Setter Property="Width"
                                        Value="46"/>
                        <Setter Property="Height"
                                        Value="32"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                        Value="True">
                                                                <Setter Property="Background"
                                                                                Value="#333"/>
                                                                <Setter Property="Foreground"
                                                                                Value="White"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>
                <Style x:Key="ModernWindowStyle"
                                TargetType="Window">
                        <Setter Property="Background"
                                        Value="#121212"/>
                        <Setter Property="Foreground"
                                        Value="White"/>
                        <Setter Property="FontFamily"
                                        Value="Segoe UI"/>
                        <Setter Property="WindowStyle"
                                        Value="None"/>
                        <Setter Property="ResizeMode"
                                        Value="CanResize"/>
                        <Setter Property="WindowChrome.WindowChrome">
                                <Setter.Value>
                                        <WindowChrome CaptionHeight="40"
                                                        ResizeBorderThickness="5"
                                                      GlassFrameThickness="0"
                                                        CornerRadius="0"/>
                                </Setter.Value>
                        </Setter>
                </Style>
        </Window.Resources>
        <Border BorderBrush="#333"
                        BorderThickness="1"
                        Background="#1E1E1E">
                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Title Bar -->
                        <Grid Grid.Row="0"
                                        Background="Transparent"
                                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                                <TextBlock Text="PROFILE SETTINGS"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="10,0,0,0"
                                                Foreground="White"
                                                FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top">
                                        <Button Content="—"
                                                        Style="{StaticResource WindowControlButtonStyle}"
                                                        Click="OnMinimize_Click"/>
                                        <Button Content="☐"
                                                        Style="{StaticResource WindowControlButtonStyle}"
                                                        Click="OnMaximize_Click"/>
                                        <Button Content="✕"
                                                        Click="OnClose_Click">
                                                <Button.Style>
                                                        <Style TargetType="Button"
                                                                        BasedOn="{StaticResource WindowControlButtonStyle}">
                                                                <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver"
                                                                                        Value="True">
                                                                                <Setter Property="Background"
                                                                                                Value="#E81123"/>
                                                                                <Setter Property="Foreground"
                                                                                                Value="White"/>
                                                                        </Trigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                </StackPanel>
                        </Grid>

                        <!-- Original Content -->
                        <ScrollViewer Grid.Row="1"
                                        VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="20">
                                        <TextBlock Text="🔑 API 키 관리"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#00E676"
                                                   Margin="0,0,0,20"/>

                                        <TextBlock Text="Binance API Key"
                                                   Margin="0,5"/>
                                        <PasswordBox x:Name="txtBinanceKey"
                                                     Height="30"
                                                     Background="#1E2235"
                                                     Foreground="White"
                                                     BorderBrush="#2D3142"
                                                        BorderThickness="0"
                                                        VerticalContentAlignment="Center"
                                                        Padding="10,0"/>
                                        <TextBlock Text="Binance Secret Key"
                                                   Margin="0,5"/>
                                        <PasswordBox x:Name="txtBinanceSecret"
                                                     Height="30"
                                                     Background="#1E2235"
                                                     Foreground="White"
                                                     BorderBrush="#2D3142"
                                                        BorderThickness="0"
                                                        VerticalContentAlignment="Center"
                                                        Padding="10,0"/>

                                        <Separator Background="#2D3142"
                                                   Margin="0,15"/>

                                        <TextBlock Text="🎮 시뮬레이션 (Binance Testnet)"
                                                   FontSize="14" FontWeight="Bold"
                                                   Foreground="#FFC107" Margin="0,0,0,5"/>
                                        <TextBlock Text="demo.binancefuture.com에서 API 키를 발급받으세요"
                                                   FontSize="10" Foreground="#94A3B8" Margin="0,0,0,8"/>

                                        <TextBlock Text="Testnet API Key"
                                                   Margin="0,5"/>
                                        <PasswordBox x:Name="txtTestnetKey"
                                                     Height="30"
                                                     Background="#1E2235"
                                                     Foreground="White"
                                                     BorderBrush="#2D3142"
                                                        BorderThickness="0"
                                                        VerticalContentAlignment="Center"
                                                        Padding="10,0"/>
                                        <TextBlock Text="Testnet Secret Key"
                                                   Margin="0,5"/>
                                        <PasswordBox x:Name="txtTestnetSecret"
                                                     Height="30"
                                                     Background="#1E2235"
                                                     Foreground="White"
                                                     BorderBrush="#2D3142"
                                                        BorderThickness="0"
                                                        VerticalContentAlignment="Center"
                                                        Padding="10,0"/>

                                        <Separator Background="#2D3142"
                                                   Margin="0,15"/>

                                        <TextBlock Text="Telegram Bot Token"
                                                   Margin="0,5"/>
                                        <TextBox x:Name="txtBotToken"
                                                 Height="30"
                                                 Background="#1E2235"
                                                 Foreground="White"
                                                 BorderBrush="#2D3142"
                                                        BorderThickness="0"
                                                        VerticalContentAlignment="Center"
                                                        Padding="10,0"/>
                                        <TextBlock Text="Telegram Chat ID"
                                                   Margin="0,5"/>
                                        <TextBox x:Name="txtChatId"
                                                 Height="30"
                                                 Background="#1E2235"
                                                 Foreground="White"
                                                 BorderBrush="#2D3142"
                                                        BorderThickness="0"
                                                        VerticalContentAlignment="Center"
                                                        Padding="10,0"/>

                                        <Button x:Name="btnSave"
                                                Content="저장하기"
                                                Height="40"
                                                Margin="0,20,0,0"
                                                Background="#00E676"
                                                Foreground="Black"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="btnSave_Click"/>
                                </StackPanel>
                        </ScrollViewer>
                </Grid>
        </Border>
</Window>
