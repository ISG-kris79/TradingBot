<?xml version="1.0" encoding="utf-8"?>
<!--
Velopack 배포 및 GitHub 릴리스 자동화 프로필
사용법: Visual Studio에서 [빌드] > [게시] > "VelopackRelease" 선택
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <PublishDir>E:\게시\fu_coin</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <_TargetId>Folder</_TargetId>
    <TargetFramework>net9.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- ko 언어 리소스만 포함 -->
    <SatelliteResourceLanguages>ko</SatelliteResourceLanguages>
  </PropertyGroup>
  <!-- 게시 후 자동으로 Velopack 패키징 및 GitHub 릴리스 실행 -->
  <Target Name="PostPublishActions" AfterTargets="Publish">
    <Message Text="========================================" Importance="high" />
    <Message Text="Velopack 패키징 및 GitHub 릴리스 시작" Importance="high" />
    <Message Text="========================================" Importance="high" />
    <!-- PowerShell 스크립트 실행 -->
    <Exec Command="powershell -ExecutionPolicy Bypass -File &quot;$(ProjectDir)..\..\publish-and-release.ps1&quot; -PublishPath &quot;$(PublishDir.TrimEnd('\'))&quot; -Version &quot;$(Version)&quot;" IgnoreExitCode="false" ConsoleToMSBuild="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="ScriptOutput" />
    </Exec>
    <Message Text="$(ScriptOutput)" Importance="high" />
  </Target>
</Project>