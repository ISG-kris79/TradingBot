<Project>
  <PropertyGroup>
    <AssemblyName>TradingBot</AssemblyName>
    <IntermediateOutputPath>obj\x64\Debug\</IntermediateOutputPath>
    <BaseIntermediateOutputPath>obj\</BaseIntermediateOutputPath>
    <MSBuildProjectExtensionsPath>E:\PROJECT\CoinFF\TradingBot\TradingBot\obj\</MSBuildProjectExtensionsPath>
    <_TargetAssemblyProjectName>TradingBot</_TargetAssemblyProjectName>
    <RootNamespace>TradingBot</RootNamespace>
  </PropertyGroup>
  <Import Project="Sdk.props" Sdk="Microsoft.NET.Sdk" />
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Platforms>AnyCPU;x64</Platforms>
    <ApplicationIcon>trading_bot.ico</ApplicationIcon>
    <!-- WPF MarkupCompile 임시 어셈블리 생성 비활성화 -->
    <GenerateTemporaryTargetAssembly>false</GenerateTemporaryTargetAssembly>
    <!-- WPF 디자인타임 빌드 무시 -->
    <DesignTimeBuild>false</DesignTimeBuild>
    <!-- SDK 자동 AssemblyInfo 생성 활성화 (.csproj 버전 정보 사용) -->
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <UserSecretsId>dfccb0df-ed10-4b34-b169-e0e2db206589</UserSecretsId>
    <LangVersion>latest</LangVersion>
    <Version>2.4.37</Version>
    <AssemblyVersion>2.4.37.0</AssemblyVersion>
    <FileVersion>2.4.37.0</FileVersion>
    <NoWarn>$(NoWarn);NU1701</NoWarn>
    <Company>TradingBot</Company>
    <Product>CoinFF TradingBot</Product>
    <Description>Cryptocurrency Trading Bot with AI/ML capabilities</Description>
    <!-- ko 언어 리소스만 포함 -->
    <SatelliteResourceLanguages>ko</SatelliteResourceLanguages>
    <!-- app.manifest 포함 -->
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- [Phase 16] 자체 포함 배포 설정 - Windows Desktop Runtime 포함 -->
    <RuntimeIdentifier Condition="'$(RuntimeIdentifier)' == ''">win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <UseAppHost>true</UseAppHost>
    <InvariantGlobalization>false</InvariantGlobalization>
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <PublishSingleFile>false</PublishSingleFile>
    <DebugType>pdbonly</DebugType>
    <!-- Velopack용 임시 디렉터리 -->
    <VelopackRid>win-x64</VelopackRid>
    <!-- ucrtbase.dll 호환성 개선 -->
    <EnableIncludeSourceLink>false</EnableIncludeSourceLink>
    <DebugSymbols>true</DebugSymbols>
    <TieredCompilation>true</TieredCompilation>
    <TieredCompilationQuickJit>true</TieredCompilationQuickJit>
  </PropertyGroup>
  <ItemGroup>
    <!-- WPF Window Icon용 (어셈블리에 임베드) -->
    <!-- 시스템 트레이 및 출력 폴더용 -->
    <Content Include="trading_bot.ico">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <!-- Mobile MAUI 파일 제외 -->
    <None Remove="Mobile/**/*" />
    <None Remove="Releases\**" />
    <None Remove="TradingBot.Web/**/*" />
