<Window x:Class="TradingBot.BacktestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:TradingBot"
        mc:Ignorable="d"
        Title="Backtest Result"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:GreaterThanConverter x:Key="GreaterThanConverter"/>
        <local:LessThanConverter x:Key="LessThanConverter"/>
        <Style x:Key="WindowControlButtonStyle"
                TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                    Value="True"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#94A3B8"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="46"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#333"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernWindowStyle"
                TargetType="Window">
            <Setter Property="Background"
                    Value="#121212"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="WindowStyle"
                    Value="None"/>
            <Setter Property="ResizeMode"
                    Value="CanResize"/>
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                                  GlassFrameThickness="0"
                            CornerRadius="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#333"
            BorderThickness="1"
            Background="#1E1E1E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="{Binding WindowTitle}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="—"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMinimize_Click"/>
                    <Button Content="☐"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMaximize_Click"/>
                    <Button Content="✕"
                            Click="OnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource WindowControlButtonStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E81123"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Original Content -->
            <Grid Grid.Row="1"
                  Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 1. 寃곌낵 ?붿빟 -->
                <Border Grid.Row="0"
                        Background="#161925"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Total Profit"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding Result.TotalProfit, StringFormat={}{0:N2} USDT}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{Binding ProfitColor}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Profit %"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding Result.ProfitPercentage, StringFormat={}{0:F2}%}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{Binding ProfitColor}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Win Rate"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding Result.WinRate, StringFormat={}{0:F1}%}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#3B82F6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Max Drawdown"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding Result.MaxDrawdown, StringFormat={}{0:F2}%}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#EF4444"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="#101826"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="테스트 정보"
                                   Foreground="#93C5FD"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding StrategySummary}"
                                   Foreground="#E5E7EB"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding MessageSummary}"
                                   Foreground="#CBD5E1"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding PeriodSummary}"
                                   Foreground="#94A3B8"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding DatasetSummary}"
                                   Foreground="#94A3B8"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="#0F172A"
                        BorderBrush="#243041"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,12"
                        Visibility="{Binding HasTopTrials, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="OPTIMIZE TOP 5 TRIALS"
                                   Foreground="#93C5FD"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8"/>
                        <DataGrid ItemsSource="{Binding TopTrials}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  RowHeight="28"
                                  Background="#111827"
                                  Foreground="#E5E7EB"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="Background" Value="#111827"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Rank}" Value="1">
                                            <Setter Property="Background" Value="#3F2E00"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rank}" Value="2">
                                            <Setter Property="Background" Value="#2F3545"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Rank}" Value="3">
                                            <Setter Property="Background" Value="#3A2A1E"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="🏅"
                                                    Binding="{Binding Medal}"
                                                    Width="45">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="15"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="#"
                                                    Binding="{Binding Rank}"
                                                    SortMemberPath="Rank"
                                                    Width="45"/>
                                <DataGridTextColumn Header="Trial"
                                                    Binding="{Binding TrialId}"
                                                    SortMemberPath="TrialId"
                                                    Width="80"/>
                                <DataGridTextColumn Header="Final Balance"
                                                    Binding="{Binding FinalBalance, StringFormat={}{0:N2}}"
                                                    SortMemberPath="FinalBalance"
                                                    Width="130"/>
                                <DataGridTextColumn Header="Profit %"
                                                    Binding="{Binding ProfitPercent, StringFormat={}{0:F2}%}"
                                                    SortMemberPath="ProfitPercent"
                                                    Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="Foreground" Value="#E5E7EB"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ProfitPercent}" Value="0">
                                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ProfitPercent, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ProfitPercent, Converter={StaticResource LessThanConverter}, ConverterParameter=0}" Value="True">
                                                    <Setter Property="Foreground" Value="#EF4444"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Parameters"
                                                    Binding="{Binding Parameters}"
                                                    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- 2. 李⑦듃 -->
                <lvc:CartesianChart Grid.Row="3"
                                    Series="{Binding ChartSeries}"
                                    LegendLocation="Bottom"
                                    Hoverable="True"
                                    DataTooltip="{x:Null}">
                    <lvc:CartesianChart.ChartLegend>
                        <lvc:DefaultLegend Foreground="White"/>
                    </lvc:CartesianChart.ChartLegend>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Time"
                                  Labels="{Binding Labels}"
                                  Foreground="#94A3B8">
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="#2D3142"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Price"
                                  LabelFormatter="{Binding Formatter}"
                                  Foreground="#94A3B8">
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="#2D3142"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Grid>
    </Border>
</Window>

