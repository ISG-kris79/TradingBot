<Window x:Class="TradingBot.BacktestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:TradingBot"
        mc:Ignorable="d"
        Title="Backtest Result"
        Height="600"
        Width="1000"
        WindowStartupLocation="CenterOwner"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStyle="None">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
                TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                    Value="True"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#94A3B8"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="46"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter Property="Background"
                                        Value="#333"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernWindowStyle"
                TargetType="Window">
            <Setter Property="Background"
                    Value="#121212"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="WindowStyle"
                    Value="None"/>
            <Setter Property="ResizeMode"
                    Value="CanResize"/>
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome CaptionHeight="40"
                            ResizeBorderThickness="5"
                                  GlassFrameThickness="0"
                            CornerRadius="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#333"
            BorderThickness="1"
            Background="#1E1E1E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="{Binding WindowTitle}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="—"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMinimize_Click"/>
                    <Button Content="☐"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMaximize_Click"/>
                    <Button Content="✕"
                            Click="OnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource WindowControlButtonStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E81123"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Original Content -->
            <Grid Grid.Row="1"
                  Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 1. 寃곌낵 ?붿빟 -->
                <Border Grid.Row="0"
                        Background="#161925"
                        CornerRadius="8"
                        Padding="15"
                        Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Total Profit"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding Result.TotalProfit, StringFormat={}{0:N2} USDT}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{Binding ProfitColor}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Profit %"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding Result.ProfitPercentage, StringFormat={}{0:F2}%}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{Binding ProfitColor}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Win Rate"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding Result.WinRate, StringFormat={}{0:F1}%}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#3B82F6"/>
                        </StackPanel>

                        <StackPanel Grid.Column="3"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="Max Drawdown"
                                       Foreground="#94A3B8"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding Result.MaxDrawdown, StringFormat={}{0:F2}%}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#EF4444"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 2. 李⑦듃 -->
                <lvc:CartesianChart Grid.Row="1"
                                    Series="{Binding ChartSeries}"
                                    LegendLocation="Bottom"
                                    Hoverable="True"
                                    DataTooltip="{x:Null}">
                    <lvc:CartesianChart.ChartLegend>
                        <lvc:DefaultLegend Foreground="White"/>
                    </lvc:CartesianChart.ChartLegend>
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis Title="Time"
                                  Labels="{Binding Labels}"
                                  Foreground="#94A3B8">
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="#2D3142"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis Title="Price"
                                  LabelFormatter="{Binding Formatter}"
                                  Foreground="#94A3B8">
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="#2D3142"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Grid>
    </Border>
</Window>

