<Window x:Class="TradingBot.ActivePnLWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="실시간 포지션 수익률" Height="400" Width="600" 
        Background="#0F111A" Foreground="White" Topmost="True">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="📊 Active Positions PnL" FontSize="16" FontWeight="Bold" Foreground="#00E676" Margin="0,0,0,10"/>

        <lvc:CartesianChart Grid.Row="1" Series="{Binding ActivePnLSeries}" LegendLocation="None">
            <lvc:CartesianChart.AxisX>
                <lvc:Axis Labels="{Binding ActivePnLLabels}" LabelsRotation="0">
                    <lvc:Axis.Separator><lvc:Separator Step="1"/></lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisX>
            <lvc:CartesianChart.AxisY>
                <lvc:Axis Title="Profit (%)" LabelFormatter="{Binding PnLFormatter}"/>
            </lvc:CartesianChart.AxisY>
        </lvc:CartesianChart>
    </Grid>
</Window>