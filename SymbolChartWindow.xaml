<Window x:Class="TradingBot.SymbolChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        mc:Ignorable="d"
        Title="심볼 차트"
        Height="640"
        Width="980"
        MinWidth="760"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        Background="#0F111A">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Foreground="#E2E8F0"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,8">
            <Run Text="SYMBOL: "/>
            <Run Text="{Binding SelectedSymbol.Symbol}"/>
        </TextBlock>

        <Border Grid.Row="1"
                Background="#111827"
                BorderBrush="#2D3142"
                BorderThickness="1"
                CornerRadius="10"
                Padding="8">
            <Grid>
                <TextBlock Text="심볼을 선택하면 차트가 표시됩니다."
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsLiveChartEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <lvc:CartesianChart Series="{Binding LiveChartSeries}"
                                    LegendLocation="Right"
                                    Hoverable="False"
                                    DataTooltip="{x:Null}">
                    <lvc:CartesianChart.AxisX>
                        <lvc:Axis LabelsRotation="-15"
                                  ShowLabels="{Binding IsLiveChartEmpty, Converter={StaticResource InvertBooleanConverter}}"
                                  Foreground="#94A3B8"
                                  LabelFormatter="{Binding LiveChartXFormatter}">
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="#2D3142"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisX>
                    <lvc:CartesianChart.AxisY>
                        <lvc:Axis ShowLabels="{Binding IsLiveChartEmpty, Converter={StaticResource InvertBooleanConverter}}"
                                  Foreground="#94A3B8"
                                  LabelFormatter="{Binding LiveChartYFormatter}">
                            <lvc:Axis.Separator>
                                <lvc:Separator Stroke="#2D3142"/>
                            </lvc:Axis.Separator>
                        </lvc:Axis>
                    </lvc:CartesianChart.AxisY>
                </lvc:CartesianChart>
            </Grid>
        </Border>
    </Grid>
</Window>
