                            <TextBlock Text="{Binding TradeHistory.Count, StringFormat='Total: {0} records'}"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Stats Panel -->
                        <Border Grid.Row="1"
                                Style="{StaticResource CardStyle}"
                                Padding="24"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="WIN RATE"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL PROFIT"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProfit, StringFormat={}{0:N2} USDT}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource LessThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="AVERAGE ROI"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding AverageRoe, StringFormat={}{0:F2}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL TRADES"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TradeHistory.Count}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Trade History Grid -->
                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}"
                                Padding="0"
                                Margin="0">
                            <DataGrid ItemsSource="{Binding TradeHistory}"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="STATUS"
                                                            Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4"
                                                        Padding="8,4"
                                                        ToolTip="{Binding ExitReason}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"
                                                                    Value="#334155"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOpenPosition}"
                                                                             Value="True">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding PositionStatus}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="TIME"
                                                        Binding="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                        Width="160"/>
                                    <DataGridTextColumn Header="SYMBOL"
                                                        Binding="{Binding Symbol}"
                                                        Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="SIDE"
                                                            Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4"
                                                        Padding="8,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Side}"
                                                                             Value="BUY">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource AccentBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Side}"
                                                                             Value="SELL">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource ErrorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Side}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="PRICE"
                                                            Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                            <Binding Path="Symbol"/>
                                                            <Binding Path="Price"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="STRATEGY"
                                                        Binding="{Binding Strategy}"
                                                        Width="150"/>
                                    <DataGridTextColumn Header="AI SCORE"
                                                        Binding="{Binding AiScore, StringFormat=F1}"
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Center"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="PNL (USDT)"
                                                        Binding="{Binding PnL, StringFormat=N2}"
                                                        Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Right"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PnL, Converter={StaticResource LessThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PnL, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ROE (%)"
                                                        Binding="{Binding PnLPercent, StringFormat={}{0:F2}%}"
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="SemiBold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- AI MONITOR TAB -->
                <TabItem Header="🤖  AI MONITOR">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <!-- Model Accuracy Cards -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="🎯 AI MODEL ACCURACY"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <TextBlock Text="기준: Confidence 60% 이상 샘플 기준 / 목표 정확도 65% 이상"
                                               FontSize="11"
                                               Foreground="#9CA3AF"
                                               Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Style="{StaticResource StatCardStyle}"
                                                Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="ML.NET"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding MLNetAccuracy, StringFormat={}{0:F1}%}"
                                                           FontSize="32"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource StatCardStyle}"
                                                Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Transformer"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding TransformerAccuracy, StringFormat={}{0:F1}%}"
                                                           FontSize="32"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource SecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Performance Comparison -->
                            <Border Style="{StaticResource CardStyle}"
                                    Padding="0">
                                <StackPanel Margin="20">
                                    <TextBlock Text="📊 MODEL PERFORMANCE COMPARISON"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <DataGrid ItemsSource="{Binding ModelPerformances}"
                                              Style="{StaticResource ModernDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="MODEL"
                                                                Binding="{Binding ModelName}"
                                                                Width="*"/>
                                            <DataGridTextColumn Header="ACCURACY (C≥60%)"
                                                                Binding="{Binding Accuracy, StringFormat={}{0:F2}%}"
                                                                Width="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight"
                                                                Value="Bold"/>
                                                        <Setter Property="Foreground"
                                                                Value="{Binding StatusColor}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="PREDICTIONS"
                                                                Binding="{Binding TotalPredictions}"
                                                                Width="120"/>
                                            <DataGridTextColumn Header="CORRECT"
                                                                Binding="{Binding CorrectPredictions}"
                                                                Width="100"/>
                                            <DataGridTextColumn Header="CONFIDENCE"
                                                                Binding="{Binding AvgConfidence, StringFormat={}{0:F2}%}"
                                                                Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Prediction Chart -->
                            <Border Style="{StaticResource CardStyle}"
                                    Height="350">
                                <StackPanel>
                                    <TextBlock Text="🔮 PREDICTION vs ACTUAL (Last 20)"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <lvc:CartesianChart Series="{Binding PredictionComparisonSeries}"
                                                        LegendLocation="Bottom"
                                                        Hoverable="True">
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="Price (USDT)"
                                                      MinValue="{Binding PredictionChartAxisMin}"
                                                      MaxValue="{Binding PredictionChartAxisMax}"
                                                      Foreground="#9CA3AF"
                                                      LabelFormatter="{Binding LiveChartYFormatter}"/>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="Prediction #"
                                                      Foreground="#9CA3AF"/>
                                        </lvc:CartesianChart.AxisX>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ADVANCED FEATURES TAB -->
                <TabItem Header="⚡ ADVANCED"
                         Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <!-- Arbitrage Panel -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💰 ARBITRAGE TRADING"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Min Profit (%):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtArbitrageMinProfit"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="0.2"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Scan Interval (s):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtArbitrageScanInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="60"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartArbitrage"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartArbitrage_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopArbitrage"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopArbitrage_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtArbitrageStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Fund Transfer Panel -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💱 FUND TRANSFER"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Check Interval (min):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtFundTransferInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="60"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Min Amount (USDT):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtFundTransferMinAmount"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="100"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartFundTransfer"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartFundTransfer_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopFundTransfer"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopFundTransfer_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtFundTransferStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Rebalancing Panel -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock Text="⚖ PORTFOLIO REBALANCING"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Check Interval (h):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtRebalancingInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="24"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Threshold (%):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtRebalancingThreshold"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="5.0"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartRebalancing"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartRebalancing_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopRebalancing"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopRebalancing_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtRebalancingStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- NOTIFICATION BAR (Footer Messages) -->
            <Border Grid.Row="3"
                    Background="#1A1F3A"
                    BorderThickness="0,2,0,0"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    Padding="0">
                <Border.Effect>
                    <DropShadowEffect Color="{StaticResource PrimaryColor}"
                                      BlurRadius="8"
                                      ShadowDepth="0"
                                      Opacity="0.3"/>
                </Border.Effect>
                <Grid Height="48">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Status Icon -->
                    <Border Grid.Column="0"
                            Background="{StaticResource PrimaryBrush}"
                            Width="48"
                            Height="48">
                        <TextBlock Text="🔔"
                                   FontSize="24"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Footer Message -->
                    <Border Grid.Column="1"
                            Background="Transparent">
                        <TextBlock x:Name="lblFooter"
                                   Text="SYSTEM READY  •  WAITING FOR COMMAND"
                                   Foreground="#E0E7FF"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Margin="20,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="{StaticResource PrimaryColor}"
                                                  BlurRadius="4"
                                                  ShadowDepth="0"
                                                  Opacity="0.4"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- STATUS BAR -->
            <Border Grid.Row="4"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#2D3454"
                    CornerRadius="0,0,12,12">
                <Grid Margin="20,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="txtMajorProfileStatus"
                               Text="● Major Profile: Balanced"
                               Foreground="#9CA3AF"
                               FontSize="11"
                               Margin="0,0,16,0"/>
                        <TextBlock x:Name="txtTelegramStatus"
                                   Text="Telegram: Offline"
                                   Foreground="#6B7280"
                                   FontSize="11"
                                   Margin="0,0,16,0"/>
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{StaticResource AccentBrush}"
                                 Margin="0,0,6,0"/>
                        <TextBlock Text="Binance USDT-Futures  •  Connected"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
