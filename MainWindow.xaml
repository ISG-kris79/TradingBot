<Window x:Class="TradingBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:TradingBot"
        Title="Trading Bot" Height="900" Width="1400" 
        Background="{Binding MainBackground}" Foreground="{Binding TextForeground}" FontFamily="Segoe UI Semibold">

    <Window.Resources>
        <local:StatusToIconConverter x:Key="StatusToIconConverter"/>
        <local:GreaterThanConverter x:Key="GreaterThanConverter"/>
        <local:LessThanConverter x:Key="LessThanConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <Storyboard x:Key="FlashGreen">
            <ColorAnimation Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                        From="#00E676" To="White" Duration="0:0:0.8"/>
        </Storyboard>

        <Storyboard x:Key="FlashRed">
            <ColorAnimation Storyboard.TargetProperty="(Control.Foreground).(SolidColorBrush.Color)"
                        From="#FF5252" To="White" Duration="0:0:0.8"/>
        </Storyboard>
        <Storyboard x:Key="RowEntranceFlash">
            <ColorAnimation Storyboard.TargetProperty="(Panel.Background).(SolidColorBrush.Color)"
                        From="#00E676" To="#1A3A5A" Duration="0:0:2" 
                        AutoReverse="False" RepeatBehavior="1x"/>
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                         From="0.5" To="1.0" Duration="0:0:0.5" 
                         RepeatBehavior="2x"/>
        </Storyboard>
        <Style x:Key="ProButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" Background="{TemplateBinding Background}" CornerRadius="6" Padding="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder" Property="Background" Value="#2D3142"/>
                                <Setter Property="Foreground" Value="#575E75"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkColumnHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E2235"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#2D3142"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{Binding PanelBackground}" Padding="20,15" BorderBrush="{Binding BorderColor}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="AI COIN FUTURES" FontSize="20" FontWeight="Bold" Foreground="#00E676" VerticalAlignment="Center"/>
                    <TextBlock Text=" ENGINE" FontSize="20" FontWeight="Bold" Foreground="{Binding TextForeground}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <!-- [Agent 2] 레이아웃 설정 메뉴 -->
                    <Menu Background="Transparent" Margin="0,0,10,0" VerticalAlignment="Center">
                        <MenuItem Header="👁️ VIEW" Foreground="{Binding TextForeground}" FontWeight="Bold" Cursor="Hand">
                            <MenuItem.Resources>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </MenuItem.Resources>
                            <MenuItem Header="Account Summary" IsCheckable="True" IsChecked="{Binding IsAccountSummaryVisible}"/>
                            <MenuItem Header="Live Log &amp; Alerts" IsCheckable="True" IsChecked="{Binding IsLiveLogVisible}"/>
                            <MenuItem Header="Profit Chart" IsCheckable="True" IsChecked="{Binding IsChartVisible}"/>
                        </MenuItem>
                    </Menu>

                    <Button Content="👤" Width="40" Background="Transparent" BorderThickness="0" Foreground="{Binding TextForeground}" FontSize="16" Cursor="Hand" Click="btnProfile_Click" Margin="0,0,10,0" ToolTip="User Profile"/>
                    <Button Content="🌗" Width="40" Background="Transparent" BorderThickness="0" FontSize="16" Cursor="Hand" Command="{Binding ToggleThemeCommand}" Margin="0,0,10,0" ToolTip="Toggle Theme"/>
                    
                    <!-- 거래소 선택 ComboBox -->
                    <ComboBox x:Name="cmbExchange" Width="120" Margin="0,0,10,0" VerticalAlignment="Center" 
                              SelectedIndex="0" Background="White" Foreground="Black" BorderBrush="#2D3142">
                        <ComboBoxItem Content="Binance"/>
                        <ComboBoxItem Content="Bybit"/>
                        <ComboBoxItem Content="Bitget"/>
                    </ComboBox>
                    
                    <Button x:Name="btnBacktest" Content="BACKTEST" Width="100" Background="#3B82F6" Style="{StaticResource ProButtonStyle}" Margin="0,0,10,0" Click="btnBacktest_Click"/>
                    <Button x:Name="btnOptimize" Content="OPTIMIZE" Width="100" Background="#8B5CF6" Style="{StaticResource ProButtonStyle}" Margin="0,0,10,0" Click="btnOptimize_Click"/>
                    <Button x:Name="btnStart" Content="RUN" Width="140" Background="#10B981" Style="{StaticResource ProButtonStyle}" Margin="0,0,10,0" Click="btnStart_Click"/>
                    <Button x:Name="btnStop" Content="STOP" Width="100" Background="#EF4444" Style="{StaticResource ProButtonStyle}" IsEnabled="False" Click="btnStop_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <ProgressBar Grid.Row="1" x:Name="pgScanning" Height="4" Background="#0F111A" Foreground="#00E676" BorderThickness="0"/>

        <TabControl Grid.Row="2" Margin="15" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="0,0,10,0" Padding="10,5" Cursor="Hand">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#00E676"/>
                                        <Setter Property="Foreground" Value="#00E676"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="#64748B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="DASHBOARD">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">

                        <Grid Margin="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- [Agent 2] Visibility 바인딩 -->
                            <GroupBox Header="🏦 ACCOUNT SUMMARY" Grid.Column="0" Foreground="{Binding TextForeground}" BorderBrush="{Binding BorderColor}" Margin="0,0,5,0" Visibility="{Binding IsAccountSummaryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <UniformGrid Columns="2" Margin="10">
                                    <StackPanel VerticalAlignment="Center" Margin="5">
                                        <TextBlock Text="Total Equity" Foreground="#AAA" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="txtTotalEquity" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="{Binding TextForeground}"/>
                                    </StackPanel>
                                    <StackPanel VerticalAlignment="Center" Margin="5">
                                        <TextBlock Text="Available" Foreground="#AAA" FontSize="11" Margin="0,0,0,3"/>
                                        <TextBlock x:Name="txtAvailableBalance" Text="$0.00" FontSize="20" FontWeight="Bold" Foreground="{Binding TextForeground}"/>
                                    </StackPanel>
                                </UniformGrid>
                            </GroupBox>

                            <GroupBox Header="📊 STRATEGY SLOTS" Grid.Column="1" Foreground="{Binding TextForeground}" BorderBrush="{Binding BorderColor}" Margin="5,0,0,0" Visibility="{Binding IsAccountSummaryVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel VerticalAlignment="Center" Margin="10">
                                    <Grid Margin="0,2">
                                        <TextBlock Text="Ⓜ️ MAJOR" Foreground="Cyan" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtMajorSlot" Text="0 / 4" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,2">
                                        <TextBlock Text="🔥 PUMP" Foreground="Orange" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtPumpSlot" Text="0 / 2" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>

                                    <Separator Background="#444" Margin="0,8"/>

                                    <TextBlock x:Name="txtTotalPositionInfo" Text="Active Positions: 0" HorizontalAlignment="Center" Foreground="#888" FontSize="11"/>
                                </StackPanel>
                            </GroupBox>
                        </Grid>

                        <Border Background="{Binding PanelBackground}" CornerRadius="10" Padding="15" Height="180" Margin="0,0,0,10" Visibility="{Binding IsLiveLogVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="ENGINE LIVE ACTIVITY" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <ListBox x:Name="lstLiveLog" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{Binding SubTextForeground}" FontFamily="Consolas" FontSize="10"/>
                            </Grid>
                        </Border>

                        <Border Background="{Binding PanelBackground}" BorderBrush="#00E676" BorderThickness="0,2,0,0" CornerRadius="0,0,10,10" Padding="15" Height="220" Margin="0,0,0,10" Visibility="{Binding IsLiveLogVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="CRITICAL ALERTS" Foreground="#00E676" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <ListBox x:Name="lstAlerts" Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="{Binding TextForeground}" FontFamily="Consolas" FontSize="11"/>
                            </Grid>
                        </Border>

                        <Border Background="{Binding PanelBackground}" CornerRadius="10" Padding="18" Height="180" Visibility="{Binding IsChartVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <lvc:CartesianChart Hoverable="False">
                                <lvc:CartesianChart.Series>
                                    <lvc:LineSeries Values="{Binding ProfitHistory}" PointGeometry="{x:Null}" Stroke="#00E676" Fill="Transparent" StrokeThickness="2"/>
                                </lvc:CartesianChart.Series>
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis ShowLabels="False"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Foreground="#475569" FontSize="10"/>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Border>
                    </StackPanel>

                    <!-- [Phase 5] 실시간 심볼 차트 -->
                    <Border Grid.Row="1" Background="{Binding PanelBackground}" CornerRadius="10" Padding="5" Margin="0,10,0,0">
                        <Grid>
                            <TextBlock Text="Select a symbol from the list to view chart" Foreground="{Binding SubTextForeground}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsLiveChartEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <lvc:CartesianChart Series="{Binding LiveChartSeries}" LegendLocation="None" Hoverable="False" DataTooltip="{x:Null}">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis LabelsRotation="-15" ShowLabels="{Binding IsLiveChartEmpty, Converter={StaticResource InvertBooleanConverter}}" Foreground="#94A3B8" LabelFormatter="{Binding LiveChartXFormatter}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#2D3142" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis ShowLabels="{Binding IsLiveChartEmpty, Converter={StaticResource InvertBooleanConverter}}" Foreground="#94A3B8" LabelFormatter="{Binding LiveChartYFormatter}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#2D3142" />
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="{Binding PanelBackground}" CornerRadius="10" Padding="5">
                        <DataGrid x:Name="dgMultiTimeframe" AutoGenerateColumns="False" Background="Transparent" 
                                  Foreground="{Binding TextForeground}" BorderThickness="0" CanUserAddRows="False" RowHeight="50"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{Binding BorderColor}"
                                  ColumnHeaderStyle="{StaticResource DarkColumnHeader}" CanUserSortColumns="True"
                                    EnableRowVirtualization="True"
                                    VirtualizingStackPanel.IsVirtualizing="True">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridRow">
                                                <Border x:Name="RowBorder" 
                                    Background="{Binding DataContext.PanelBackground, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    BorderBrush="{Binding DataContext.BorderColor, RelativeSource={RelativeSource AncestorType=Window}}" 
                                    BorderThickness="0,0,0,1">
                                                    <SelectiveScrollingGrid>
                                                        <SelectiveScrollingGrid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </SelectiveScrollingGrid.ColumnDefinitions>
                                                        <DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                    </SelectiveScrollingGrid>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsPositionActive}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <ColorAnimation Storyboard.TargetName="RowBorder"
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                From="#00E676" To="#1A3A5A" Duration="0:0:1.5"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <Setter TargetName="RowBorder" Property="Background" Value="#1A3A5A"/>
                                                        <Setter Property="Foreground" Value="#FFD700"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>

                                                    <!-- [추가] 수익률 양수(>0)일 때 배경색 은은한 초록색 깜빡임 효과 -->
                                                    <DataTrigger Binding="{Binding ProfitRate, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="ProfitBlinkAnim">
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <ColorAnimation Storyboard.TargetName="RowBorder"
                                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                    To="#0A351C" Duration="0:0:1.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="ProfitBlinkAnim"/>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>

                                                    <!-- [추가] 수익률 음수(<0)일 때 배경색 은은한 붉은색 깜빡임 효과 -->
                                                    <DataTrigger Binding="{Binding ProfitRate, Converter={StaticResource LessThanConverter}, ConverterParameter=0}" Value="True">
                                                        <DataTrigger.EnterActions>
                                                            <BeginStoryboard x:Name="LossBlinkAnim">
                                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                                    <ColorAnimation Storyboard.TargetName="RowBorder"
                                                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                    To="#350A0A" Duration="0:0:1.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </DataTrigger.EnterActions>
                                                        <DataTrigger.ExitActions>
                                                            <StopStoryboard BeginStoryboardName="LossBlinkAnim"/>
                                                        </DataTrigger.ExitActions>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SYMBOL" Binding="{Binding Symbol}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPositionActive}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard Storyboard="{StaticResource FlashGreen}"/>
                                                    </DataTrigger.EnterActions>
                                                    <Setter Property="Foreground" Value="LimeGreen"/>
                                                    <Setter Property="FontWeight" Value="ExtraBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="PRICE" Binding="{Binding LastPrice, StringFormat=N2}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontFamily" Value="Consolas"/>
                                            <Setter Property="Margin" Value="0,0,10,0"/>
                                            <Setter Property="Foreground" Value="{Binding PriceColor}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="RSI (15m)" Binding="{Binding RSI_1H, StringFormat=N1}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RSI_1H, Converter={StaticResource LessThanConverter}, ConverterParameter=30.0001}" Value="True">
                                                    <Setter Property="Foreground" Value="Cyan"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RSI_1H, Converter={StaticResource GreaterThanConverter}, ConverterParameter=69.9999}" Value="True">
                                                    <Setter Property="Foreground" Value="Orange"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RSI_1H, Converter={StaticResource GreaterThanConverter}, ConverterParameter=69.9999}" Value="True">
                                                    <Setter Property="Foreground" Value="Orange"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="AI SCORE" Binding="{Binding AIScore, StringFormat={}{0}%}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding AIScoreColor}"/>
                                            <Setter Property="FontWeight" Value="ExtraBold"/>
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="DECISION" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding DecisionBg}" CornerRadius="4" Padding="8,3" Margin="4">
                                                <TextBlock Text="{Binding Decision}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="BB POSITION" Binding="{Binding BBPosition}" Width="110">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Center"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="STATUS &amp; STRATEGY" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToIconConverter}}" 
                                           FontSize="16" Margin="0,0,8,0"/>

                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ExitStrategySummary}" 
                                               FontSize="11" Foreground="Gray"/>
                                                    <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Danger">
                                                                        <Setter Property="Foreground" Value="Red"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="TakeProfitReady">
                                                                        <Setter Property="Foreground" Value="Lime"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="STRATEGY / VOL" Binding="{Binding StrategyName}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontStyle" Value="Italic"/>
                                            <Setter Property="Foreground" Value="#475569"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Margin" Value="10,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="PROFIT (%)" Width="100">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="ProfitRate" StringFormat="{}{0:F2}%" Mode="OneWay"/>
                                    </DataGridTextColumn.Binding>
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding ProfitColor}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                            <!-- [추가] 수동 청산 버튼 컬럼 -->
                            <DataGridTemplateColumn Header="ACTION" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="CLOSE" 
                                                Command="{Binding DataContext.ClosePositionCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                CommandParameter="{Binding Symbol}"
                                                Background="#EF4444" Foreground="White" FontWeight="Bold" FontSize="10"
                                                Padding="5,2" BorderThickness="0" Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPositionActive}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="TRADE HISTORY">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Start Date:" VerticalAlignment="Center" Foreground="{Binding SubTextForeground}" Margin="0,0,10,0"/>
                        <DatePicker SelectedDate="{Binding StartDate}" Width="120" Margin="0,0,20,0" VerticalContentAlignment="Center"/>

                        <TextBlock Text="End Date:" VerticalAlignment="Center" Foreground="{Binding SubTextForeground}" Margin="0,0,10,0"/>
                        <DatePicker SelectedDate="{Binding EndDate}" Width="120" Margin="0,0,20,0" VerticalContentAlignment="Center"/>

                        <Button Content="SEARCH" Command="{Binding LoadHistoryCommand}" Width="100" Background="#3B82F6" Style="{StaticResource ProButtonStyle}"/>
                        
                        <TextBlock Text="{Binding TradeHistory.Count, StringFormat='Total: {0} Records'}" VerticalAlignment="Center" Foreground="{Binding SubTextForeground}" Margin="20,0,0,0"/>
                    </StackPanel>

                    <!-- 통계 차트 패널 -->
                    <Border Grid.Row="1" Background="{Binding PanelBackground}" BorderBrush="{Binding BorderColor}" 
                            BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- 승률 -->
                            <StackPanel Grid.Column="0" Margin="10">
                                <TextBlock Text="승률" FontSize="12" Foreground="{Binding SubTextForeground}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}" FontSize="24" FontWeight="Bold" 
                                           Foreground="#00E676" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- 총 수익 -->
                            <StackPanel Grid.Column="1" Margin="10">
                                <TextBlock Text="총 수익" FontSize="12" Foreground="{Binding SubTextForeground}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding TotalProfit, StringFormat={}{0:N2} USDT}" FontSize="24" FontWeight="Bold" 
                                           HorizontalAlignment="Center" Margin="0,5,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                    <Setter Property="Foreground" Value="#00E676"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource LessThanConverter}, ConverterParameter=0}" Value="True">
                                                    <Setter Property="Foreground" Value="#FF5252"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- 평균 ROE -->
                            <StackPanel Grid.Column="2" Margin="10">
                                <TextBlock Text="평균 ROE" FontSize="12" Foreground="{Binding SubTextForeground}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding AverageRoe, StringFormat={}{0:F2}%}" FontSize="24" FontWeight="Bold" 
                                           Foreground="#3B82F6" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>

                            <!-- 총 거래 횟수 -->
                            <StackPanel Grid.Column="3" Margin="10">
                                <TextBlock Text="총 거래" FontSize="12" Foreground="{Binding SubTextForeground}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding TradeHistory.Count, StringFormat={}{0}회}" FontSize="24" FontWeight="Bold" 
                                           Foreground="#8B5CF6" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="2" ItemsSource="{Binding TradeHistory}" AutoGenerateColumns="False" 
                              Background="Transparent" RowBackground="Transparent" Foreground="{Binding TextForeground}"
                              BorderThickness="1" BorderBrush="{Binding BorderColor}"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{Binding BorderColor}" MouseDoubleClick="DataGrid_MouseDoubleClick"
                              ColumnHeaderStyle="{StaticResource DarkColumnHeader}" CanUserAddRows="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="TIME" Binding="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160"/>
                            <DataGridTextColumn Header="SYMBOL" Binding="{Binding Symbol}" Width="100" FontWeight="Bold"/>
                            <DataGridTemplateColumn Header="SIDE" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Side}" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Side}" Value="BUY">
                                                            <Setter Property="Foreground" Value="#00E676"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Side}" Value="SELL">
                                                            <Setter Property="Foreground" Value="#FF5252"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="PRICE" Binding="{Binding Price, StringFormat=N4}" Width="100"/>
                            <DataGridTextColumn Header="STRATEGY" Binding="{Binding Strategy}" Width="150"/>
                            <DataGridTextColumn Header="AI SCORE" Binding="{Binding AiScore, StringFormat=F1}" Width="80"/>
                            
                            <!-- [추가] PnL 및 수익률 컬럼 -->
                            <DataGridTextColumn Header="PnL (USDT)" Binding="{Binding PnL, StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PnL, Converter={StaticResource LessThanConverter}, ConverterParameter=0}" Value="True">
                                                <Setter Property="Foreground" Value="#FF5252"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PnL, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                <Setter Property="Foreground" Value="#00E676"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTextColumn Header="ROE (%)" Binding="{Binding PnLPercent, StringFormat={}{0:F2}%}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <StatusBar Grid.Row="3" Background="#0F111A" BorderBrush="#1E293B" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock x:Name="lblFooter" Text="SYSTEM READY | WAITING FOR COMMAND" Foreground="#64748B" FontSize="10"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="txtTelegramStatus" Text="Telegram: Off" Foreground="Gray" FontSize="10" Margin="0,0,15,0"/>
                    <TextBlock Text="Binance USDT-Futures API Connected" Foreground="#10B981" FontSize="10" Margin="0,0,10,0"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>