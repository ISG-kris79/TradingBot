                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="📊 실시간 시장 신호" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                            <Border Background="#0D2010" BorderBrush="#00E676" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
