                                                            <DataTemplate>
                                                                <StackPanel Margin="8,4">
                                                                    <TextBlock FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="{Binding PriceColor}">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                                                <Binding Path="Symbol"/>
                                                                                <Binding Path="LastPrice"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                    <TextBlock Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                        <Run Text="진입 " Foreground="#6B7280" FontSize="10"/>
                                                                        <Run FontSize="10" FontFamily="Consolas" Foreground="#94A3B8">
                                                                            <Run.Text>
                                                                                <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                                                    <Binding Path="Symbol"/>
                                                                                    <Binding Path="EntryPrice"/>
                                                                                </MultiBinding>
                                                                            </Run.Text>
                                                                        </Run>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- [v5.10.87] ②-1 마진/손익 USDT -->
                                                    <DataGridTemplateColumn Header="마진/손익" Width="120">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="8,4" Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <TextBlock FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="#E0E7FF" Text="{Binding EntryMarginUsdt}" ToolTip="진입 마진 (증거금)"/>
                                                                    <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{Binding ProfitColor}" Text="{Binding ProfitUsdt}" ToolTip="실시간 손익"/>
                                                                    <TextBlock FontSize="9" Foreground="#6B7280" Text="{Binding EntryNotionalUsdt, StringFormat='Notional {0}'}" ToolTip="명목금액 (마진 × 레버리지)"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ③ ROI: 수익률 + USDT 금액 -->
                                                    <DataGridTemplateColumn Header="ROI" Width="100">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ProfitRate, StringFormat={}{0:+0.00;-0.00;0.00}%}"
                                                                               Foreground="{Binding ProfitColor}"
                                                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding ProfitUsdt, Mode=OneWay}"
                                                                               Foreground="{Binding ProfitColor}"
                                                                               FontFamily="Consolas" FontSize="9"
                                                                               HorizontalAlignment="Center" Opacity="0.7"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- [v5.22.27] AI 점수 컬럼 제거 — AI 시스템 폐기 (2026-04-29). 기존 AIScore/MLProbability 0 영구 표시 잔존 코드 제거. -->
                                                    <DataGridTemplateColumn Header="신호점수" Width="100">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding AIScoreText}"
                                                                           Foreground="{Binding ScoreColor}"
                                                                           FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,4"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑤ STATUS: 진입 상태 Badge (v3.2.34) -->
                                                    <DataGridTemplateColumn Header="상태" Width="118">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="4,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Border BorderBrush="{Binding EntryStatusColor}" BorderThickness="1.5"
                                                                            CornerRadius="4" Padding="8,3"
                                                                            HorizontalAlignment="Center">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                            <TextBlock Text="{Binding EntryStatusIcon}" FontSize="11" Margin="0,0,3,0"
                                                                                       VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding EntryStatus}" Foreground="{Binding EntryStatusColor}"
                                                                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding AIScoreUpdatedText}" Foreground="#374151" FontSize="9"
                                                                               FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑥ SL / TP: 손절/익절 요약 -->
                                                    <DataGridTemplateColumn Header="손절/익절" Width="152">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding RiskSummary}" Foreground="#CBD5E1" FontFamily="Consolas" FontSize="10"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="NoWrap"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑦ SIGNAL: 매수/매도/대기 배지 -->
                                                    <DataGridTemplateColumn Header="신호" Width="108">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{Binding DecisionBg}" CornerRadius="6" Padding="10,5" Margin="4,4">
                                                                    <TextBlock Text="{Binding DisplayDecision}" Foreground="White"
                                                                               FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑧ EXIT: 청산 상태 -->
                                                    <DataGridTemplateColumn Header="청산" Width="92">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{Binding CloseStatusBackground}" CornerRadius="6" Padding="8,5" Margin="4,4"
                                                                        ToolTip="{Binding CloseIncompleteDetail}">
                                                                    <TextBlock Text="{Binding CloseStatusText}" Foreground="{Binding CloseStatusForeground}"
                                                                               FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑨ ACTION: 강제청산 버튼 -->
                                                    <DataGridTemplateColumn Header="ACTION" Width="76">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="CLOSE"
                                                                        Command="{Binding DataContext.ClosePositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Symbol}"
                                                                        Style="{StaticResource DangerButtonStyle}"
                                                                        FontSize="10" Padding="8,4"
                                                                        Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Border>

                                        <!-- [v4.9.0] AI INSIGHT PANEL — 대기/보유 자동 전환 -->
                                        <Border Grid.Row="2"
                                                Background="#0B1220"
                                                BorderBrush="#1E3A5F"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12,10"
                                                Margin="0,8,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="1"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- ── LEFT: Top Candidates (대기 상태) ── -->
                                                <Grid Grid.Column="0" Margin="0,0,8,0">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
                                                        <TextBlock Text="🎯 TOP CANDIDATES" FontSize="11" FontWeight="Bold"
                                                                   Foreground="#00E5FF"/>
                                                        <TextBlock Text="{Binding TopCandidates.Count, StringFormat={} ({0})}"
                                                                   FontSize="10" Foreground="#6B7280" Margin="6,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ListBox Grid.Row="1"
                                                             ItemsSource="{Binding TopCandidates}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             VirtualizingStackPanel.IsVirtualizing="True"
                                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="0,3"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#111827" CornerRadius="5" Padding="8,5" Margin="0,2">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0">
                                                                            <TextBlock Text="{Binding Symbol}" Foreground="#E0E7FF"
                                                                                       FontWeight="Bold" FontSize="12" FontFamily="Consolas"/>
                                                                            <TextBlock Text="{Binding PredictedTpSlText}"
                                                                                       Foreground="#6B7280" FontSize="9" FontFamily="Consolas"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                                                            <TextBlock Text="{Binding MLProbabilityText}"
                                                                                       Foreground="#FFD700" FontSize="12" FontWeight="Bold"
                                                                                       FontFamily="Consolas" HorizontalAlignment="Right"/>
                                                                            <TextBlock Text="{Binding DetectedAtText}"
                                                                                       Foreground="#4B5563" FontSize="8"
                                                                                       HorizontalAlignment="Right"/>
                                                                        </StackPanel>
                                                                        <Border Grid.Column="2" Background="{Binding StatusColor}"
                                                                                CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                                                                VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Status}"
                                                                                       Foreground="#000000" FontSize="9"
                                                                                       FontWeight="Bold"/>
                                                                        </Border>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>

                                                <Rectangle Grid.Column="1" Fill="#1E3A5F"/>

                                                <!-- ── RIGHT: Active Positions (모든 포지션 표시 — v4.9.8 버그 수정) ── -->
                                                <Grid Grid.Column="2" Margin="8,0,0,0">
                                                    <!-- 보유 있을 때 -->
                                                    <Border Visibility="{Binding HasAnyActivePosition, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>
                                                            <TextBlock Grid.Row="0" Text="📊 활성 포지션" FontSize="11" FontWeight="Bold"
                                                                       Foreground="#10B981" Margin="0,0,0,6"/>
                                                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                                <ItemsControl ItemsSource="{Binding ActivePositions}">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Background="#0A1421" BorderBrush="#1E3A5F" BorderThickness="1"
                                                                                    CornerRadius="4" Padding="6,4" Margin="0,0,0,4">
                                                                                <StackPanel>
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="Bold"
                                                                                                   Foreground="#E0E7FF" FontFamily="Consolas" VerticalAlignment="Center"/>
                                                                                        <TextBlock Grid.Column="1" Text="{Binding RoeText}"
                                                                                                   Foreground="{Binding RoeColor}"
                                                                                                   FontSize="13" FontWeight="Bold" FontFamily="Consolas"
                                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        <Border Grid.Column="2" Background="#111827" CornerRadius="3" Padding="5,1">
                                                                                            <TextBlock Text="{Binding Side}"
                                                                                                       Foreground="{Binding SideColor}"
                                                                                                       FontSize="9" FontWeight="Bold" FontFamily="Consolas"/>
                                                                                        </Border>
                                                                                    </Grid>
                                                                                    <Grid Margin="0,3,0,0">
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0" Text="{Binding SlText}"
                                                                                                   Foreground="#EF4444" FontSize="9" FontFamily="Consolas"
                                                                                                   VerticalAlignment="Center"/>
                                                                                        <ProgressBar Grid.Column="1"
                                                                                                     Value="{Binding ProgressToTpPct, Mode=OneWay}"
                                                                                                     Maximum="100" Height="5" Margin="5,0"
                                                                                                     Background="#111827" Foreground="#10B981"
                                                                                                     BorderThickness="0"/>
                                                                                        <TextBlock Grid.Column="2" Text="{Binding TpText}"
                                                                                                   Foreground="#10B981" FontSize="9" FontFamily="Consolas"
                                                                                                   VerticalAlignment="Center"/>
                                                                                    </Grid>
                                                                                    <Grid Margin="0,2,0,0">
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Text="{Binding PnlText}" Foreground="#A5B4FC"
                                                                                                   FontSize="10" FontFamily="Consolas"/>
                                                                                        <TextBlock Grid.Column="1" Text="{Binding HoldingTimeText}"
                                                                                                   Foreground="#FBBF24" FontSize="10" FontFamily="Consolas"/>
                                                                                    </Grid>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                        </Grid>
                                                    </Border>
                                                    <!-- 보유 없을 때 -->
                                                    <Border Visibility="{Binding HasAnyActivePosition, Converter={StaticResource InvertBoolToVisibilityConverter}}">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="💤" FontSize="28" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="활성 포지션 없음" Foreground="#6B7280"
                                                                       FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                                            <TextBlock Text="AI가 진입 기회를 탐색 중입니다" Foreground="#4B5563"
                                                                       FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <!-- FAST LOG (3) + Critical Alerts (2) 나란히 (v3.2.32) -->
                                        <Grid Grid.Row="3" Margin="0,8,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- FAST LOG -->
                                            <Border Grid.Column="0"
                                                    Background="#0D1117"
                                                    BorderBrush="#1E3A5F"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="6,4,6,6"
                                                    Margin="0,0,4,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="📡 빠른 로그" FontSize="10" FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,3"/>
                                                    <ListBox Grid.Row="1"
                                                             ItemsSource="{Binding FastLogs}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             FontFamily="Consolas"
                                                             FontSize="10"
                                                             VirtualizingStackPanel.IsVirtualizing="True"
                                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                                             ScrollViewer.CanContentScroll="True">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="2,1"/>
                                                                <Setter Property="Foreground" Value="#8B949E"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                    </ListBox>
                                                </Grid>
                                            </Border>

                                            <!-- Critical Alerts -->
                                            <Border Grid.Column="1"
                                                    Background="#1A0A0A"
                                                    BorderBrush="#5F1E1E"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="6,4,6,6"
                                                    Margin="4,0,0,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="⚠  긴급 알림" FontSize="10" FontWeight="Bold"
                                                               Foreground="#FF6B6B" Margin="0,0,0,3"/>
                                                    <ListBox x:Name="lstAlerts"
                                                             Grid.Row="1"
                                                             ItemsSource="{Binding Alerts}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             FontFamily="Consolas"
                                                             FontSize="10"
                                                             VirtualizingStackPanel.IsVirtualizing="True"
                                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                             ScrollViewer.CanContentScroll="True">
                                                        <ListBox.Resources>
                                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource MinimalScrollBar}"/>
                                                        </ListBox.Resources>
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="2,1"/>
                                                                <Setter Property="Foreground" Value="#FF9999"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                    </ListBox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TRADE HISTORY TAB -->
                <TabItem Header="📈  매매기록">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Start:"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding StartDate}"
                                        Width="130"
                                        Margin="0,0,16,0"/>

                            <TextBlock Text="End:"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding EndDate}"
                                        Width="130"
                                        Margin="0,0,16,0"/>

                            <Button Content="🔍 SEARCH"
                                    Command="{Binding LoadHistoryCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="110"
                                    Height="36"
                                    Margin="0,0,12,0"/>

                            <Button Content="� Sync"
                                    Command="{Binding SyncPositionsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="90"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    ToolTip="거래소 포지션 동기화 (누락된 청산 복구)"/>

                            <Button Content="�📥 Export CSV"
                                    Command="{Binding ExportHistoryCommand}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Width="130"
                                    Height="36"
                                    Margin="0,0,16,0"/>

                            <TextBlock Text="{Binding TradeHistory.Count, StringFormat='총 {0}건'}"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Stats Panel -->
                        <Border Grid.Row="1"
                                Style="{StaticResource CardStyle}"
                                Padding="24"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="WIN RATE"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL PROFIT"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProfit, StringFormat={}{0:N2} USDT}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource LessThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="AVERAGE ROI"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding AverageRoe, StringFormat={}{0:F2}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="매매 건수"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TradeHistory.Count}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 매매 기록 -->
                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}"
                                Padding="0"
                                Margin="0">
                            <DataGrid ItemsSource="{Binding PositionHistory}"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="진입시각" Binding="{Binding OpenTimeText}" Width="130"/>
                                    <DataGridTextColumn Header="종료시각" Binding="{Binding CloseTimeText}" Width="130"/>
                                    <DataGridTextColumn Header="심볼" Binding="{Binding Symbol}" Width="100"/>
                                    <DataGridTextColumn Header="방향" Binding="{Binding SideKr}" Width="60"/>
                                    <DataGridTextColumn Header="평균진입" Binding="{Binding AvgEntryPrice, StringFormat=N4}" Width="110"/>
                                    <DataGridTextColumn Header="평균청산" Binding="{Binding AvgExitPrice, StringFormat=N4}" Width="110"/>
                                    <DataGridTextColumn Header="수량" Binding="{Binding TotalQuantity, StringFormat=N4}" Width="100"/>
                                    <DataGridTextColumn Header="순손익" Binding="{Binding NetPnl, StringFormat=N4}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NetPnl, Converter={StaticResource LessThanConverter}, ConverterParameter=0}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NetPnl, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ROE%" Binding="{Binding RoePct, StringFormat={}{0:F2}%}" Width="80"/>
                                    <DataGridTextColumn Header="분할" Binding="{Binding FillCount}" Width="50"/>
                                    <DataGridTextColumn Header="구간" Binding="{Binding DurationText}" Width="60"/>
                                    <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>


                <!-- TRADE HISTORY TAB -->
                <TabItem Header="📈  매매기록">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Start:"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding StartDate}"
                                        Width="130"
                                        Margin="0,0,16,0"/>

                            <TextBlock Text="End:"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding EndDate}"
                                        Width="130"
                                        Margin="0,0,16,0"/>

                            <Button Content="🔍 SEARCH"
                                    Command="{Binding LoadHistoryCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="110"
                                    Height="36"
                                    Margin="0,0,12,0"/>

                            <Button Content="� Sync"
                                    Command="{Binding SyncPositionsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="90"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    ToolTip="거래소 포지션 동기화 (누락된 청산 복구)"/>

                            <Button Content="�📥 Export CSV"
                                    Command="{Binding ExportHistoryCommand}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Width="130"
                                    Height="36"
                                    Margin="0,0,16,0"/>

                            <TextBlock Text="{Binding TradeHistory.Count, StringFormat='총 {0}건'}"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Stats Panel -->
                        <Border Grid.Row="1"
                                Style="{StaticResource CardStyle}"
                                Padding="24"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="WIN RATE"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL PROFIT"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProfit, StringFormat={}{0:N2} USDT}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource LessThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="AVERAGE ROI"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding AverageRoe, StringFormat={}{0:F2}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="매매 건수"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TradeHistory.Count}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 매매 기록 -->
                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}"
                                Padding="0"
                                Margin="0">
                            <DataGrid ItemsSource="{Binding PositionHistory}"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="진입시각" Binding="{Binding OpenTimeText}" Width="130"/>
                                    <DataGridTextColumn Header="종료시각" Binding="{Binding CloseTimeText}" Width="130"/>
                                    <DataGridTextColumn Header="심볼" Binding="{Binding Symbol}" Width="100"/>
                                    <DataGridTextColumn Header="방향" Binding="{Binding SideKr}" Width="60"/>
                                    <DataGridTextColumn Header="평균진입" Binding="{Binding AvgEntryPrice, StringFormat=N4}" Width="110"/>
                                    <DataGridTextColumn Header="평균청산" Binding="{Binding AvgExitPrice, StringFormat=N4}" Width="110"/>
                                    <DataGridTextColumn Header="수량" Binding="{Binding TotalQuantity, StringFormat=N4}" Width="100"/>
                                    <DataGridTextColumn Header="순손익" Binding="{Binding NetPnl, StringFormat=N4}" Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NetPnl, Converter={StaticResource LessThanConverter}, ConverterParameter=0}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NetPnl, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ROE%" Binding="{Binding RoePct, StringFormat={}{0:F2}%}" Width="80"/>
                                    <DataGridTextColumn Header="분할" Binding="{Binding FillCount}" Width="50"/>
                                    <DataGridTextColumn Header="구간" Binding="{Binding DurationText}" Width="60"/>
                                    <DataGridTextColumn Header="카테고리" Binding="{Binding Category}" Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- PERFORMANCE TAB (v3.7.0 리디자인) -->
                <TabItem Header="📊  성과분석">
                    <ScrollViewer Style="{StaticResource MinimalScrollViewer}" Background="#0D1117">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="350"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더: 기간 탭 + 요약 -->
                        <Border Grid.Row="0" Background="#161B22" CornerRadius="12" Padding="16,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PERFORMANCE" FontSize="16" FontWeight="Bold" Foreground="#E6EDF3" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                    <Border Background="#21262D" CornerRadius="8" Padding="2">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Content="  일별  " GroupName="PerfPeriod" IsChecked="True" Margin="2" Checked="PerfDaily_Checked"
                                                         FontSize="13" FontWeight="Bold" Foreground="White" Background="#30363D"
                                                         BorderBrush="#58A6FF" BorderThickness="1" Padding="12,6"
                                                         Style="{StaticResource {x:Type ToggleButton}}"/>
                                            <RadioButton Content="  주별  " GroupName="PerfPeriod" Margin="2" Checked="PerfWeekly_Checked"
                                                         FontSize="13" FontWeight="Bold" Foreground="White" Background="#30363D"
                                                         BorderBrush="#58A6FF" BorderThickness="1" Padding="12,6"
                                                         Style="{StaticResource {x:Type ToggleButton}}"/>
                                            <RadioButton Content="  월별  " GroupName="PerfPeriod" Margin="2" Checked="PerfMonthly_Checked"
                                                         FontSize="13" FontWeight="Bold" Foreground="White" Background="#30363D"
                                                         BorderBrush="#58A6FF" BorderThickness="1" Padding="12,6"
                                                         Style="{StaticResource {x:Type ToggleButton}}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding PerformanceSummary}" Foreground="#7EE787" FontSize="13"
                                           FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- PnL 차트 (수익 초록 / 손실 빨강) -->
                        <Border Grid.Row="1" Background="#161B22" CornerRadius="12" Padding="16,12" Margin="0,0,0,8">
                            <lvc:CartesianChart Series="{Binding PerformanceSeries}" LegendLocation="None"
                                               AnimationsSpeed="0:0:0.3" Hoverable="True" Background="Transparent"
                                               xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding PerformanceLabels}" Foreground="#8B949E" FontSize="11" LabelsRotation="-30">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Foreground="#8B949E" FontSize="11" LabelFormatter="{Binding YFormatter}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#21262D" StrokeThickness="1" StrokeDashArray="4,4"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Border>

                        <!-- 달력 뷰 (7열 그리드) -->
                        <Border Grid.Row="2" Background="#161B22" CornerRadius="12" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="DAILY P&amp;L CALENDAR" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" Margin="4,0,0,10"/>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding CalendarEntries}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding CellBackground}" CornerRadius="8" Padding="6,8" Margin="3"
                                                    BorderBrush="{Binding PnlColor}" BorderThickness="1">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding DayLabel}" Foreground="#C9D1D9" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding PnlDisplay}" Foreground="{Binding PnlColor}"
                                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding TradeCountDisplay}" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </TabItem>


            </TabControl>

            <!-- UNIFIED FOOTER BAR (40px) — Log | Status | Clock | Connection -->
            <Border Grid.Row="3"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#2D3454"
                    CornerRadius="0,0,12,12">
                <Border.Effect>
                    <DropShadowEffect Color="{StaticResource PrimaryColor}"
                                      BlurRadius="6"
                                      ShadowDepth="0"
                                      Opacity="0.2"/>
                </Border.Effect>
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bell icon + Footer log -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Background="#0A1220"
                                CornerRadius="5"
                                Padding="6,3"
                                Margin="0,0,10,0">
                            <TextBlock Text="🔔"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               x:Name="lblFooter"
                               Text="SYSTEM READY  •  WAITING FOR COMMAND"
                               Foreground="#A5B4FC"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{StaticResource PrimaryColor}"
                                              BlurRadius="4"
                                              ShadowDepth="0"
                                              Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Right: Profile | Telegram | Clock | Connected -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="txtMajorProfileStatus"
                                   Text="● Major Profile: Balanced"
                                   Foreground="#9CA3AF"
                                   FontSize="10"
                                   Margin="0,0,14,0"/>
                        <TextBlock x:Name="txtTelegramStatus"
                                   Text="Telegram: Offline"
                                   Foreground="#6B7280"
                                   FontSize="10"
                                   Margin="0,0,14,0"/>
                        <!-- Live Clock -->
                        <Border Background="#0A1220"
                                BorderBrush="#1E3A5F"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="8,3"
                                Margin="0,0,14,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtDateDisplay"
                                           Text="----/--/--"
                                           Foreground="#4B5563"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock x:Name="txtTimeDisplay"
                                           Text="--:--:--"
                                           Foreground="#00E5FF"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00E5FF" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <!-- Connection -->
                        <Ellipse Width="7"
                                 Height="7"
                                 Fill="{StaticResource AccentBrush}"
                                 Margin="0,0,5,0"/>
                        <TextBlock Text="Binance  •  Connected"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
