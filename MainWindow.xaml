<Window x:Class="TradingBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:TradingBot"
            Title="COINFF TRADINGBOT"
        Height="950"
        Width="1600"
        MinHeight="700"
        MinWidth="1200"
        Background="#0A0E27"
        Foreground="#E0E7FF"
        FontFamily="Segoe UI, Malgun Gothic"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Icon="/trading_bot.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="72"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Converters -->
        <local:StatusToIconConverter x:Key="StatusToIconConverter"/>
        <local:GreaterThanConverter x:Key="GreaterThanConverter"/>
        <local:LessThanConverter x:Key="LessThanConverter"/>
        <local:InvertBooleanConverter x:Key="InvertBooleanConverter"/>
        <local:PriceFormattingConverter x:Key="PriceFormattingConverter"/>
        <local:LogTextToColorConverter x:Key="LogTextToColorConverter"/>
        <local:ScoreToArcGeometryConverter x:Key="ScoreToArcGeometryConverter"/>
        <local:PercentageWidthConverter x:Key="PercentageWidthConverter"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Color Resources -->
        <Color x:Key="PrimaryColor">#00E5FF</Color>
        <Color x:Key="SecondaryColor">#7C4DFF</Color>
        <Color x:Key="AccentColor">#00E676</Color>
        <Color x:Key="ErrorColor">#FF5370</Color>
        <Color x:Key="WarningColor">#FFB300</Color>
        <Color x:Key="BackgroundDark">#0A0E27</Color>
        <Color x:Key="BackgroundMedium">#1A1F3A</Color>
        <Color x:Key="BackgroundLight">#252B48</Color>

        <SolidColorBrush x:Key="PrimaryBrush"
                         Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="SecondaryBrush"
                         Color="{StaticResource SecondaryColor}"/>
        <SolidColorBrush x:Key="AccentBrush"
                         Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="ErrorBrush"
                         Color="{StaticResource ErrorColor}"/>
        <SolidColorBrush x:Key="WarningBrush"
                         Color="{StaticResource WarningColor}"/>
        <SolidColorBrush x:Key="BackgroundDarkBrush"
                         Color="{StaticResource BackgroundDark}"/>
        <SolidColorBrush x:Key="BackgroundMediumBrush"
                         Color="{StaticResource BackgroundMedium}"/>
        <SolidColorBrush x:Key="BackgroundLightBrush"
                         Color="{StaticResource BackgroundLight}"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground"
                    Value="#E0E7FF"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="20,10"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource BackgroundLight}"
                                                         Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource PrimaryColor}"
                                                          BlurRadius="20"
                                                          ShadowDepth="0"
                                                          Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource BackgroundLight}"
                                                         Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryButtonStyle"
               BasedOn="{StaticResource ModernButtonStyle}"
               TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="{StaticResource PrimaryColor}"
                                      Offset="0"/>
                        <GradientStop Color="{StaticResource SecondaryColor}"
                                      Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>

        <!-- Success Button -->
        <Style x:Key="SuccessButtonStyle"
               BasedOn="{StaticResource ModernButtonStyle}"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButtonStyle"
               BasedOn="{StaticResource ModernButtonStyle}"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource ErrorBrush}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>

        <!-- Modern Card Style -->
        <Style x:Key="CardStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="{StaticResource BackgroundMediumBrush}"/>
            <Setter Property="CornerRadius"
                    Value="12"/>
            <Setter Property="Padding"
                    Value="20"/>
            <Setter Property="Margin"
                    Value="0,0,0,16"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#2D3454"
                                     Opacity="0.5"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="25"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat Card Style -->
        <Style x:Key="StatCardStyle"
               TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#1A1F3A"
                                      Offset="0"/>
                        <GradientStop Color="#252B48"
                                      Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius"
                    Value="10"/>
            <Setter Property="Padding"
                    Value="16"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#4D00E5FF"
                                      Offset="0"/>
                        <GradientStop Color="#4D7C4DFF"
                                      Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="15"
                                      ShadowDepth="2"
                                      Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern DataGrid Style -->
        <Style x:Key="ModernDataGridStyle"
               TargetType="DataGrid">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#E0E7FF"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="GridLinesVisibility"
                    Value="None"/>
            <Setter Property="RowBackground"
                    Value="Transparent"/>
            <Setter Property="AlternatingRowBackground">
                <Setter.Value>
                    <SolidColorBrush Color="#1A1F3A"
                                     Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="ColumnHeaderHeight"
                    Value="48"/>
            <Setter Property="RowHeight"
                    Value="60"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="CanUserAddRows"
                    Value="False"/>
            <Setter Property="CanUserDeleteRows"
                    Value="False"/>
            <Setter Property="AutoGenerateColumns"
                    Value="False"/>
            <Setter Property="SelectionMode"
                    Value="Single"/>
            <Setter Property="IsReadOnly"
                    Value="True"/>
            <Setter Property="HeadersVisibility"
                    Value="Column"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGrid">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="DG_ScrollViewer"
                                          Style="{DynamicResource MinimalScrollViewer}"
                                          Focusable="false">
                                <ScrollViewer.Template>
                                    <ControlTemplate TargetType="ScrollViewer">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <DataGridColumnHeadersPresenter Grid.Column="0" Grid.Row="0"
                                                                            x:Name="PART_ColumnHeadersPresenter"
                                                                            Visibility="{Binding HeadersVisibility, 
                                                                                       ConverterParameter={x:Static DataGridHeadersVisibility.Column}, 
                                                                                       Converter={x:Static DataGrid.HeadersVisibilityConverter}, 
                                                                                       RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"/>

                                            <ScrollContentPresenter Grid.Column="0" Grid.Row="1"
                                                                    x:Name="PART_ScrollContentPresenter"
                                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>

                                            <ScrollBar Grid.Column="1" Grid.Row="1"
                                                       x:Name="PART_VerticalScrollBar"
                                                       Style="{DynamicResource MinimalScrollBar}"
                                                       Orientation="Vertical"
                                                       Maximum="{TemplateBinding ScrollableHeight}"
                                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                                       Value="{Binding VerticalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>

                                            <ScrollBar Grid.Column="0" Grid.Row="2"
                                                       x:Name="PART_HorizontalScrollBar"
                                                       Style="{DynamicResource MinimalScrollBar}"
                                                       Orientation="Horizontal"
                                                       Maximum="{TemplateBinding ScrollableWidth}"
                                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                                       Value="{Binding HorizontalOffset, Mode=OneWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollViewer.Template>
                                <ItemsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Column Header Style -->
        <Style x:Key="ModernColumnHeaderStyle"
               TargetType="DataGridColumnHeader">
            <Setter Property="Background"
                    Value="{StaticResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground"
                    Value="#9CA3AF"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Padding"
                    Value="16,12"/>
            <Setter Property="BorderThickness"
                    Value="0,0,0,2"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
        </Style>

        <!-- Tab Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground"
                    Value="#6B7280"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Padding"
                    Value="20,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                CornerRadius="4,4,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,8,0">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground"
                                        Value="#E0E7FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Foreground"
                                        Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- AI Command Center Animations -->
        <Storyboard x:Key="SniperBlinkStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="txtSniperReady"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.0"
                             Duration="0:0:0.5"
                             AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="CyanGlowPulse" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="ellConfidenceGlow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.3" To="1.0"
                             Duration="0:0:0.8"
                             AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="RedNeonStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="borderShortNeon"
                             Storyboard.TargetProperty="Opacity"
                             From="0.5" To="1.0"
                             Duration="0:0:0.4"
                             AutoReverse="True"/>
        </Storyboard>

        <!-- Smooth Animations -->
        <Storyboard x:Key="GlowAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.4"
                             To="1.0"
                             Duration="0:0:1.5"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
        </Storyboard>

        <!-- Minimal ScrollBar Style -->
        <Style x:Key="MinimalScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot">
                            <Grid.LayoutTransform>
                                <RotateTransform x:Name="RotateTransform" Angle="0"/>
                            </Grid.LayoutTransform>
                            <Border Background="Transparent" CornerRadius="3"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Border x:Name="ThumbBorder"
                                                        Background="#33FFFFFF"
                                                        CornerRadius="3"
                                                        Opacity="0.3">
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="MouseEnter">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ThumbBorder"
                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                     To="0.7"
                                                                                     Duration="0:0:0.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                        <EventTrigger RoutedEvent="MouseLeave">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ThumbBorder"
                                                                                     Storyboard.TargetProperty="Opacity"
                                                                                     To="0.3"
                                                                                     Duration="0:0:0.2"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter TargetName="GridRoot" Property="LayoutTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="-90"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="6"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimal ScrollViewer Style -->
        <Style x:Key="MinimalScrollViewer" TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource MinimalScrollBar}"
                                       HorizontalAlignment="Right"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container with Rounded Corners -->
    <Border Background="{StaticResource BackgroundDarkBrush}"
            CornerRadius="12"
            BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#4D00E5FF"
                              Offset="0"/>
                <GradientStop Color="#4D7C4DFF"
                              Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="72"/>
                <RowDefinition Height="3"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>

            <!-- HEADER (72px) — Logo | Live Stat Pills | Controls | Window Chrome -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundMediumBrush}"
                    CornerRadius="12,12,0,0"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#2D3454">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Direction="270" Opacity="0.4"/>
                </Border.Effect>
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo & Title (Col 0) -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="32"
                                Height="32"
                                CornerRadius="6"
                                Margin="0,0,12,0"
                                Background="#1A1F3A">
                            <Image Source="trading_bot.jpg"
                                   Stretch="UniformToFill">
                                <Image.Clip>
                                    <RectangleGeometry Rect="0,0,32,32"
                                                       RadiusX="6"
                                                       RadiusY="6"/>
                                </Image.Clip>
                            </Image>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="COINFF"
                                           FontSize="18"
                                           FontWeight="Black"
                                           Foreground="{StaticResource AccentBrush}">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{StaticResource AccentColor}"
                                                          BlurRadius="12"
                                                          ShadowDepth="0"
                                                          Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text=" TRADING"
                                           FontSize="18"
                                           FontWeight="Light"
                                           Foreground="#E0E7FF"
                                           Margin="2,0,0,0"/>
                                <TextBlock x:Name="txtHeaderVersion"
                                           Text=" v0.0.0"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Bottom"
                                           Margin="8,0,0,3"
                                           Opacity="0.7"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,-2,0,0">
                                <TextBlock Text="AI-POWERED FUTURES TRADING ENGINE"
                                           FontSize="8"
                                           Foreground="#6B7280"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="txtAccountMode"
                                           Text=""
                                           FontSize="8"
                                           FontWeight="Bold"
                                           Foreground="#FFB300"
                                           Margin="8,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Live Stat Pills (Col 2) — 좌측 사이드바로 이동, 상단 숨김 -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="Collapsed"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- Equity Pill -->
                        <Border Background="#0A1220"
                                BorderBrush="#1E3A5F"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="EQUITY"
                                           Foreground="#4B5563"
                                           FontSize="8"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="txtTotalEquity"
                                           Text="{Binding TotalEquity}"
                                           Foreground="{Binding EquityColor}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           FontFamily="Consolas">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00E5FF" BlurRadius="6" ShadowDepth="0" Opacity="0.25"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <!-- Available Pill -->
                        <Border Background="#0A1220"
                                BorderBrush="#1E3A5F"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="AVAILABLE"
                                           Foreground="#4B5563"
                                           FontSize="8"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="txtAvailableBalance"
                                           Text="{Binding AvailableBalance}"
                                           Foreground="#A5B4FC"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                        <!-- Transfer PnL Pill -->
                        <Border Background="#0A1220"
                                BorderBrush="#1E3A5F"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="TRANSFER PnL"
                                           Foreground="#4B5563"
                                           FontSize="8"
                                           FontWeight="Bold"/>
                                <TextBlock Text="{Binding NetTransferInfo}"
                                           Foreground="{Binding NetTransferColor}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                        <!-- ROI Pill -->
                        <Border Background="#0A1220"
                                BorderBrush="#1E3A5F"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,6"
                                Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="ROI"
                                           Foreground="#4B5563"
                                           FontSize="8"
                                           FontWeight="Bold"/>
                                <TextBlock Text="{Binding AverageRoe, StringFormat={}{0:F2}%}"
                                           Foreground="{StaticResource WarningBrush}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                        <!-- Positions Pill -->
                        <Border Background="#0A1220"
                                BorderBrush="#1E3A5F"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,6">
                            <StackPanel>
                                <TextBlock Text="POSITIONS"
                                           Foreground="#4B5563"
                                           FontSize="8"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="txtTotalPositionInfo"
                                           Text="{Binding TotalPositionInfo}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Main Controls (Col 4) -->
                    <StackPanel Grid.Column="4"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- Exchange Selector - Hidden -->
                        <ComboBox x:Name="cmbExchange"
                                  Width="130"
                                  Height="34"
                                  SelectedIndex="0"
                                  Margin="0,0,12,0"
                                  Background="{StaticResource BackgroundLightBrush}"
                                  Foreground="#4B5563"
                                  BorderBrush="{StaticResource PrimaryBrush}"
                                  FontWeight="SemiBold"
                                  WindowChrome.IsHitTestVisibleInChrome="True"
                                  FontSize="18"
                                  Visibility="Collapsed"
                                  IsEnabled="False">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Background" Value="#252B48"/>
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="20"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#2D3454"/>
                                            <Setter Property="Foreground" Value="#00E5FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1A1F3A"/>
                                            <Setter Property="Foreground" Value="#00E5FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBoxItem Content="🟡 Binance"/>
                        </ComboBox>
                        <Button x:Name="btnSettings"
                                Content="⚙"
                                Width="36"
                                Height="36"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="btnSettings_Click"
                                Padding="0"
                                Margin="0,0,8,0"
                                ToolTip="Settings"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button x:Name="btnStart"
                                Content="▶ START"
                                Width="120"
                                Height="38"
                                Style="{StaticResource SuccessButtonStyle}"
                                Click="btnStart_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnStop"
                                Content="⏹ STOP"
                                Width="105"
                                Height="38"
                                Style="{StaticResource DangerButtonStyle}"
                                Click="btnStop_Click"
                                IsEnabled="False"
                                WindowChrome.IsHitTestVisibleInChrome="True"/>

                        <!-- 수동 진입 LONG/SHORT 버튼 -->
                        <Border BorderBrush="#2D3142" BorderThickness="1,0,0,0" Margin="12,0,0,0" Padding="12,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▲ LONG"
                                        Width="85" Height="32"
                                        FontSize="12" FontWeight="Bold"
                                        Foreground="White"
                                        Command="{Binding ManualLongCommand}"
                                        WindowChrome.IsHitTestVisibleInChrome="True"
                                        Margin="0,0,6,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#1B5E20"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="8,4">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#2E7D32"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#388E3C"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="▼ SHORT"
                                        Width="85" Height="32"
                                        FontSize="12" FontWeight="Bold"
                                        Foreground="White"
                                        Command="{Binding ManualShortCommand}"
                                        WindowChrome.IsHitTestVisibleInChrome="True">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#B71C1C"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="6" Padding="8,4">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#C62828"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#D32F2F"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right Controls (Col 6) -->
                    <StackPanel Grid.Column="6"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- Admin Menu -->
                        <Menu x:Name="mnuAdmin"
                              Background="Transparent"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              Visibility="Collapsed">
                            <MenuItem Header="👑 ADMIN"
                                      Foreground="#FFB300"
                                      FontWeight="Bold"
                                      FontSize="12">
                                <MenuItem Header="👥 User Management"
                                          Click="mnuUserManagement_Click"/>
                                <Separator/>
                                <MenuItem x:Name="mnuPendingCount"
                                          Header="⏳ Pending: 0"
                                          IsEnabled="False"
                                          Foreground="Orange"/>
                            </MenuItem>
                        </Menu>

                        <!-- User & Settings -->
                        <Button Content="👤"
                                Width="32"
                                Height="32"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="btnProfile_Click"
                                Padding="0"
                                Margin="0,0,6,0"
                                ToolTip="Profile"/>
                        <!-- Settings moved to main controls area -->
                        <Border Width="16" Margin="0,0,0,0"
                                ToolTip="Settings"/>

                        <!-- Window Controls -->
                        <Button Content="─"
                                Width="38"
                                Height="32"
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderThickness="0"
                                FontSize="14"
                                Click="OnMinimize_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="#2D3454"/>
                                            <Setter Property="Foreground"
                                                    Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="☐"
                                Width="38"
                                Height="32"
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderThickness="0"
                                FontSize="14"
                                Click="OnMaximize_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="#2D3454"/>
                                            <Setter Property="Foreground"
                                                    Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="✕"
                                Width="38"
                                Height="32"
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderThickness="0"
                                FontSize="14"
                                Click="OnClose_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="{StaticResource ErrorBrush}"/>
                                            <Setter Property="Foreground"
                                                    Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Progress Bar -->
            <ProgressBar Grid.Row="1"
                         x:Name="pgScanning"
                         Height="3"
                         Background="Transparent"
                         Foreground="{StaticResource AccentBrush}"
                         BorderThickness="0"/>

            <!-- [v4.7.2] 초기학습 진행 배너 — 진입 차단 시각화 (상단 오버레이) -->
            <Border Grid.Row="2"
                    VerticalAlignment="Top"
                    Margin="16,8,16,0"
                    Background="#1F2937"
                    BorderBrush="#F59E0B"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="20,14"
                    Panel.ZIndex="100"
                    Visibility="{Binding InitialTrainingBannerVisibility}">
                <Border.Effect>
                    <DropShadowEffect Color="#F59E0B" BlurRadius="18" ShadowDepth="0" Opacity="0.7"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🧠"
                               FontSize="26" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding InitialTrainingStatusText}"
                                   Foreground="#FBBF24" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text="{Binding InitialTrainingStageText}"
                                   Foreground="#E5E7EB" FontSize="11" Margin="0,3,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <Border Grid.Column="2"
                            Background="#111827"
                            CornerRadius="6"
                            Padding="14,8"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding InitialTrainingElapsedText}"
                                   Foreground="#10B981" FontSize="16" FontWeight="Bold"
                                   FontFamily="Consolas"/>
                    </Border>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <TabControl Grid.Row="2"
                        Margin="16">
                <!-- DASHBOARD TAB -->
                <TabItem Header="📊  DASHBOARD">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Sidebar (200px 컴팩트) -->
                        <ScrollViewer Grid.Column="0"
                                      Style="{StaticResource MinimalScrollViewer}"
                                      Margin="0,0,16,0">
                            <StackPanel>

                            <!-- Account Info Card (좌측 상단) -->
                            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="💰 ACCOUNT" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Equity" Foreground="#6B7280" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalEquity}"
                                                   Foreground="{Binding EquityColor}" FontSize="12" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Available" Foreground="#6B7280" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AvailableBalance}"
                                                   Foreground="#A5B4FC" FontSize="12" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Transfer PnL" Foreground="#6B7280" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="{Binding NetTransferInfo}"
                                                   Foreground="{Binding NetTransferColor}" FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ROI" Foreground="#6B7280" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AverageRoe, StringFormat={}{0:F2}%}"
                                                   Foreground="{StaticResource WarningBrush}" FontSize="12" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Positions" Foreground="#6B7280" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TotalPositionInfo}"
                                                   Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Entry Gate Card (컴팩트) -->
                            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="🧠 ENTRY GATE" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}" Margin="0,0,0,6"/>

                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="ML.NET 예측" Foreground="#6B7280" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="{Binding WaveMLScoreText}"
                                                   Foreground="#10B981" FontSize="12" FontWeight="Bold" FontFamily="Consolas"/>
                                    </Grid>

                                    <TextBlock Text="{Binding GateThresholdSummaryText}"
                                               Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <!-- AI Learning (컴팩트) -->
                            <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="🤖 AI LEARNING" FontSize="10" FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding AiModelStatusText}" Foreground="{Binding AiModelStatusColor}"
                                               FontSize="10" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,4"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="총 결정" Foreground="#9CA3AF" FontSize="10"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding AiTotalDecisions}" Foreground="#E0E7FF" FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Row="1" Text="라벨링" Foreground="#9CA3AF" FontSize="10" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,2,0,0">
                                            <Run Text="{Binding AiLabeledCount, Mode=OneWay}"/><Run Text=" ("/><Run Text="{Binding AiLabelingRateText, Mode=OneWay}"/><Run Text=")"/>
                                        </TextBlock>
                                        <TextBlock Grid.Row="2" Text="진행 중" Foreground="#9CA3AF" FontSize="10" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AiActiveDecisions}" Foreground="{StaticResource SecondaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ═══════════════════════════════════════════════════════════
                                 TimeOut Probability Entry — AI 확률 진입 대기열
                                 ─ 60분 공백 시 과거 패턴 코사인 유사도 기반 승률 게이지
                                 ═══════════════════════════════════════════════════════════ -->
                            <Border x:Name="BorderTimeOutProbWidget"
                                    Background="#0D1B2A"
                                    BorderBrush="#1E3A5F"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8,6"
                                    Margin="0,0,0,8">
                                <Border.Effect>
                                    <DropShadowEffect x:Name="GlowTimeOut"
                                                      Color="#1E3A5F"
                                                      BlurRadius="8"
                                                      ShadowDepth="0"
                                                      Opacity="0.4"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- 헤더 -->
                                    <TextBlock Text="⏳ AI PREDICTIVE TIME-OUT PROB" FontSize="10" FontWeight="Bold"
                                               Foreground="#7C3AED" Margin="0,0,0,4"/>

                                    <!-- 스캔 상태 행 -->
                                    <Border Background="#071226"
                                            CornerRadius="5"
                                            Padding="8,6"
                                            Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="68"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="STATUS"
                                                       Foreground="#4B5563"
                                                       FontSize="9"
                                                       FontWeight="Bold"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtTimeOutScanStatus"
                                                       Grid.Column="1"
                                                       Text="STANDBY"
                                                       Foreground="#00E5FF"
                                                       FontSize="10"
                                                       FontFamily="Consolas"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                    <!-- 심볼 + 승률 한 줄 -->
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TxtTimeOutMatchSymbol"
                                                   Grid.Column="0"
                                                   Text="—"
                                                   Foreground="#E0E7FF"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TxtTimeOutWinRate"
                                                   Grid.Column="1"
                                                   Text="0.0%"
                                                   Foreground="#7C3AED"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   FontFamily="Consolas"/>
                                    </Grid>

                                    <!-- 승률 진행 바 -->
                                    <ProgressBar x:Name="PbTimeOutWinProb"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="0"
                                                 Height="8"
                                                 Background="#1C1F33"
                                                 Foreground="#7C3AED"
                                                 BorderThickness="0"
                                                 Margin="0,0,0,3"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="0%"
                                                   Foreground="#374151" FontSize="8"/>
                                        <TextBlock Grid.Column="1" Text="── 70% ──"
                                                   Foreground="#7C3AED" FontSize="8"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="100%"
                                                   Foreground="#374151" FontSize="8"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- 신호 레이블 -->
                                    <Border x:Name="BorderTimeOutSignal"
                                            Background="#0A0F1E"
                                            CornerRadius="5"
                                            Padding="8,5">
                                        <TextBlock x:Name="TxtTimeOutSignalLabel"
                                                   Text="⌛ IDLE — 60M DROUGHT WAITING..."
                                                   Foreground="#374151"
                                                   FontSize="9"
                                                   FontFamily="Consolas"
                                                   TextWrapping="Wrap"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <!-- ═══ END TimeOut Probability Entry Widget ═══ -->

                            <!-- Critical Alerts → DataGrid 아래 FAST LOG 옆으로 이동 (v3.2.24) -->

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Main Content Area -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Hidden storyboard containers (Height=0, preserves DataTrigger animations) -->
                            <Grid Grid.Row="0" Visibility="Collapsed">
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BattleBbSupportActive}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="BbSupportWaveStoryboard">
                                                            <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.72" Duration="0:0:0.65"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="BbSupportWaveStoryboard"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BattleStopPulseActive}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="AtrPulseStoryboard">
                                                            <Storyboard AutoReverse="True" RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.5" Duration="0:0:0.45"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="AtrPulseStoryboard"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Opacity" Value="0.7"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BattleTrendRiderActive}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="TrendRiderPulseStoryboard">
                                                            <Storyboard AutoReverse="True" RepeatBehavior="3x">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0.6" Duration="0:0:0.5"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="TrendRiderPulseStoryboard"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </Grid>

                            <!-- Cockpit Strip -->
                            <Border Grid.Row="1"
                                    Background="{StaticResource BackgroundDarkBrush}"
                                    BorderBrush="{StaticResource BackgroundLightBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12,8"
                                    Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- AI Status -->
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="🧠 AI STATUS" Foreground="{StaticResource SecondaryBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding BattleThresholdText}" Foreground="#C7D2FE" FontSize="10" FontFamily="Consolas" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding BattleConfidenceText}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Rectangle Grid.Column="1" Fill="{StaticResource BackgroundLightBrush}"/>

                                    <!-- THE PULSE -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="⚡ THE PULSE" Foreground="{StaticResource SecondaryBrush}" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding BattlePulseScoreText}" Foreground="{Binding BattlePulseBrush}" FontSize="22" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center"/>
                                        <TextBlock Text="SCORE" Foreground="#64748B" FontSize="9" HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <Rectangle Grid.Column="3" Fill="{StaticResource BackgroundLightBrush}"/>

                                    <!-- Golden Zone -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="🎯 GOLDEN ZONE" Foreground="{Binding BattleGoldenZoneBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding BattleGoldenZoneText}" Foreground="{Binding BattleGoldenZoneBrush}" FontSize="11" FontFamily="Consolas" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding BattleFibCountdownText}" Foreground="#94A3B8" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Rectangle Grid.Column="5" Fill="{StaticResource BackgroundLightBrush}"/>

                                    <!-- ATR Stop -->
                                    <StackPanel Grid.Column="6" VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="☁ ATR STOP" Foreground="{Binding BattleAtrCloudBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding BattleAtrCloudText}" Foreground="{Binding BattleAtrCloudBrush}" FontSize="10" FontFamily="Consolas" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding BattleRsiCountdownText}" Foreground="#94A3B8" FontSize="10" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Rectangle Grid.Column="7" Fill="{StaticResource BackgroundLightBrush}"/>

                                    <!-- Trend-Rider -->
                                    <StackPanel Grid.Column="8" VerticalAlignment="Center" Margin="12,0,0,0">
                                        <TextBlock Text="🪜 TREND-RIDER" Foreground="{Binding BattleTrendRiderBrush}" FontSize="9" FontWeight="Bold" Margin="0,0,0,3"/>
                                        <TextBlock Text="{Binding BattleTrendRiderText}" Foreground="{Binding BattleTrendRiderBrush}" FontSize="11" FontFamily="Consolas" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding BattleTrendRiderActionText}" Foreground="#94A3B8" FontSize="10" FontFamily="Consolas" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Main Split: DataGrid + Right Panel -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="260"/>
                                </Grid.ColumnDefinitions>

                                <!-- Live Market Signals DataGrid -->
                                <Border Grid.Column="0"
                                        Background="{StaticResource BackgroundDarkBrush}"
                                        BorderBrush="{StaticResource BackgroundLightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12"
                                        Margin="0,0,10,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="150"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="📊 LIVE MARKET SIGNALS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                                            <Border Background="#0D2010" BorderBrush="#00E676" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                                                <TextBlock Text="● REALTIME" Foreground="#00E676" FontSize="9" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <Border Grid.Row="1" Padding="0">
                                            <DataGrid x:Name="dgMultiTimeframe"
                                                      Style="{StaticResource ModernDataGridStyle}"
                                                      ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                                      RowHeight="48"
                                                      EnableRowVirtualization="True"
                                                      EnableColumnVirtualization="True"
                                                      VirtualizingStackPanel.IsVirtualizing="True"
                                                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                      SelectedItem="{Binding SelectedSymbol, Mode=TwoWay}"
                                                      MouseDoubleClick="dgMultiTimeframe_MouseDoubleClick">
                                                <DataGrid.RowStyle>
                                                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="Foreground" Value="#E0E7FF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPositionActive}" Value="True">
                                                                <Setter Property="Background" Value="#081A0F"/>
                                                            </DataTrigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1A1F3A"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter Property="Background" Value="#1E2547"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </DataGrid.RowStyle>
                                                <DataGrid.Columns>

                                                    <!-- ① SYMBOL: 심볼 + 전략 배지 + 포지션 방향 -->
                                                    <DataGridTemplateColumn Header="SYMBOL" Width="152">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="8,4">
                                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Symbol}" FontSize="14" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                                                        <!-- 전략 배지: Major Scalp=파랑, Pump Breakout=빨강 -->
                                                                        <Border Background="{Binding StrategyBg}" CornerRadius="3" Padding="4,1" Margin="5,0,0,0" VerticalAlignment="Center"
                                                                                Visibility="{Binding StrategyName, Converter={StaticResource NullToCollapsedConverter}}">
                                                                            <TextBlock Text="{Binding StrategyName}" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <!-- 포지션 방향 pill (진입중일 때만) -->
                                                                    <Border Background="{Binding PositionSideColor}" CornerRadius="3" Padding="5,1"
                                                                            HorizontalAlignment="Left" Margin="0,2,0,0"
                                                                            Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                        <TextBlock Text="{Binding PositionSide}" FontSize="9" FontWeight="Bold" Foreground="#0F172A"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ② PRICE: 현재가 + 진입가 (진입중) -->
                                                    <DataGridTemplateColumn Header="PRICE" Width="128">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="8,4">
                                                                    <TextBlock FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="{Binding PriceColor}">
                                                                        <TextBlock.Text>
                                                                            <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                                                <Binding Path="Symbol"/>
                                                                                <Binding Path="LastPrice"/>
                                                                            </MultiBinding>
                                                                        </TextBlock.Text>
                                                                    </TextBlock>
                                                                    <TextBlock Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                        <Run Text="진입 " Foreground="#6B7280" FontSize="10"/>
                                                                        <Run FontSize="10" FontFamily="Consolas" Foreground="#94A3B8">
                                                                            <Run.Text>
                                                                                <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                                                    <Binding Path="Symbol"/>
                                                                                    <Binding Path="EntryPrice"/>
                                                                                </MultiBinding>
                                                                            </Run.Text>
                                                                        </Run>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ③ ROI: 수익률 + USDT 금액 -->
                                                    <DataGridTemplateColumn Header="ROI" Width="100">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding ProfitRate, StringFormat={}{0:+0.00;-0.00;0.00}%}"
                                                                               Foreground="{Binding ProfitColor}"
                                                                               FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding ProfitUsdt, Mode=OneWay}"
                                                                               Foreground="{Binding ProfitColor}"
                                                                               FontFamily="Consolas" FontSize="9"
                                                                               HorizontalAlignment="Center" Opacity="0.7"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ④ AI SCORE: AIScore + ML% -->
                                                    <DataGridTemplateColumn Header="AI SCORE" Width="118">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="4,4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding AIScoreText}"
                                                                               Foreground="{Binding ScoreColor}"
                                                                               FontFamily="Consolas" FontSize="15" FontWeight="Bold"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding MLProbabilityText}" Foreground="#6B7280" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑤ STATUS: 진입 상태 Badge (v3.2.34) -->
                                                    <DataGridTemplateColumn Header="STATUS" Width="118">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Margin="4,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                    <Border BorderBrush="{Binding EntryStatusColor}" BorderThickness="1.5"
                                                                            CornerRadius="4" Padding="8,3"
                                                                            HorizontalAlignment="Center">
                                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                            <TextBlock Text="{Binding EntryStatusIcon}" FontSize="11" Margin="0,0,3,0"
                                                                                       VerticalAlignment="Center"/>
                                                                            <TextBlock Text="{Binding EntryStatus}" Foreground="{Binding EntryStatusColor}"
                                                                                       FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <TextBlock Text="{Binding AIScoreUpdatedText}" Foreground="#374151" FontSize="9"
                                                                               FontFamily="Consolas" HorizontalAlignment="Center" Margin="0,1,0,0"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑥ SL / TP: 손절/익절 요약 -->
                                                    <DataGridTemplateColumn Header="SL / TP" Width="152">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding RiskSummary}" Foreground="#CBD5E1" FontFamily="Consolas" FontSize="10"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="NoWrap"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑦ SIGNAL: 매수/매도/대기 배지 -->
                                                    <DataGridTemplateColumn Header="SIGNAL" Width="108">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{Binding DecisionBg}" CornerRadius="6" Padding="10,5" Margin="4,4">
                                                                    <TextBlock Text="{Binding DisplayDecision}" Foreground="White"
                                                                               FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑧ EXIT: 청산 상태 -->
                                                    <DataGridTemplateColumn Header="EXIT" Width="92">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border Background="{Binding CloseStatusBackground}" CornerRadius="6" Padding="8,5" Margin="4,4"
                                                                        ToolTip="{Binding CloseIncompleteDetail}">
                                                                    <TextBlock Text="{Binding CloseStatusText}" Foreground="{Binding CloseStatusForeground}"
                                                                               FontWeight="Bold" FontSize="11" HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ⑨ ACTION: 강제청산 버튼 -->
                                                    <DataGridTemplateColumn Header="ACTION" Width="76">
                                                        <DataGridTemplateColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Button Content="CLOSE"
                                                                        Command="{Binding DataContext.ClosePositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding Symbol}"
                                                                        Style="{StaticResource DangerButtonStyle}"
                                                                        FontSize="10" Padding="8,4"
                                                                        Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </Border>

                                        <!-- FAST LOG (3) + Critical Alerts (2) 나란히 (v3.2.32) -->
                                        <Grid Grid.Row="2" Margin="0,8,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="2*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- FAST LOG -->
                                            <Border Grid.Column="0"
                                                    Background="#0D1117"
                                                    BorderBrush="#1E3A5F"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="6,4,6,6"
                                                    Margin="0,0,4,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="📡 FAST LOG" FontSize="10" FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,3"/>
                                                    <ListBox Grid.Row="1"
                                                             ItemsSource="{Binding FastLogs}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             FontFamily="Consolas"
                                                             FontSize="10"
                                                             VirtualizingStackPanel.IsVirtualizing="True"
                                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                                                             ScrollViewer.CanContentScroll="True">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="2,1"/>
                                                                <Setter Property="Foreground" Value="#8B949E"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                    </ListBox>
                                                </Grid>
                                            </Border>

                                            <!-- Critical Alerts -->
                                            <Border Grid.Column="1"
                                                    Background="#1A0A0A"
                                                    BorderBrush="#5F1E1E"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    Padding="6,4,6,6"
                                                    Margin="4,0,0,0">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="⚠  CRITICAL ALERTS" FontSize="10" FontWeight="Bold"
                                                               Foreground="#FF6B6B" Margin="0,0,0,3"/>
                                                    <ListBox x:Name="lstAlerts"
                                                             Grid.Row="1"
                                                             ItemsSource="{Binding Alerts}"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             FontFamily="Consolas"
                                                             FontSize="10"
                                                             VirtualizingStackPanel.IsVirtualizing="True"
                                                             ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                             ScrollViewer.CanContentScroll="True">
                                                        <ListBox.Resources>
                                                            <Style TargetType="ScrollBar" BasedOn="{StaticResource MinimalScrollBar}"/>
                                                        </ListBox.Resources>
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="2,1"/>
                                                                <Setter Property="Foreground" Value="#FF9999"/>
                                                                <Setter Property="Background" Value="Transparent"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                    </ListBox>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <!-- Right Panel: Live Events + Profit Goal + Execution Stepper -->
                                <Border Grid.Column="1"
                                        Background="{StaticResource BackgroundDarkBrush}"
                                        BorderBrush="{StaticResource BackgroundLightBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="12">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                        <StackPanel>
                                            <!-- Live Trade Events -->
                                            <TextBlock Text="⚡ LIVE EVENTS" Foreground="{StaticResource PrimaryBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                            <Border Background="{StaticResource BackgroundMediumBrush}"
                                                    BorderBrush="{StaticResource BackgroundLightBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="🛰 XRP SCENARIO" Foreground="{StaticResource WarningBrush}" FontSize="10" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding BattleXrpScenarioText}" Foreground="{Binding BattleXrpScenarioBrush}"
                                                               FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- FAST LOG → 좌측 패널로 이동됨 (v3.2.12) -->

                                            <!-- Profit Goal Tracker -->
                                            <Border Background="{StaticResource BackgroundMediumBrush}"
                                                    BorderBrush="{StaticResource BackgroundLightBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="10"
                                                    Margin="0,0,0,12">
                                                <StackPanel>
                                                    <TextBlock Text="🎯 PROFIT GOAL" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="Bold" FontFamily="Consolas"/>
                                                    <TextBlock Text="{Binding MonthlyGoalTargetText}" Foreground="White" FontSize="12" FontWeight="Bold" FontFamily="Consolas" Margin="0,4,0,0"/>
                                                    <ProgressBar Value="{Binding MonthlyGoalProgressPercent}" Maximum="100" Height="8" Margin="0,6,0,0"
                                                                 Foreground="{StaticResource AccentBrush}" Background="{StaticResource BackgroundDarkBrush}"/>
                                                    <TextBlock Text="{Binding MonthlyGoalCurrentText}" Foreground="#E2E8F0" FontSize="11" FontWeight="SemiBold" FontFamily="Consolas" Margin="0,6,0,0"/>
                                                    <TextBlock Text="{Binding MonthlyGoalPaceText}" Foreground="{Binding MonthlyGoalPaceBrush}" FontSize="10" FontWeight="Bold" FontFamily="Consolas" Margin="0,3,0,0"/>
                                                    <TextBlock Text="{Binding MonthlyGoalXrpBonusText}" Foreground="{Binding MonthlyGoalXrpBonusBrush}" FontSize="10" FontWeight="SemiBold" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Execution Stepper -->
                                            <TextBlock Text="🧩 EXECUTION STEPPER" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                            <ItemsControl ItemsSource="{Binding BattleExecutionSteps}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{StaticResource BackgroundMediumBrush}"
                                                                BorderBrush="{Binding StateBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="10"
                                                                Margin="0,0,0,8">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Ellipse Width="10" Height="10" Fill="{Binding StateBrush}" VerticalAlignment="Top" Margin="0,4,8,0"/>
                                                                <StackPanel Grid.Column="1">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Order}" Foreground="{StaticResource PrimaryBrush}" FontSize="10" FontWeight="Bold" FontFamily="Consolas" Margin="0,0,6,0"/>
                                                                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Detail}" Foreground="#CBD5E1" FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="2" Text="{Binding StateText}" Foreground="{Binding StateBrush}" FontSize="10" FontWeight="Bold" VerticalAlignment="Top" FontFamily="Consolas"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- AI Prediction Summary Card -->
                                            <Border Background="{StaticResource BackgroundMediumBrush}" CornerRadius="6" Padding="10,8" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="📊 AI PREDICTION" Foreground="{StaticResource PrimaryBrush}" FontSize="11" FontWeight="Bold" Margin="0,0,0,6"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="ML" Foreground="#FFD700" FontSize="10" FontWeight="Bold" Margin="0,0,8,2"/>
                                                        <ProgressBar Grid.Row="0" Grid.Column="1" Value="{Binding BattleMLConfidence, FallbackValue=0}" Maximum="100" Height="10"
                                                                     Background="#252B48" Foreground="#FFD700" BorderThickness="0"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="BB" Foreground="#7C4DFF" FontSize="10" FontWeight="Bold" Margin="0,4,8,0"/>
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="#94A3B8" FontSize="10" Margin="0,4,0,0"
                                                                   Text="{Binding BattleBBPositionText, FallbackValue='Position: --'}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TRADE HISTORY TAB -->
                <TabItem Header="📈  TRADE HISTORY">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Start:"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding StartDate}"
                                        Width="130"
                                        Margin="0,0,16,0"/>

                            <TextBlock Text="End:"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding EndDate}"
                                        Width="130"
                                        Margin="0,0,16,0"/>

                            <Button Content="🔍 SEARCH"
                                    Command="{Binding LoadHistoryCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="110"
                                    Height="36"
                                    Margin="0,0,12,0"/>

                            <Button Content="� Sync"
                                    Command="{Binding SyncPositionsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="90"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    ToolTip="거래소 포지션 동기화 (누락된 청산 복구)"/>

                            <Button Content="�📥 Export CSV"
                                    Command="{Binding ExportHistoryCommand}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Width="130"
                                    Height="36"
                                    Margin="0,0,16,0"/>

                            <TextBlock Text="{Binding TradeHistory.Count, StringFormat='Total: {0} records'}"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Stats Panel -->
                        <Border Grid.Row="1"
                                Style="{StaticResource CardStyle}"
                                Padding="24"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="WIN RATE"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL PROFIT"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProfit, StringFormat={}{0:N2} USDT}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource LessThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="AVERAGE ROI"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding AverageRoe, StringFormat={}{0:F2}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL TRADES"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TradeHistory.Count}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Trade History Grid -->
                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}"
                                Padding="0"
                                Margin="0">
                            <DataGrid ItemsSource="{Binding TradeHistory}"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="STATUS"
                                                            Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4"
                                                        Padding="8,4"
                                                        ToolTip="{Binding ExitReason}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"
                                                                    Value="#334155"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOpenPosition}"
                                                                             Value="True">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding PositionStatus}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="TIME"
                                                        Binding="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                        Width="160"/>
                                    <DataGridTextColumn Header="SYMBOL"
                                                        Binding="{Binding Symbol}"
                                                        Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="SIDE"
                                                            Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4"
                                                        Padding="8,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Side}"
                                                                             Value="BUY">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource AccentBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Side}"
                                                                             Value="SELL">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource ErrorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Side}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="PRICE"
                                                            Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                            <Binding Path="Symbol"/>
                                                            <Binding Path="Price"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="STRATEGY"
                                                        Binding="{Binding Strategy}"
                                                        Width="150"/>
                                    <DataGridTextColumn Header="AI SCORE"
                                                        Binding="{Binding AiScore, StringFormat=F1}"
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Center"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="PNL (USDT)"
                                                        Binding="{Binding PnL, StringFormat=N2}"
                                                        Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Right"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PnL, Converter={StaticResource LessThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PnL, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ROE (%)"
                                                        Binding="{Binding PnLPercent, StringFormat={}{0:F2}%}"
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="SemiBold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- AI COMMAND CENTER TAB -->
                <TabItem Header="🎯  AI COMMAND">
                    <Grid x:Name="gridAiCommand" Background="#0D1117">

                        <!-- Red Neon border overlay (SHORT detected) -->
                        <Border x:Name="borderShortNeon"
                                BorderThickness="4"
                                Opacity="0"
                                IsHitTestVisible="False"
                                Panel.ZIndex="100"
                                Visibility="{Binding IsShortOpportunity, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FF5370"/>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#FF5370" BlurRadius="30" ShadowDepth="0" Opacity="1.0"/>
                            </Border.Effect>
                        </Border>

                        <!-- Waiting overlay when no AI data -->
                        <Grid Panel.ZIndex="50"
                              Visibility="{Binding IsAiCommandEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Background="#E60D1117">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="🧠" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock Text="AI COMMAND CENTER" FontSize="20" FontWeight="Bold"
                                           Foreground="#58A6FF" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="START 버튼을 눌러 AI 분석을 시작하세요" FontSize="14"
                                           Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <Border Background="#161B22" CornerRadius="8" Padding="16,10" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="8" Height="8" Fill="#FFB300" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="대기 중 — AI 엔진이 실시간 데이터를 수신하면 자동 활성화됩니다"
                                                   FontSize="12" Foreground="#C9D1D9"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Style="{StaticResource MinimalScrollViewer}" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>    <!-- Left: Bull/Bear seesaw -->
                                <ColumnDefinition Width="*"/>      <!-- Center: AI gauge + TF sync -->
                                <ColumnDefinition Width="260"/>    <!-- Right: Sniper view -->
                            </Grid.ColumnDefinitions>

                            <!-- ── LEFT: Bull/Bear Seesaw ── -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="⚖ MARKET POWER"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="#58A6FF" Margin="0,0,0,16"
                                               HorizontalAlignment="Center"/>

                                    <!-- Bull Power Bar -->
                                    <TextBlock Text="🐂 BULL POWER"
                                               FontSize="11" Foreground="#00E676"
                                               FontWeight="Bold" Margin="0,0,0,4"/>
                                    <Grid Height="28" Margin="0,0,0,4">
                                        <Border Background="#1A1F3A" CornerRadius="4"/>
                                        <Border HorizontalAlignment="Left"
                                                CornerRadius="4">
                                            <Border.Width>
                                                <MultiBinding>
                                                    <MultiBinding.Converter>
                                                        <local:PercentageWidthConverter/>
                                                    </MultiBinding.Converter>
                                                    <Binding Path="BullPower"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                </MultiBinding>
                                            </Border.Width>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#00E676" Offset="0"/>
                                                    <GradientStop Color="#00BCD4" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding BullPower, StringFormat={}{0:F0}%}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold" FontSize="12"
                                                   Foreground="White"/>
                                    </Grid>

                                    <!-- Bear Power Bar -->
                                    <TextBlock Text="🐻 BEAR POWER"
                                               FontSize="11" Foreground="#FF5370"
                                               FontWeight="Bold" Margin="0,8,0,4"/>
                                    <Grid Height="28" Margin="0,0,0,12">
                                        <Border Background="#1A1F3A" CornerRadius="4"/>
                                        <Border HorizontalAlignment="Left"
                                                CornerRadius="4">
                                            <Border.Width>
                                                <MultiBinding>
                                                    <MultiBinding.Converter>
                                                        <local:PercentageWidthConverter/>
                                                    </MultiBinding.Converter>
                                                    <Binding Path="BearPower"/>
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                                </MultiBinding>
                                            </Border.Width>
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FF5370" Offset="0"/>
                                                    <GradientStop Color="#FF1744" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding BearPower, StringFormat={}{0:F0}%}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   FontWeight="Bold" FontSize="12"
                                                   Foreground="White"/>
                                    </Grid>

                                    <!-- Current Bias -->
                                    <Border Background="#0A0E27" CornerRadius="8" Padding="12,8">
                                        <StackPanel>
                                            <TextBlock Text="CURRENT BIAS"
                                                       FontSize="11" Foreground="#8B949E" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding CurrentBias}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="{Binding AiCmdBiasColor}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- LONG Scanning Badge -->
                                    <Border Margin="0,12,0,0"
                                            CornerRadius="8" Padding="10,6"
                                            Visibility="{Binding IsLongScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border.Background>
                                            <SolidColorBrush Color="#001A30"/>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#00B0FF" BlurRadius="20" ShadowDepth="0" Opacity="0.8"/>
                                        </Border.Effect>
                                        <TextBlock Text="🔵 LONG SCANNING..."
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="#00B0FF"
                                                   HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- SHORT Alert Badge -->
                                    <Border Margin="0,12,0,0"
                                            CornerRadius="8" Padding="10,6"
                                            Visibility="{Binding IsShortOpportunity, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Border.Background>
                                            <SolidColorBrush Color="#300010"/>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF5370" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                                        </Border.Effect>
                                        <TextBlock Text="🔴 BEARISH REVERSAL"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="#FF5370"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- ── CENTER: AI Confidence + Timeframe Sync ── -->
                            <StackPanel Grid.Column="1" Margin="0,0,12,0">

                                <!-- AI Confidence Gauge Card -->
                                <Border Style="{StaticResource CardStyle}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                            <TextBlock Text="🧠 AI CONFIDENCE — "
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="#E6EDF3"/>
                                            <TextBlock Text="{Binding AiCmdSymbol}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="{StaticResource PrimaryBrush}"/>
                                        </StackPanel>

                                        <!-- Gauge -->
                                        <Grid Grid.Row="1" Height="170" Margin="0,0,0,8">
                                            <!-- Background glow when high confidence -->
                                            <Ellipse x:Name="ellConfidenceGlow"
                                                     Width="150" Height="150"
                                                     Opacity="0"
                                                     Visibility="{Binding AiCmdIsHighConfidence, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#4000E5FF" Offset="0"/>
                                                        <GradientStop Color="#0000E5FF" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                            </Ellipse>

                                            <!-- Arc gauge (drawn from code-behind via x:Name) -->
                                            <Canvas Width="170" Height="170"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                                <!-- Background ring -->
                                                <Ellipse Canvas.Left="10" Canvas.Top="10"
                                                         Width="150" Height="150"
                                                         Stroke="#1A1F3A" StrokeThickness="14"
                                                         Fill="Transparent"/>
                                                <!-- Foreground arc (updated by code-behind) -->
                                                <Path x:Name="pathConfidenceArc"
                                                      StrokeThickness="14"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Fill="Transparent">
                                                    <Path.Effect>
                                                        <DropShadowEffect x:Name="arcGlowEffect"
                                                                          Color="#00E5FF"
                                                                          BlurRadius="18"
                                                                          ShadowDepth="0"
                                                                          Opacity="0.8"/>
                                                    </Path.Effect>
                                                </Path>
                                            </Canvas>

                                            <!-- Center text overlay -->
                                            <StackPanel HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AiCmdConfidenceText}"
                                                           FontSize="40" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{Binding AiCmdGaugeColor}"/>
                                                <TextBlock Text="{Binding AiCmdDirection}"
                                                           FontSize="13" FontWeight="Bold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{Binding AiCmdBiasColor}"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Threshold hint -->
                                        <TextBlock Grid.Row="2"
                                                   Text="★ 85% 초과 시 즉시 진입 (1M Hub 대기 없음)"
                                                   FontSize="11" Foreground="#6B7280"
                                                   HorizontalAlignment="Center"/>
                                    </Grid>
                                </Border>

                                <!-- Timeframe Sync Traffic Lights -->
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="🚦 TIMEFRAME SYNC"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="White" Margin="0,0,0,16"/>

                                        <!-- 4H -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="18" Height="18"
                                                     Fill="{Binding TfH4Color}"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.8"
                                                                      Color="#00E676"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock Grid.Column="1" Text="4H" FontSize="13" FontWeight="Bold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding TfH4Status}"
                                                       FontSize="12" Foreground="{Binding TfH4Color}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- 1H -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="18" Height="18"
                                                     Fill="{Binding TfH1Color}"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.8"
                                                                      Color="#00E676"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock Grid.Column="1" Text="1H" FontSize="13" FontWeight="Bold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding TfH1Status}"
                                                       FontSize="12" Foreground="{Binding TfH1Color}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- 15M -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="18" Height="18"
                                                     Fill="{Binding Tf15mColor}"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.8"
                                                                      Color="#FFB300"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock Grid.Column="1" Text="15M" FontSize="13" FontWeight="Bold"
                                                       Foreground="White" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Tf15mStatus}"
                                                       FontSize="12" Foreground="{Binding Tf15mColor}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ── RIGHT: 1M Sniper View ── -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource CardStyle}"
                                    x:Name="borderSniperView">
                                <StackPanel>
                                    <TextBlock Text="🔫 1M SNIPER VIEW"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="#58A6FF"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,16"/>

                                    <!-- Symbol targeting -->
                                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,12">
                                        <TextBlock Text="TARGET"
                                                   FontSize="11" Foreground="#8B949E" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding AiCmdSymbol}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   HorizontalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Crosshair visual -->
                                    <Grid Width="120" Height="120" Margin="0,0,0,16"
                                          HorizontalAlignment="Center">
                                        <!-- Outer ring -->
                                        <Ellipse Width="120" Height="120"
                                                 Stroke="{Binding Tf15mColor}"
                                                 StrokeThickness="2"
                                                 Fill="Transparent"/>
                                        <!-- Inner ring -->
                                        <Ellipse Width="80" Height="80"
                                                 Stroke="{Binding Tf15mColor}"
                                                 StrokeThickness="1"
                                                 Fill="Transparent"
                                                 Opacity="0.6"/>
                                        <!-- Cross lines -->
                                        <Line X1="60" Y1="0" X2="60" Y2="46"
                                              Stroke="{Binding Tf15mColor}" StrokeThickness="1.5"/>
                                        <Line X1="60" Y1="74" X2="60" Y2="120"
                                              Stroke="{Binding Tf15mColor}" StrokeThickness="1.5"/>
                                        <Line X1="0" Y1="60" X2="46" Y2="60"
                                              Stroke="{Binding Tf15mColor}" StrokeThickness="1.5"/>
                                        <Line X1="74" Y1="60" X2="120" Y2="60"
                                              Stroke="{Binding Tf15mColor}" StrokeThickness="1.5"/>
                                        <!-- Center dot -->
                                        <Ellipse Width="8" Height="8"
                                                 Fill="{Binding Tf15mColor}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Effect>
                                                <DropShadowEffect Color="#00E5FF"
                                                                  BlurRadius="10" ShadowDepth="0"/>
                                            </Ellipse.Effect>
                                        </Ellipse>
                                    </Grid>

                                    <!-- READY TO SHOOT blinking -->
                                    <TextBlock x:Name="txtSniperReady"
                                               Text="🎯 READY TO SHOOT"
                                               FontSize="16" FontWeight="Bold"
                                               Foreground="#FFB300"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding IsSniperReady, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                                    <!-- FIRE status (visible when Tf15mStatus == FIRE, via data trigger in code) -->
                                    <TextBlock x:Name="txtSniperFire"
                                               Text="🔥 FIRE!"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="#FF5370"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"
                                               Visibility="Collapsed">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="#FF5370" BlurRadius="20" ShadowDepth="0"/>
                                        </TextBlock.Effect>
                                    </TextBlock>

                                    <!-- Countdown -->
                                    <TextBlock Text="{Binding SniperCountdownText}"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="#FF5370"
                                               HorizontalAlignment="Center"
                                               Margin="0,4,0,0"/>

                                    <!-- Confidence bar -->
                                    <StackPanel Margin="0,12,0,0">
                                        <TextBlock Text="CONFIDENCE LEVEL"
                                                   FontSize="10" Foreground="#6B7280"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,4"/>
                                        <ProgressBar Value="{Binding AiCmdConfidence}"
                                                     Minimum="0" Maximum="100"
                                                     Height="8"
                                                     Background="#1A1F3A">
                                            <ProgressBar.Foreground>
                                                <SolidColorBrush Color="#00E5FF"/>
                                            </ProgressBar.Foreground>
                                        </ProgressBar>
                                        <TextBlock Text="{Binding AiCmdConfidenceText}"
                                                   FontSize="11" Foreground="{Binding AiCmdGaugeColor}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- 상승 에너지 잔량 (Price Position in Forecast Band) -->
                        <!-- ML.NET Fib 0.382~0.5 눌림목 → 초록, TF 수렴후발산 → 금색 깜빡임 -->
                        <Border x:Name="PriceEnergyBorder" Background="#1A1F3A" CornerRadius="10" Padding="14" Margin="0,10,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <!-- TF 수렴 후 발산 감지 시 깜빡임 애니메이션 -->
                                        <DataTrigger Binding="{Binding PriceEnergyPulseActive}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="PulseStoryboard">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <ColorAnimation
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            From="#FFD700" To="#1A1F3A"
                                                            Duration="0:0:0.5"
                                                            AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="PulseStoryboard"/>
                                            </DataTrigger.ExitActions>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#FFD700"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="PRICE ENERGY" FontSize="10" Foreground="#6B7280" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PriceProgressZone}" FontSize="10"
                                               Foreground="{Binding PriceProgressColor}" FontWeight="Bold"/>
                                </Grid>
                                <ProgressBar x:Name="PriceEnergyBar"
                                             Value="{Binding PriceProgress, Mode=OneWay}" Maximum="100" Height="10"
                                             Background="#252B48" Margin="0,6,0,0"
                                             Foreground="{Binding PriceProgressColor}">
                                    <ProgressBar.Style>
                                        <Style TargetType="ProgressBar">
                                            <Style.Triggers>
                                                <!-- TF 수렴 후 발산 → ProgressBar 자체도 깜빡임 -->
                                                <DataTrigger Binding="{Binding PriceEnergyPulseActive}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard x:Name="BarPulse">
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation
                                                                    Storyboard.TargetProperty="Opacity"
                                                                    From="1.0" To="0.3"
                                                                    Duration="0:0:0.4"
                                                                    AutoReverse="True"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="BarPulse"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ProgressBar.Style>
                                </ProgressBar>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Fib .382" FontSize="8" Foreground="#4B5563"/>
                                    <TextBlock Grid.Column="1" Text="{Binding PriceProgressText}" FontSize="12"
                                               Foreground="{Binding PriceProgressColor}" FontWeight="Bold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="Fib 1.0" FontSize="8" Foreground="#4B5563"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- AI Dynamic Trailing Stop: Exit Score Gauge -->
                        <Border Background="#1A1F3A" CornerRadius="10" Padding="14" Margin="0,10,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ExitScorePulseActive, Mode=OneWay}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="ExitPulse">
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <ColorAnimation
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            From="#FF5370" To="#1A1F3A"
                                                            Duration="0:0:0.4" AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="ExitPulse"/>
                                            </DataTrigger.ExitActions>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="BorderBrush">
                                                <Setter.Value><SolidColorBrush Color="#FF5370"/></Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="EXIT SCORE" FontSize="10"
                                               Foreground="#6B7280" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ExitScoreZone, Mode=OneWay}" FontSize="10"
                                               Foreground="{Binding ExitScoreColor, Mode=OneWay}" FontWeight="Bold"
                                               Margin="0,0,10,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DynamicStopPriceText}" FontSize="10"
                                               Foreground="#94A3B8"/>
                                </Grid>
                                <ProgressBar Value="{Binding ExitScore, Mode=OneWay}" Maximum="100" Height="10"
                                             Background="#252B48" Margin="0,6,0,0"
                                             Foreground="{Binding ExitScoreColor, Mode=OneWay}"/>
                                <TextBlock Text="{Binding ExitScoreText, Mode=OneWay}" FontSize="11"
                                           Foreground="{Binding ExitScoreColor, Mode=OneWay}" HorizontalAlignment="Center"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Entry Pipeline: Block Reason + Volume Gauge + Profit Target -->
                        <Border Background="#1A1F3A" CornerRadius="10" Padding="14" Margin="0,10,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Block Reason -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="ENTRY STATUS" FontSize="10" Foreground="#6B7280" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding BlockReason}" FontSize="12" Foreground="#FF5370"
                                               Visibility="{Binding HasBlockReason, Converter={StaticResource BoolToVisibilityConverter}}"
                                               TextWrapping="Wrap" Margin="0,3,0,0"/>
                                    <TextBlock x:Name="txtEntryReady" Text="READY" FontSize="12" Foreground="#00E676"
                                               Margin="0,3,0,0"/>
                                </StackPanel>

                                <!-- Volume Gauge -->
                                <StackPanel Grid.Column="1" Margin="16,0" MinWidth="100" VerticalAlignment="Center">
                                    <TextBlock Text="1M VOLUME" FontSize="10" Foreground="#6B7280" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <ProgressBar Value="{Binding VolumeGauge, Mode=OneWay}" Maximum="100" Height="8"
                                                 Background="#252B48" Margin="0,5,0,0">
                                        <ProgressBar.Foreground>
                                            <SolidColorBrush Color="#00E5FF"/>
                                        </ProgressBar.Foreground>
                                    </ProgressBar>
                                    <TextBlock Text="{Binding VolumeGaugeText}" FontSize="11"
                                               Foreground="{Binding VolumeGaugeColor}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>

                                <!-- Daily Profit Target -->
                                <StackPanel Grid.Column="2" MinWidth="130" VerticalAlignment="Center">
                                    <TextBlock Text="DAILY TARGET" FontSize="10" Foreground="#6B7280" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <ProgressBar Value="{Binding DailyProfitProgress, Mode=OneWay}" Maximum="100" Height="8"
                                                 Background="#252B48" Margin="0,5,0,0">
                                        <ProgressBar.Foreground>
                                            <SolidColorBrush Color="#00E676"/>
                                        </ProgressBar.Foreground>
                                    </ProgressBar>
                                    <TextBlock Text="{Binding DailyProfitText}" FontSize="11"
                                               Foreground="{Binding DailyProfitColor}" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- PERFORMANCE TAB (v3.7.0 리디자인) -->
                <TabItem Header="📊  PERFORMANCE">
                    <ScrollViewer Style="{StaticResource MinimalScrollViewer}" Background="#0D1117">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="350"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더: 기간 탭 + 요약 -->
                        <Border Grid.Row="0" Background="#161B22" CornerRadius="12" Padding="16,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="PERFORMANCE" FontSize="16" FontWeight="Bold" Foreground="#E6EDF3" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                    <Border Background="#21262D" CornerRadius="8" Padding="2">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Content="  일별  " GroupName="PerfPeriod" IsChecked="True" Margin="2" Checked="PerfDaily_Checked"
                                                         FontSize="13" FontWeight="Bold" Foreground="White" Background="#30363D"
                                                         BorderBrush="#58A6FF" BorderThickness="1" Padding="12,6"
                                                         Style="{StaticResource {x:Type ToggleButton}}"/>
                                            <RadioButton Content="  주별  " GroupName="PerfPeriod" Margin="2" Checked="PerfWeekly_Checked"
                                                         FontSize="13" FontWeight="Bold" Foreground="White" Background="#30363D"
                                                         BorderBrush="#58A6FF" BorderThickness="1" Padding="12,6"
                                                         Style="{StaticResource {x:Type ToggleButton}}"/>
                                            <RadioButton Content="  월별  " GroupName="PerfPeriod" Margin="2" Checked="PerfMonthly_Checked"
                                                         FontSize="13" FontWeight="Bold" Foreground="White" Background="#30363D"
                                                         BorderBrush="#58A6FF" BorderThickness="1" Padding="12,6"
                                                         Style="{StaticResource {x:Type ToggleButton}}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding PerformanceSummary}" Foreground="#7EE787" FontSize="13"
                                           FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- PnL 차트 (수익 초록 / 손실 빨강) -->
                        <Border Grid.Row="1" Background="#161B22" CornerRadius="12" Padding="16,12" Margin="0,0,0,8">
                            <lvc:CartesianChart Series="{Binding PerformanceSeries}" LegendLocation="None"
                                               AnimationsSpeed="0:0:0.3" Hoverable="True" Background="Transparent"
                                               xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Labels="{Binding PerformanceLabels}" Foreground="#8B949E" FontSize="11" LabelsRotation="-30">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Foreground="#8B949E" FontSize="11" LabelFormatter="{Binding YFormatter}">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="#21262D" StrokeThickness="1" StrokeDashArray="4,4"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </Border>

                        <!-- 달력 뷰 (7열 그리드) -->
                        <Border Grid.Row="2" Background="#161B22" CornerRadius="12" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="DAILY P&amp;L CALENDAR" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" Margin="4,0,0,10"/>
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding CalendarEntries}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="7"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding CellBackground}" CornerRadius="8" Padding="6,8" Margin="3"
                                                    BorderBrush="{Binding PnlColor}" BorderThickness="1">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding DayLabel}" Foreground="#C9D1D9" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding PnlDisplay}" Foreground="{Binding PnlColor}"
                                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding TradeCountDisplay}" Foreground="#8B949E" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- AI MONITOR TAB -->
                <TabItem Header="🤖  AI MONITOR">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">

                            <!-- Model Accuracy Cards -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="🎯 AI MODEL ACCURACY"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <TextBlock Text="기준: Confidence 60% 이상 샘플 기준 / 목표 정확도 65% 이상"
                                               FontSize="11"
                                               Foreground="#9CA3AF"
                                               Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Style="{StaticResource StatCardStyle}"
                                                Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="ML.NET"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding MLNetAccuracy, StringFormat={}{0:F1}%}"
                                                           FontSize="32"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource StatCardStyle}"
                                                Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Transformer"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding TransformerAccuracy, StringFormat={}{0:F1}%}"
                                                           FontSize="32"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource SecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Performance Comparison -->
                            <Border Style="{StaticResource CardStyle}"
                                    Padding="0">
                                <StackPanel Margin="20">
                                    <TextBlock Text="📊 MODEL PERFORMANCE COMPARISON"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <DataGrid ItemsSource="{Binding ModelPerformances}"
                                              Style="{StaticResource ModernDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="MODEL"
                                                                Binding="{Binding ModelName}"
                                                                Width="*"/>
                                            <DataGridTextColumn Header="ACCURACY (C≥60%)"
                                                                Binding="{Binding Accuracy, StringFormat={}{0:F2}%}"
                                                                Width="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight"
                                                                Value="Bold"/>
                                                        <Setter Property="Foreground"
                                                                Value="{Binding StatusColor}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="PREDICTIONS"
                                                                Binding="{Binding TotalPredictions}"
                                                                Width="120"/>
                                            <DataGridTextColumn Header="CORRECT"
                                                                Binding="{Binding CorrectPredictions}"
                                                                Width="100"/>
                                            <DataGridTextColumn Header="CONFIDENCE"
                                                                Binding="{Binding AvgConfidence, StringFormat={}{0:F2}%}"
                                                                Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Prediction Chart -->
                            <Border Style="{StaticResource CardStyle}"
                                    Height="350">
                                <StackPanel>
                                    <TextBlock Text="🔮 PREDICTION vs ACTUAL (Last 20)"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <lvc:CartesianChart Series="{Binding PredictionComparisonSeries}"
                                                        LegendLocation="Bottom"
                                                        Hoverable="True">
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="Price (USDT)"
                                                      MinValue="{Binding PredictionChartAxisMin}"
                                                      MaxValue="{Binding PredictionChartAxisMax}"
                                                      Foreground="#9CA3AF"
                                                      LabelFormatter="{Binding LiveChartYFormatter}"/>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="Prediction #"
                                                      Foreground="#9CA3AF"/>
                                        </lvc:CartesianChart.AxisX>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ADVANCED FEATURES TAB -->
                <TabItem Header="⚡ ADVANCED"
                         Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <!-- Arbitrage Panel -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💰 ARBITRAGE TRADING"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Min Profit (%):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtArbitrageMinProfit"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="0.2"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Scan Interval (s):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtArbitrageScanInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="60"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartArbitrage"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartArbitrage_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopArbitrage"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopArbitrage_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtArbitrageStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Fund Transfer Panel -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💱 FUND TRANSFER"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Check Interval (min):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtFundTransferInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="60"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Min Amount (USDT):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtFundTransferMinAmount"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="100"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartFundTransfer"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartFundTransfer_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopFundTransfer"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopFundTransfer_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtFundTransferStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Rebalancing Panel -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock Text="⚖ PORTFOLIO REBALANCING"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Check Interval (h):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtRebalancingInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="24"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Threshold (%):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtRebalancingThreshold"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="5.0"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartRebalancing"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartRebalancing_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopRebalancing"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopRebalancing_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtRebalancingStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- UNIFIED FOOTER BAR (40px) — Log | Status | Clock | Connection -->
            <Border Grid.Row="3"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#2D3454"
                    CornerRadius="0,0,12,12">
                <Border.Effect>
                    <DropShadowEffect Color="{StaticResource PrimaryColor}"
                                      BlurRadius="6"
                                      ShadowDepth="0"
                                      Opacity="0.2"/>
                </Border.Effect>
                <Grid Margin="16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bell icon + Footer log -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Background="#0A1220"
                                CornerRadius="5"
                                Padding="6,3"
                                Margin="0,0,10,0">
                            <TextBlock Text="🔔"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               x:Name="lblFooter"
                               Text="SYSTEM READY  •  WAITING FOR COMMAND"
                               Foreground="#A5B4FC"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{StaticResource PrimaryColor}"
                                              BlurRadius="4"
                                              ShadowDepth="0"
                                              Opacity="0.3"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Right: Profile | Telegram | Clock | Connected -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="txtMajorProfileStatus"
                                   Text="● Major Profile: Balanced"
                                   Foreground="#9CA3AF"
                                   FontSize="10"
                                   Margin="0,0,14,0"/>
                        <TextBlock x:Name="txtTelegramStatus"
                                   Text="Telegram: Offline"
                                   Foreground="#6B7280"
                                   FontSize="10"
                                   Margin="0,0,14,0"/>
                        <!-- Live Clock -->
                        <Border Background="#0A1220"
                                BorderBrush="#1E3A5F"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="8,3"
                                Margin="0,0,14,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="txtDateDisplay"
                                           Text="----/--/--"
                                           Foreground="#4B5563"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock x:Name="txtTimeDisplay"
                                           Text="--:--:--"
                                           Foreground="#00E5FF"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           FontFamily="Consolas"
                                           VerticalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="#00E5FF" BlurRadius="6" ShadowDepth="0" Opacity="0.4"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <!-- Connection -->
                        <Ellipse Width="7"
                                 Height="7"
                                 Fill="{StaticResource AccentBrush}"
                                 Margin="0,0,5,0"/>
                        <TextBlock Text="Binance  •  Connected"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="10"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
