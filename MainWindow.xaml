<Window x:Class="TradingBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:TradingBot"
            Title="COINFF TRADINGBOT"
        Height="950"
        Width="1600"
        MinHeight="700"
        MinWidth="1200"
        Background="#0A0E27"
        Foreground="#E0E7FF"
        FontFamily="Segoe UI, Malgun Gothic"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Icon="/trading_bot.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="64"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="12"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Converters -->
        <local:StatusToIconConverter x:Key="StatusToIconConverter"/>
        <local:GreaterThanConverter x:Key="GreaterThanConverter"/>
        <local:LessThanConverter x:Key="LessThanConverter"/>
        <local:InvertBooleanConverter x:Key="InvertBooleanConverter"/>
        <local:PriceFormattingConverter x:Key="PriceFormattingConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Color Resources -->
        <Color x:Key="PrimaryColor">#00E5FF</Color>
        <Color x:Key="SecondaryColor">#7C4DFF</Color>
        <Color x:Key="AccentColor">#00E676</Color>
        <Color x:Key="ErrorColor">#FF5370</Color>
        <Color x:Key="WarningColor">#FFB300</Color>
        <Color x:Key="BackgroundDark">#0A0E27</Color>
        <Color x:Key="BackgroundMedium">#1A1F3A</Color>
        <Color x:Key="BackgroundLight">#252B48</Color>

        <SolidColorBrush x:Key="PrimaryBrush"
                         Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="SecondaryBrush"
                         Color="{StaticResource SecondaryColor}"/>
        <SolidColorBrush x:Key="AccentBrush"
                         Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="ErrorBrush"
                         Color="{StaticResource ErrorColor}"/>
        <SolidColorBrush x:Key="WarningBrush"
                         Color="{StaticResource WarningColor}"/>
        <SolidColorBrush x:Key="BackgroundDarkBrush"
                         Color="{StaticResource BackgroundDark}"/>
        <SolidColorBrush x:Key="BackgroundMediumBrush"
                         Color="{StaticResource BackgroundMedium}"/>
        <SolidColorBrush x:Key="BackgroundLightBrush"
                         Color="{StaticResource BackgroundLight}"/>

        <!-- Modern Button Style -->
        <Style x:Key="ModernButtonStyle"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground"
                    Value="#E0E7FF"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="20,10"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource BackgroundLight}"
                                                         Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="{StaticResource PrimaryColor}"
                                                          BlurRadius="20"
                                                          ShadowDepth="0"
                                                          Opacity="0.4"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="{StaticResource BackgroundLight}"
                                                         Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="border"
                                        Property="Opacity"
                                        Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryButtonStyle"
               BasedOn="{StaticResource ModernButtonStyle}"
               TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="{StaticResource PrimaryColor}"
                                      Offset="0"/>
                        <GradientStop Color="{StaticResource SecondaryColor}"
                                      Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>

        <!-- Success Button -->
        <Style x:Key="SuccessButtonStyle"
               BasedOn="{StaticResource ModernButtonStyle}"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>

        <!-- Danger Button -->
        <Style x:Key="DangerButtonStyle"
               BasedOn="{StaticResource ModernButtonStyle}"
               TargetType="Button">
            <Setter Property="Background"
                    Value="{StaticResource ErrorBrush}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
        </Style>

        <!-- Modern Card Style -->
        <Style x:Key="CardStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="{StaticResource BackgroundMediumBrush}"/>
            <Setter Property="CornerRadius"
                    Value="12"/>
            <Setter Property="Padding"
                    Value="20"/>
            <Setter Property="Margin"
                    Value="0,0,0,16"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#2D3454"
                                     Opacity="0.5"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="25"
                                      ShadowDepth="2"
                                      Direction="270"
                                      Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Stat Card Style -->
        <Style x:Key="StatCardStyle"
               TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#1A1F3A"
                                      Offset="0"/>
                        <GradientStop Color="#252B48"
                                      Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius"
                    Value="10"/>
            <Setter Property="Padding"
                    Value="16"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0"
                                         EndPoint="1,1">
                        <GradientStop Color="#4D00E5FF"
                                      Offset="0"/>
                        <GradientStop Color="#4D7C4DFF"
                                      Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="15"
                                      ShadowDepth="2"
                                      Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern DataGrid Style -->
        <Style x:Key="ModernDataGridStyle"
               TargetType="DataGrid">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#E0E7FF"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="GridLinesVisibility"
                    Value="None"/>
            <Setter Property="RowBackground"
                    Value="Transparent"/>
            <Setter Property="AlternatingRowBackground">
                <Setter.Value>
                    <SolidColorBrush Color="#1A1F3A"
                                     Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="ColumnHeaderHeight"
                    Value="48"/>
            <Setter Property="RowHeight"
                    Value="60"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="CanUserAddRows"
                    Value="False"/>
            <Setter Property="CanUserDeleteRows"
                    Value="False"/>
            <Setter Property="AutoGenerateColumns"
                    Value="False"/>
            <Setter Property="SelectionMode"
                    Value="Single"/>
            <Setter Property="IsReadOnly"
                    Value="True"/>
            <Setter Property="HeadersVisibility"
                    Value="Column"/>
        </Style>

        <!-- DataGrid Column Header Style -->
        <Style x:Key="ModernColumnHeaderStyle"
               TargetType="DataGridColumnHeader">
            <Setter Property="Background"
                    Value="{StaticResource BackgroundMediumBrush}"/>
            <Setter Property="Foreground"
                    Value="#9CA3AF"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="FontSize"
                    Value="12"/>
            <Setter Property="Padding"
                    Value="16,12"/>
            <Setter Property="BorderThickness"
                    Value="0,0,0,2"/>
            <Setter Property="BorderBrush"
                    Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
        </Style>

        <!-- Tab Style -->
        <Style TargetType="TabControl">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Padding"
                    Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground"
                    Value="#6B7280"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Padding"
                    Value="20,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                CornerRadius="4,4,0,0"
                                Padding="{TemplateBinding Padding}"
                                Margin="0,0,8,0">
                            <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="Border"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Foreground"
                                        Value="#E0E7FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Foreground"
                                        Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Smooth Animations -->
        <Storyboard x:Key="GlowAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0.4"
                             To="1.0"
                             Duration="0:0:1.5"
                             AutoReverse="True"
                             RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <!-- Main Container with Rounded Corners -->
    <Border Background="{StaticResource BackgroundDarkBrush}"
            CornerRadius="12"
            BorderThickness="1">
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0"
                                 EndPoint="1,1">
                <GradientStop Color="#4D00E5FF"
                              Offset="0"/>
                <GradientStop Color="#4D7C4DFF"
                              Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="3"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundMediumBrush}"
                    CornerRadius="12,12,0,0"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#2D3454">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo & Title -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="32"
                                Height="32"
                                CornerRadius="6"
                                Margin="0,0,12,0"
                                Background="#1A1F3A">
                            <Image Source="trading_bot.jpg"
                                   Stretch="UniformToFill">
                                <Image.Clip>
                                    <RectangleGeometry Rect="0,0,32,32"
                                                       RadiusX="6"
                                                       RadiusY="6"/>
                                </Image.Clip>
                            </Image>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="COINFF"
                                           FontSize="18"
                                           FontWeight="Black"
                                           Foreground="{StaticResource AccentBrush}">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="{StaticResource AccentColor}"
                                                          BlurRadius="12"
                                                          ShadowDepth="0"
                                                          Opacity="0.5"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text=" TRADING"
                                           FontSize="18"
                                           FontWeight="Light"
                                           Foreground="#E0E7FF"
                                           Margin="2,0,0,0"/>
                                <TextBlock x:Name="txtHeaderVersion"
                                           Text=" v0.0.0"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Bottom"
                                           Margin="8,0,0,3"
                                           Opacity="0.7"/>
                            </StackPanel>
                            <TextBlock Text="AI-POWERED FUTURES TRADING ENGINE"
                                       FontSize="8"
                                       Foreground="#6B7280"
                                       FontWeight="SemiBold"
                                       Margin="0,-2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Controls Center -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- Exchange Selector -->
                        <ComboBox x:Name="cmbExchange"
                                  Width="130"
                                  Height="34"
                                  SelectedIndex="0"
                                  Margin="0,0,12,0"
                                  Background="{StaticResource BackgroundLightBrush}"
                                  Foreground="#4B5563"
                                  BorderBrush="{StaticResource PrimaryBrush}"
                                  FontWeight="SemiBold"
                                  WindowChrome.IsHitTestVisibleInChrome="True"
                                  FontSize="18">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Foreground"
                                            Value="White"/>
                                    <Setter Property="Background"
                                            Value="#252B48"/>
                                    <Setter Property="Padding"
                                            Value="8,4"/>
                                    <Setter Property="FontWeight"
                                            Value="SemiBold"/>
                                    <Setter Property="FontSize"
                                            Value="20"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsHighlighted"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="#2D3454"/>
                                            <Setter Property="Foreground"
                                                    Value="#00E5FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="#1A1F3A"/>
                                            <Setter Property="Foreground"
                                                    Value="#00E5FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                            <ComboBoxItem Content="🟡 Binance"/>
                            <ComboBoxItem Content="🟣 Bybit"/>
                        </ComboBox>

                        <!-- Main Actions -->
                        <Button x:Name="btnStart"
                                Content="▶ START"
                                Width="120"
                                Height="36"
                                Style="{StaticResource SuccessButtonStyle}"
                                Click="btnStart_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnStop"
                                Content="⏹ STOP"
                                Width="105"
                                Height="36"
                                Style="{StaticResource DangerButtonStyle}"
                                Click="btnStop_Click"
                                IsEnabled="False"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnBacktest"
                                Content="📊 BACKTEST"
                                Width="130"
                                Height="36"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="btnBacktest_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                                ToolTip="시장 그리드에서 종목을 더블클릭으로 선택한 후 클릭&#x0a;30일간 엘리엇 웨이브 전략으로 백테스트 실행"
                                Margin="0,0,8,0"/>
                        <Button x:Name="btnOptimize"
                                Content="⚙ OPTIMIZE"
                                Width="130"
                                Height="36"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="btnOptimize_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="시장 그리드에서 종목을 더블클릭으로 선택한 후 클릭&#x0a;다양한 전략과 기간으로 최적화 테스트"
                            Margin="0,0,8,0"/>
                    </StackPanel>

                    <!-- Right Controls -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                        <!-- Admin Menu -->
                        <Menu x:Name="mnuAdmin"
                              Background="Transparent"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              Visibility="Collapsed">
                            <MenuItem Header="👑 ADMIN"
                                      Foreground="#FFB300"
                                      FontWeight="Bold"
                                      FontSize="12">
                                <MenuItem Header="👥 User Management"
                                          Click="mnuUserManagement_Click"/>
                                <Separator/>
                                <MenuItem x:Name="mnuPendingCount"
                                          Header="⏳ Pending: 0"
                                          IsEnabled="False"
                                          Foreground="Orange"/>
                            </MenuItem>
                        </Menu>

                        <!-- User & Settings -->
                        <Button Content="👤"
                                Width="32"
                                Height="32"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="btnProfile_Click"
                                Padding="0"
                                Margin="0,0,6,0"
                                ToolTip="Profile"/>
                        <Button x:Name="btnSettings"
                                Content="⚙"
                                Width="32"
                                Height="32"
                                Style="{StaticResource ModernButtonStyle}"
                                Click="btnSettings_Click"
                                Padding="0"
                                Margin="0,0,16,0"
                                ToolTip="Settings"/>

                        <!-- Window Controls -->
                        <Button Content="─"
                                Width="38"
                                Height="32"
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderThickness="0"
                                FontSize="14"
                                Click="OnMinimize_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="#2D3454"/>
                                            <Setter Property="Foreground"
                                                    Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="☐"
                                Width="38"
                                Height="32"
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderThickness="0"
                                FontSize="14"
                                Click="OnMaximize_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="#2D3454"/>
                                            <Setter Property="Foreground"
                                                    Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="✕"
                                Width="38"
                                Height="32"
                                Background="Transparent"
                                Foreground="#6B7280"
                                BorderThickness="0"
                                FontSize="14"
                                Click="OnClose_Click"
                                WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"
                                            Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter Property="Background"
                                                    Value="{StaticResource ErrorBrush}"/>
                                            <Setter Property="Foreground"
                                                    Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Progress Bar -->
            <ProgressBar Grid.Row="1"
                         x:Name="pgScanning"
                         Height="3"
                         Background="Transparent"
                         Foreground="{StaticResource AccentBrush}"
                         BorderThickness="0"/>

            <!-- MAIN CONTENT -->
            <TabControl Grid.Row="2"
                        Margin="16">
                <!-- DASHBOARD TAB -->
                <TabItem Header="📊  DASHBOARD">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Sidebar -->
                        <StackPanel Grid.Column="0"
                                    Margin="0,0,16,0">
                            <Border Style="{StaticResource CardStyle}"
                                    Padding="16"
                                    Margin="0,0,0,16">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="txtDateDisplay"
                                               Text="----/--/--"
                                               Foreground="#4B5563"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               TextAlignment="Center"/>
                                    <TextBlock x:Name="txtTimeDisplay"
                                               Text="--:--:--"
                                               Foreground="#00E5FF"
                                               FontSize="32"
                                               FontWeight="Light"
                                               TextAlignment="Center"
                                               Margin="0,6,0,0"
                                               FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>

                            <!-- Account Card -->
                            <Border Style="{StaticResource StatCardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="💰 ACCOUNT OVERVIEW"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                        <TextBlock x:Name="txtAccountMode"
                                                   Text=""
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="Total Equity"
                                                   Foreground="#9CA3AF"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   x:Name="txtTotalEquity"
                                                   Text="$0.00"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="Bold"/>

                                        <TextBlock Grid.Row="1"
                                                   Text="Available"
                                                   Foreground="#9CA3AF"
                                                   FontSize="12"
                                                   Margin="0,8,0,0"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   x:Name="txtAvailableBalance"
                                                   Text="$0.00"
                                                   Foreground="#E0E7FF"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Grid.Row="2"
                                                   Text="ROI"
                                                   Foreground="#9CA3AF"
                                                   FontSize="12"
                                                   Margin="0,8,0,0"/>
                                        <TextBlock Grid.Row="2"
                                                   Grid.Column="1"
                                                   Text="{Binding AverageRoe, StringFormat={}{0:F2}%}"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Grid.Row="3"
                                                   Text="Active Positions"
                                                   Foreground="#9CA3AF"
                                                   FontSize="12"
                                                   Margin="0,8,0,0"/>
                                        <TextBlock Grid.Row="3"
                                                   Grid.Column="1"
                                                   x:Name="txtTotalPositionInfo"
                                                   Text="0"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Margin="0,8,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Entry Gate Card -->
                            <Border Style="{StaticResource StatCardStyle}"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="🧠 ENTRY GATE STATUS"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Text="PASS"
                                                   Foreground="#9CA3AF"
                                                   FontSize="12"/>
                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="1"
                                                   Text="{Binding GatePassCount}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="16"
                                                   FontWeight="Bold"/>

                                        <TextBlock Grid.Row="1"
                                                   Text="BLOCK"
                                                   Foreground="#9CA3AF"
                                                   FontSize="12"
                                                   Margin="0,8,0,0"/>
                                        <TextBlock Grid.Row="1"
                                                   Grid.Column="1"
                                                   Text="{Binding GateBlockCount}"
                                                   Foreground="{StaticResource ErrorBrush}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Margin="0,8,0,0"/>

                                        <TextBlock Grid.Row="2"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding GateThresholdSummaryText}"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Margin="0,10,0,0"/>

                                        <TextBlock Grid.Row="3"
                                                   Grid.ColumnSpan="2"
                                                   Text="{Binding GateAutoTuneStatusText}"
                                                   Foreground="#9CA3AF"
                                                   FontSize="10"
                                                   FontFamily="Consolas"
                                                   Margin="0,8,0,0"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Alerts Card -->
                            <Border Style="{StaticResource CardStyle}"
                                    Height="300">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="⚠ CRITICAL ALERTS"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource ErrorBrush}"
                                                   VerticalAlignment="Center"/>

                                        <Border Grid.Column="1"
                                                Background="{StaticResource ErrorBrush}"
                                                CornerRadius="10"
                                                Padding="8,2"
                                                ToolTip="DB 실패 알림 카운트">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="DB"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding DbFailureAlertCount}"
                                                           Foreground="White"
                                                           FontSize="10"
                                                           FontWeight="Bold"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <ListBox x:Name="lstAlerts"
                                             Grid.Row="1"
                                             ItemsSource="{Binding Alerts}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="#E0E7FF"
                                             FontFamily="Consolas"
                                             FontSize="12"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding"
                                                        Value="4,6"/>
                                                <Setter Property="Background"
                                                        Value="Transparent"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Main Content Area -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Market Grid -->
                            <Border Grid.Row="0"
                                    Style="{StaticResource CardStyle}"
                                    Padding="0"
                                    Margin="0,0,0,16">
                                <DataGrid x:Name="dgMultiTimeframe"
                                          Style="{StaticResource ModernDataGridStyle}"
                                          ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                          RowHeight="48"
                                          MaxHeight="380"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          SelectedItem="{Binding SelectedSymbol, Mode=TwoWay}"
                                          MouseDoubleClick="dgMultiTimeframe_MouseDoubleClick">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="SYMBOL"
                                                                Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="8,0">
                                                        <TextBlock Text="{Binding Symbol}"
                                                                   FontSize="15"
                                                                   FontWeight="Bold"
                                                                   Foreground="White"/>
                                                        <TextBlock Text="{Binding PositionSide}"
                                                                   FontSize="10"
                                                                   Foreground="{Binding PositionSideColor}"
                                                                   FontWeight="SemiBold"
                                                                   Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="PRICE"
                                                                Width="120">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="8,0">
                                                        <TextBlock FontFamily="Consolas"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{Binding PriceColor}">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                                    <Binding Path="Symbol"/>
                                                                    <Binding Path="LastPrice"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                        <TextBlock Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Run Text="Entry: "
                                                                 Foreground="#6B7280"
                                                                 FontSize="10"/>
                                                            <Run FontSize="10"
                                                                 Foreground="#9CA3AF">
                                                                <Run.Text>
                                                                    <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                                        <Binding Path="Symbol"/>
                                                                        <Binding Path="EntryPrice"/>
                                                                    </MultiBinding>
                                                                </Run.Text>
                                                            </Run>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="ROI"
                                                            Binding="{Binding ProfitRate, StringFormat={}{0:F2}%}"
                                                            Width="80">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontWeight"
                                                            Value="Bold"/>
                                                    <Setter Property="HorizontalAlignment"
                                                            Value="Center"/>
                                                    <Setter Property="Foreground"
                                                            Value="{Binding ProfitColor}"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="AI"
                                                            Binding="{Binding AIScore, StringFormat=F1}"
                                                            Width="70"/>

                                        <DataGridTextColumn Header="AI시각"
                                                    Binding="{Binding AIScoreUpdatedText}"
                                                    Width="78">
                                            <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontFamily"
                                                    Value="Consolas"/>
                                                <Setter Property="HorizontalAlignment"
                                                    Value="Center"/>
                                                <Setter Property="Foreground"
                                                    Value="#9CA3AF"/>
                                            </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="L/S"
                                                            Binding="{Binding LsScoreText}"
                                                            Width="140">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily"
                                                            Value="Consolas"/>
                                                    <Setter Property="FontWeight"
                                                            Value="Bold"/>
                                                    <Setter Property="HorizontalAlignment"
                                                            Value="Center"/>
                                                    <Setter Property="VerticalAlignment"
                                                            Value="Center"/>
                                                    <Setter Property="Foreground"
                                                            Value="#E0E7FF"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="SIGNAL"
                                                                Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding DecisionBg}"
                                                            CornerRadius="6"
                                                            Padding="10,4"
                                                            Margin="4">
                                                        <TextBlock Text="{Binding DisplayDecision}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="EXIT"
                                                                Width="110">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding CloseStatusBackground}"
                                                            CornerRadius="6"
                                                            Padding="8,4"
                                                            Margin="4"
                                                            ToolTip="{Binding CloseIncompleteDetail}">
                                                        <TextBlock Text="{Binding CloseStatusText}"
                                                                   Foreground="{Binding CloseStatusForeground}"
                                                                   FontWeight="Bold"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTemplateColumn Header="SYNC"
                                                                Width="100">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border Background="{Binding SyncStatusBackground}"
                                                            CornerRadius="6"
                                                            Padding="8,4"
                                                            Margin="4"
                                                            ToolTip="{Binding ExternalSyncDetail}">
                                                        <TextBlock Text="{Binding SyncStatusText}"
                                                                   Foreground="{Binding SyncStatusForeground}"
                                                                   FontWeight="Bold"
                                                                   FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>

                                        <DataGridTextColumn Header="SOURCE"
                                                            Binding="{Binding SignalSource, TargetNullValue=-, FallbackValue=-}"
                                                            Width="85">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="HorizontalAlignment"
                                                            Value="Center"/>
                                                    <Setter Property="Foreground"
                                                            Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="FontWeight"
                                                            Value="SemiBold"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="SETUP"
                                                            Binding="{Binding ShortTermContext, TargetNullValue=-, FallbackValue=-}"
                                                            Width="450">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="FontFamily"
                                                            Value="Consolas"/>
                                                    <Setter Property="Foreground"
                                                            Value="#9CA3AF"/>
                                                    <Setter Property="Margin"
                                                            Value="12,0"/>
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTemplateColumn Header="ACTION"
                                                                Width="80">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="CLOSE"
                                                            Command="{Binding DataContext.ClosePositionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Symbol}"
                                                            Style="{StaticResource DangerButtonStyle}"
                                                            FontSize="10"
                                                            Padding="8,4"
                                                            Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <!-- Log Panel -->
                            <Border Grid.Row="1"
                                    Style="{StaticResource CardStyle}"
                                    Margin="0"
                                    MaxHeight="220">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="📝 LIVE LOG (TRADE / GATE)"
                                               FontSize="12"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,0,0,8"/>
                                    <Grid Grid.Row="1"
                                          MaxHeight="180">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                BorderBrush="#2D3454"
                                                BorderThickness="0,0,1,0"
                                                Padding="0,0,8,0">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Top"
                                                           Text="TRADE"
                                                           Foreground="#9CA3AF"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4"/>
                                                <ListBox ItemsSource="{Binding TradeLogs}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="#E0E7FF"
                                                         FontFamily="Consolas"
                                                         FontSize="10"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                            </DockPanel>
                                        </Border>
                                        <Border Grid.Column="1"
                                                Padding="8,0,0,0">
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Top"
                                                           Text="GATE"
                                                           Foreground="#9CA3AF"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,4"/>
                                                <ListBox ItemsSource="{Binding GateLogs}"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="#E0E7FF"
                                                         FontFamily="Consolas"
                                                         FontSize="10"
                                                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                                            </DockPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- TRADE HISTORY TAB -->
                <TabItem Header="📈  TRADE HISTORY">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,0,0,16">
                            <TextBlock Text="Start:"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding StartDate}"
                                        Width="130"
                                        Margin="0,0,16,0"/>

                            <TextBlock Text="End:"
                                       VerticalAlignment="Center"
                                       Foreground="#9CA3AF"
                                       Margin="0,0,8,0"/>
                            <DatePicker SelectedDate="{Binding EndDate}"
                                        Width="130"
                                        Margin="0,0,16,0"/>

                            <Button Content="🔍 SEARCH"
                                    Command="{Binding LoadHistoryCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="110"
                                    Height="36"
                                    Margin="0,0,12,0"/>

                            <Button Content="� Sync"
                                    Command="{Binding SyncPositionsCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="90"
                                    Height="36"
                                    Margin="0,0,12,0"
                                    ToolTip="거래소 포지션 동기화 (누락된 청산 복구)"/>

                            <Button Content="�📥 Export CSV"
                                    Command="{Binding ExportHistoryCommand}"
                                    Style="{StaticResource SuccessButtonStyle}"
                                    Width="130"
                                    Height="36"
                                    Margin="0,0,16,0"/>

                            <TextBlock Text="{Binding TradeHistory.Count, StringFormat='Total: {0} records'}"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Stats Panel -->
                        <Border Grid.Row="1"
                                Style="{StaticResource CardStyle}"
                                Padding="24"
                                Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="WIN RATE"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding WinRate, StringFormat={}{0:F1}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL PROFIT"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TotalProfit, StringFormat={}{0:N2} USDT}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding TotalProfit, Converter={StaticResource LessThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="AVERAGE ROI"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding AverageRoe, StringFormat={}{0:F2}%}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3"
                                            HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL TRADES"
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding TradeHistory.Count}"
                                               FontSize="28"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource SecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Trade History Grid -->
                        <Border Grid.Row="2"
                                Style="{StaticResource CardStyle}"
                                Padding="0"
                                Margin="0">
                            <DataGrid ItemsSource="{Binding TradeHistory}"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}"
                                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="STATUS"
                                                            Width="90">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4"
                                                        Padding="8,4"
                                                        ToolTip="{Binding ExitReason}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background"
                                                                    Value="#334155"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOpenPosition}"
                                                                             Value="True">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding PositionStatus}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="TIME"
                                                        Binding="{Binding Time, StringFormat='yyyy-MM-dd HH:mm:ss'}"
                                                        Width="160"/>
                                    <DataGridTextColumn Header="SYMBOL"
                                                        Binding="{Binding Symbol}"
                                                        Width="100">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="SIDE"
                                                            Width="80">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="4"
                                                        Padding="8,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Side}"
                                                                             Value="BUY">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource AccentBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Side}"
                                                                             Value="SELL">
                                                                    <Setter Property="Background"
                                                                            Value="{StaticResource ErrorBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Side}"
                                                               Foreground="White"
                                                               FontWeight="Bold"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="PRICE"
                                                            Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource PriceFormattingConverter}">
                                                            <Binding Path="Symbol"/>
                                                            <Binding Path="Price"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="STRATEGY"
                                                        Binding="{Binding Strategy}"
                                                        Width="150"/>
                                    <DataGridTextColumn Header="AI SCORE"
                                                        Binding="{Binding AiScore, StringFormat=F1}"
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Center"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="PNL (USDT)"
                                                        Binding="{Binding PnL, StringFormat=N2}"
                                                        Width="110">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="Bold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Right"/>
                                                <Setter Property="Foreground"
                                                        Value="White"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding PnL, Converter={StaticResource LessThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding PnL, Converter={StaticResource GreaterThanConverter}, ConverterParameter=0}"
                                                                 Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource AccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="ROE (%)"
                                                        Binding="{Binding PnLPercent, StringFormat={}{0:F2}%}"
                                                        Width="90">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight"
                                                        Value="SemiBold"/>
                                                <Setter Property="HorizontalAlignment"
                                                        Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- AI MONITOR TAB -->
                <TabItem Header="🤖  AI MONITOR">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <!-- Model Accuracy Cards -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="🎯 AI MODEL ACCURACY"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <TextBlock Text="기준: Confidence 60% 이상 샘플 기준 / 목표 정확도 65% 이상"
                                               FontSize="11"
                                               Foreground="#9CA3AF"
                                               Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Style="{StaticResource StatCardStyle}"
                                                Margin="0,0,8,0">
                                            <StackPanel>
                                                <TextBlock Text="ML.NET"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding MLNetAccuracy, StringFormat={}{0:F1}%}"
                                                           FontSize="32"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Style="{StaticResource StatCardStyle}"
                                                Margin="8,0,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Transformer"
                                                           Foreground="#6B7280"
                                                           FontSize="11"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding TransformerAccuracy, StringFormat={}{0:F1}%}"
                                                           FontSize="32"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource SecondaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Performance Comparison -->
                            <Border Style="{StaticResource CardStyle}"
                                    Padding="0">
                                <StackPanel Margin="20">
                                    <TextBlock Text="📊 MODEL PERFORMANCE COMPARISON"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <DataGrid ItemsSource="{Binding ModelPerformances}"
                                              Style="{StaticResource ModernDataGridStyle}"
                                              ColumnHeaderStyle="{StaticResource ModernColumnHeaderStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="MODEL"
                                                                Binding="{Binding ModelName}"
                                                                Width="*"/>
                                            <DataGridTextColumn Header="ACCURACY (C≥60%)"
                                                                Binding="{Binding Accuracy, StringFormat={}{0:F2}%}"
                                                                Width="120">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight"
                                                                Value="Bold"/>
                                                        <Setter Property="Foreground"
                                                                Value="{Binding StatusColor}"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                            <DataGridTextColumn Header="PREDICTIONS"
                                                                Binding="{Binding TotalPredictions}"
                                                                Width="120"/>
                                            <DataGridTextColumn Header="CORRECT"
                                                                Binding="{Binding CorrectPredictions}"
                                                                Width="100"/>
                                            <DataGridTextColumn Header="CONFIDENCE"
                                                                Binding="{Binding AvgConfidence, StringFormat={}{0:F2}%}"
                                                                Width="120"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <!-- Prediction Chart -->
                            <Border Style="{StaticResource CardStyle}"
                                    Height="350">
                                <StackPanel>
                                    <TextBlock Text="🔮 PREDICTION vs ACTUAL (Last 20)"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Margin="0,0,0,16"/>
                                    <lvc:CartesianChart Series="{Binding PredictionComparisonSeries}"
                                                        LegendLocation="Bottom"
                                                        Hoverable="True">
                                        <lvc:CartesianChart.AxisY>
                                            <lvc:Axis Title="Price (USDT)"
                                                      MinValue="{Binding PredictionChartAxisMin}"
                                                      MaxValue="{Binding PredictionChartAxisMax}"
                                                      Foreground="#9CA3AF"
                                                      LabelFormatter="{Binding LiveChartYFormatter}"/>
                                        </lvc:CartesianChart.AxisY>
                                        <lvc:CartesianChart.AxisX>
                                            <lvc:Axis Title="Prediction #"
                                                      Foreground="#9CA3AF"/>
                                        </lvc:CartesianChart.AxisX>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ADVANCED FEATURES TAB -->
                <TabItem Header="⚡ ADVANCED"
                         Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <!-- Arbitrage Panel -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💰 ARBITRAGE TRADING"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource AccentBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Min Profit (%):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtArbitrageMinProfit"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="0.2"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Scan Interval (s):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtArbitrageScanInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="60"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartArbitrage"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartArbitrage_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopArbitrage"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopArbitrage_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtArbitrageStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Fund Transfer Panel -->
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="💱 FUND TRANSFER"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Check Interval (min):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtFundTransferInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="60"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Min Amount (USDT):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtFundTransferMinAmount"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="100"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartFundTransfer"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartFundTransfer_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopFundTransfer"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopFundTransfer_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtFundTransferStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Rebalancing Panel -->
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0">
                                <StackPanel>
                                    <TextBlock Text="⚖ PORTFOLIO REBALANCING"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource WarningBrush}"
                                               Margin="0,0,0,16"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="150"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="0"
                                                   Text="Check Interval (h):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,12,0"/>
                                        <TextBox x:Name="txtRebalancingInterval"
                                                 Grid.Row="0"
                                                 Grid.Column="1"
                                                 Text="24"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <TextBlock Grid.Row="0"
                                                   Grid.Column="2"
                                                   Text="Threshold (%):"
                                                   Foreground="#9CA3AF"
                                                   VerticalAlignment="Center"
                                                   Margin="20,0,12,0"/>
                                        <TextBox x:Name="txtRebalancingThreshold"
                                                 Grid.Row="0"
                                                 Grid.Column="3"
                                                 Text="5.0"
                                                 Background="{StaticResource BackgroundLightBrush}"
                                                 Foreground="#E0E7FF"
                                                 BorderBrush="{StaticResource PrimaryBrush}"
                                                 Padding="8,6"/>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="4"
                                                    Orientation="Horizontal"
                                                    Margin="0,16,0,0">
                                            <Button x:Name="btnStartRebalancing"
                                                    Content="▶ START"
                                                    Style="{StaticResource SuccessButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStartRebalancing_Click"
                                                    Margin="0,0,12,0"/>
                                            <Button x:Name="btnStopRebalancing"
                                                    Content="⏹ STOP"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Width="110"
                                                    Click="BtnStopRebalancing_Click"
                                                    IsEnabled="False"
                                                    Margin="0,0,16,0"/>
                                            <TextBlock x:Name="txtRebalancingStatus"
                                                       Text="Status: Stopped"
                                                       Foreground="#6B7280"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- STATUS BAR -->
            <Border Grid.Row="3"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#2D3454"
                    CornerRadius="0,0,12,12">
                <Grid Margin="20,0">
                    <TextBlock x:Name="lblFooter"
                               Text="SYSTEM READY  •  WAITING FOR COMMAND"
                               Foreground="#6B7280"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="txtMajorProfileStatus"
                               Text="● Major Profile: Balanced"
                               Foreground="#9CA3AF"
                               FontSize="11"
                               Margin="0,0,16,0"/>
                        <TextBlock x:Name="txtTelegramStatus"
                                   Text="Telegram: Offline"
                                   Foreground="#6B7280"
                                   FontSize="11"
                                   Margin="0,0,16,0"/>
                        <Ellipse Width="8"
                                 Height="8"
                                 Fill="{StaticResource AccentBrush}"
                                 Margin="0,0,6,0"/>
                        <TextBlock Text="Binance USDT-Futures  •  Connected"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
