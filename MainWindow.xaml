                                                                        <Border Background="{Binding StrategyBg}" CornerRadius="3" Padding="4,1" Margin="5,0,0,0" VerticalAlignment="Center"
                                                                                Visibility="{Binding StrategyName, Converter={StaticResource NullToCollapsedConverter}}">
                                                                            <TextBlock Text="{Binding StrategyName}" FontSize="8" FontWeight="Bold" Foreground="White"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <!-- 포지션 방향 pill (진입중일 때만) -->
                                                                    <Border Background="{Binding PositionSideColor}" CornerRadius="3" Padding="5,1"
                                                                            HorizontalAlignment="Left" Margin="0,2,0,0"
                                                                            Visibility="{Binding IsPositionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                        <TextBlock Text="{Binding PositionSide}" FontSize="9" FontWeight="Bold" Foreground="#0F172A"/>
                                                                    </Border>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </DataGridTemplateColumn.CellTemplate>
                                                    </DataGridTemplateColumn>

                                                    <!-- ② PRICE: 현재가 + 진입가 (진입중) -->
                                                    <DataGridTemplateColumn Header="가격" Width="128">
