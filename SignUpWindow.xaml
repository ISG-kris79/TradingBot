<Window x:Class="TradingBot.SignUpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sign Up"
        Height="700"
        Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStyle="None">
        <WindowChrome.WindowChrome>
                <WindowChrome CaptionHeight="40"
                                ResizeBorderThickness="5"
                              GlassFrameThickness="0"
                                CornerRadius="0"/>
        </WindowChrome.WindowChrome>
        <Window.Resources>
                <Style x:Key="WindowControlButtonStyle"
                                TargetType="Button">
                        <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                                        Value="True"/>
                        <Setter Property="Background"
                                        Value="Transparent"/>
                        <Setter Property="Foreground"
                                        Value="#94A3B8"/>
                        <Setter Property="BorderThickness"
                                        Value="0"/>
                        <Setter Property="Width"
                                        Value="46"/>
                        <Setter Property="Height"
                                        Value="32"/>
                        <Setter Property="FontSize"
                                        Value="14"/>
                        <Setter Property="Template">
                                <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                        Value="True">
                                                                <Setter Property="Background"
                                                                                Value="#333"/>
                                                                <Setter Property="Foreground"
                                                                                Value="White"/>
                                                        </Trigger>
                                                </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                </Setter.Value>
                        </Setter>
                </Style>
                <Style x:Key="ModernWindowStyle"
                                TargetType="Window">
                        <Setter Property="Background"
                                        Value="#121212"/>
                        <Setter Property="Foreground"
                                        Value="White"/>
                        <Setter Property="FontFamily"
                                        Value="Segoe UI"/>
                        <Setter Property="WindowStyle"
                                        Value="None"/>
                        <Setter Property="ResizeMode"
                                        Value="CanResize"/>
                        <Setter Property="WindowChrome.WindowChrome">
                                <Setter.Value>
                                        <WindowChrome CaptionHeight="40"
                                                        ResizeBorderThickness="5"
                                                      GlassFrameThickness="0"
                                                        CornerRadius="0"/>
                                </Setter.Value>
                        </Setter>
                </Style>
        </Window.Resources>
        <Border BorderBrush="#333"
                        BorderThickness="1"
                        Background="#1E1E1E">
                <Grid>
                        <Grid.RowDefinitions>
                                <RowDefinition Height="40"/>
                                <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Title Bar -->
                        <Grid Grid.Row="0"
                                        Background="Transparent"
                                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                                <TextBlock Text="SIGN UP"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                Margin="10,0,0,0"
                                                Foreground="White"
                                                FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top">
                                        <Button Content="—"
                                                        Style="{StaticResource WindowControlButtonStyle}"
                                                        Click="OnMinimize_Click"/>
                                        <Button Content="☐"
                                                        Style="{StaticResource WindowControlButtonStyle}"
                                                        Click="OnMaximize_Click"/>
                                        <Button Content="✕"
                                                        Click="OnClose_Click">
                                                <Button.Style>
                                                        <Style TargetType="Button"
                                                                        BasedOn="{StaticResource WindowControlButtonStyle}">
                                                                <Style.Triggers>
                                                                        <Trigger Property="IsMouseOver"
                                                                                        Value="True">
                                                                                <Setter Property="Background"
                                                                                                Value="#E81123"/>
                                                                                <Setter Property="Foreground"
                                                                                                Value="White"/>
                                                                        </Trigger>
                                                                </Style.Triggers>
                                                        </Style>
                                                </Button.Style>
                                        </Button>
                                </StackPanel>
                        </Grid>

                        <!-- Original Content -->
                        <ScrollViewer Grid.Row="1"
                                        VerticalScrollBarVisibility="Auto">
                                <StackPanel VerticalAlignment="Center"
                                            Margin="30">
                                        <TextBlock Text="회원가입"
                                                   Foreground="White"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,0,0,20"/>

                                        <TextBlock Text="Username"
                                                   Foreground="Gray"/>
                                        <TextBox x:Name="txtUser"
                                                 Height="25"
                                                 Background="#2D2D2D"
                                                 Foreground="White"
                                                 BorderThickness="0"
                                                 Margin="0,0,0,2"
                                                 TextChanged="txtUser_TextChanged"/>
                                        <TextBlock x:Name="lblUserFeedback"
                                                   FontSize="10"
                                                   Margin="0,0,0,10"/>

                                        <TextBlock Text="Email"
                                                   Foreground="Gray"/>
                                        <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txtEmail"
                                                         Grid.Column="0"
                                                         Height="25"
                                                         Background="#2D2D2D"
                                                         Foreground="White"
                                                         BorderThickness="0"
                                                         TextChanged="txtEmail_TextChanged"/>
                                                <Button x:Name="btnVerifyEmail"
                                                        Content="인증코드 발송"
                                                        Height="25"
                                                        Margin="230,0,0,0"
                                                        Background="#333"
                                                        Foreground="White"
                                                        BorderThickness="0"
                                                        Click="btnVerifyEmail_Click">
                                                        <Button.Style>
                                                                <Style TargetType="Button">
                                                                        <Setter Property="Background"
                                                                                Value="#333"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="White"/>
                                                                        <Setter Property="Template">
                                                                                <Setter.Value>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                                <Border Background="{TemplateBinding Background}"
                                                                                                        BorderThickness="0"
                                                                                                        CornerRadius="3">
                                                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                                                          VerticalAlignment="Center"/>
                                                                                                </Border>
                                                                                        </ControlTemplate>
                                                                                </Setter.Value>
                                                                        </Setter>
                                                                        <Style.Triggers>
                                                                                <Trigger Property="IsMouseOver"
                                                                                         Value="True">
                                                                                        <Setter Property="Background"
                                                                                                Value="#555"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsPressed"
                                                                                         Value="True">
                                                                                        <Setter Property="Background"
                                                                                                Value="#222"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsEnabled"
                                                                                         Value="False">
                                                                                        <Setter Property="Background"
                                                                                                Value="#1A1A1A"/>
                                                                                        <Setter Property="Foreground"
                                                                                                Value="#666"/>
                                                                                </Trigger>
                                                                        </Style.Triggers>
                                                                </Style>
                                                        </Button.Style>
                                                </Button>
                                        </Grid>
                                        <TextBlock x:Name="lblEmailFeedback"
                                                   FontSize="10"
                                                   Margin="0,0,0,5"/>
                                        <TextBlock x:Name="lblCodeTimer"
                                                   FontSize="10"
                                                   Foreground="#FFB11A"
                                                   Margin="0,0,0,10"
                                                   Visibility="Collapsed"/>

                                        <TextBlock Text="인증코드"
                                                   Foreground="Gray"
                                                   x:Name="lblCode"
                                                   Visibility="Collapsed"/>
                                        <TextBox x:Name="txtCode"
                                                 Height="25"
                                                 Background="#2D2D2D"
                                                 Foreground="White"
                                                 BorderThickness="0"
                                                 Margin="0,0,0,10"
                                                 Visibility="Collapsed"/>

                                        <TextBlock Text="Password"
                                                   Foreground="Gray"/>
                                        <PasswordBox x:Name="txtPass"
                                                     Height="25"
                                                     Background="#2D2D2D"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     Margin="0,0,0,10"/>

                                        <TextBlock Text="Binance API Key"
                                                   Foreground="#00E676"
                                                   Margin="0,10,0,0"/>
                                        <PasswordBox x:Name="txtApiKey"
                                                     Height="25"
                                                     Background="#2D2D2D"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     Margin="0,0,0,5"/>

                                        <TextBlock Text="Binance Secret Key"
                                                   Foreground="#00E676"/>
                                        <PasswordBox x:Name="txtSecretKey"
                                                     Height="25"
                                                     Background="#2D2D2D"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     Margin="0,0,0,10"/>

                                        <TextBlock Text="Bybit API Key"
                                                   Foreground="#FFB11A"
                                                   Margin="0,5,0,0"/>
                                        <PasswordBox x:Name="txtBybitKey"
                                                     Height="25"
                                                     Background="#2D2D2D"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     Margin="0,0,0,5"/>
                                        <TextBlock Text="Bybit Secret Key"
                                                   Foreground="#FFB11A"/>
                                        <PasswordBox x:Name="txtBybitSecret"
                                                     Height="25"
                                                     Background="#2D2D2D"
                                                     Foreground="White"
                                                     BorderThickness="0"
                                                     Margin="0,0,0,10"/>

                                        <TextBlock Text="Telegram Chat ID"
                                                   Foreground="#2196F3"
                                                   Margin="0,5,0,0"/>
                                        <TextBox x:Name="txtChatId"
                                                 Height="25"
                                                 Background="#2D2D2D"
                                                 Foreground="White"
                                                 BorderThickness="0"
                                                 Margin="0,0,0,5"/>

                                        <TextBlock Text="Telegram Bot Token"
                                                   Foreground="#2196F3"/>
                                        <TextBox x:Name="txtBotToken"
                                                 Height="25"
                                                 Background="#2D2D2D"
                                                 Foreground="White"
                                                 BorderThickness="0"
                                                 Margin="0,0,0,20"/>

                                        <Button x:Name="btnRegister"
                                                Content="등록"
                                                Height="40"
                                                Background="#00E676"
                                                Foreground="Black"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Click="btnRegister_Click"/>
                                </StackPanel>
                        </ScrollViewer>
                </Grid>
        </Border>
</Window>
