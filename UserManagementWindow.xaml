<Window x:Class="TradingBot.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="사용자 관리"
        Height="600"
        Width="900"
        Background="#121212"
        Foreground="White"
        FontFamily="Segoe UI"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <Style x:Key="WindowControlButtonStyle"
               TargetType="Button">
            <Setter Property="WindowChrome.IsHitTestVisibleInChrome"
                    Value="True"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#94A3B8"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Width"
                    Value="46"/>
            <Setter Property="Height"
                    Value="32"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="Background"
                                        Value="#333"/>
                                <Setter Property="Foreground"
                                        Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernWindowStyle"
               TargetType="Window">
            <Setter Property="Background"
                    Value="#121212"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="WindowStyle"
                    Value="None"/>
            <Setter Property="ResizeMode"
                    Value="CanResize"/>
            <Setter Property="WindowChrome.WindowChrome">
                <Setter.Value>
                    <WindowChrome CaptionHeight="40"
                                  ResizeBorderThickness="5"
                                  GlassFrameThickness="0"
                                  CornerRadius="0"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border BorderBrush="#333"
            BorderThickness="1"
            Background="#1E1E1E">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="사용자 관리"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                    <Button Content="—"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMinimize_Click"/>
                    <Button Content="☐"
                            Style="{StaticResource WindowControlButtonStyle}"
                            Click="OnMaximize_Click"/>
                    <Button Content="✕"
                            Click="OnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource WindowControlButtonStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver"
                                             Value="True">
                                        <Setter Property="Background"
                                                Value="#E81123"/>
                                        <Setter Property="Foreground"
                                                Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Original Content -->
            <Grid Grid.Row="1"
                  Margin="0,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="15,15,15,10">
                    <Button x:Name="btnRefresh"
                            Content="새로고침"
                            Width="120"
                            Margin="0,0,10,0"
                            Click="btnRefresh_Click"/>
                    <Button x:Name="btnApprove"
                            Content="승인"
                            Width="100"
                            Margin="0,0,10,0"
                            Background="#107C10"
                            Click="btnApprove_Click"/>
                    <Button x:Name="btnReject"
                            Content="거부"
                            Width="120"
                            Background="#C42B1C"
                            Click="btnReject_Click"/>
                </StackPanel>

                <!-- 사용자 목록 DataGrid -->
                <DataGrid x:Name="dgUsers"
                          Grid.Row="1"
                          Margin="15,0,15,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding Id}"
                                            Width="50"/>
                        <DataGridTextColumn Header="사용자명"
                                            Binding="{Binding Username}"
                                            Width="120"/>
                        <DataGridTextColumn Header="이메일"
                                            Binding="{Binding Email}"
                                            Width="200"/>
                        <DataGridTemplateColumn Header="승인 상태"
                                                Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"
                                                        Value="대기중"/>
                                                <Setter Property="Foreground"
                                                        Value="Orange"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsApproved}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="승인됨"/>
                                                        <Setter Property="Foreground"
                                                                Value="LightGreen"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="관리자"
                                                Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"
                                                        Value="일반"/>
                                                <Setter Property="Foreground"
                                                        Value="LightGray"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAdmin}"
                                                                 Value="True">
                                                        <Setter Property="Text"
                                                                Value="최고 관리자"/>
                                                        <Setter Property="Foreground"
                                                                Value="Gold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="승인자"
                                            Binding="{Binding ApprovedBy}"
                                            Width="120"/>
                        <DataGridTextColumn Header="승인 일시"
                                            Binding="{Binding ApprovedAt, StringFormat='yyyy-MM-dd HH:mm'}"
                                            Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Status Bar -->
                <Border Grid.Row="2"
                        Background="#2D2D30"
                        Height="35"
                        BorderThickness="0,1,0,0"
                        BorderBrush="#3E3E42">
                    <TextBlock x:Name="txtStatus"
                               Text="사용자 목록 로드됨"
                               Foreground="#CCCCCC"
                               VerticalAlignment="Center"
                               Margin="15,0"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
