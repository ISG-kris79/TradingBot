<Window x:Class="TradingBot.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="비밀번호 찾기" Height="200" Width="300"
        Background="#1E1E1E" Foreground="White" WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="등록된 이메일 주소를 입력하세요." Margin="0,0,0,10"/>
            <TextBox x:Name="txtEmail" Height="30" Margin="0,0,0,20" 
                     Background="#333" Foreground="White" BorderBrush="#555" VerticalContentAlignment="Center"/>
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="btnSendReset" Content="임시 비번 발송" Grid.Column="0" Margin="0,0,5,0" 
                        Height="30" Click="btnSendReset_Click" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                <Button x:Name="btnClose" Content="닫기" Grid.Column="1" Margin="5,0,0,0" 
                        Height="30" Click="btnClose_Click" Background="#444" Foreground="White" BorderThickness="0"/>
            </Grid>
        </StackPanel>
    </Grid>
</Window>