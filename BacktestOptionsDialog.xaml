<Window x:Class="TradingBot.BacktestOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 BACKTEST 옵션 설정"
        Height="580"
        Width="480"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Modern Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1A1F3A"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#2D3348"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Radio Button Style -->
        <Style x:Key="ModernRadioButton" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#E0E7FF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#00E5FF"/>
            <Setter Property="Foreground" Value="#0A0E27"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33F0FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#252B48"/>
            <Setter Property="Foreground" Value="#E0E7FF"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2D3348"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="4,2"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource CardStyle}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="📊 BACKTEST 설정"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#00E5FF"
                           Margin="0,0,0,8"/>
                <TextBlock Text="백테스트 전략과 기간을 선택하세요"
                           FontSize="13"
                           Foreground="#A0A0A0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Strategy Selection -->
                    <Border Style="{StaticResource CardStyle}" 
                            Background="#0F1426" 
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="🎯 전략 선택"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#E0E7FF"
                                       Margin="0,0,0,12"/>

                            <RadioButton x:Name="rbLiveEntryParity"
                                         Content="🔵 Live Entry Parity (실전 진입 게이트 반영)"
                                         GroupName="Strategy"
                                         IsChecked="True"
                                         Style="{StaticResource ModernRadioButton}"/>
                            
                            <RadioButton x:Name="rbElliottWave"
                                         Content="🟢 ElliottWave (90% 실전 복제 - 추천)"
                                         GroupName="Strategy"
                                         Style="{StaticResource ModernRadioButton}"/>
                            
                            <RadioButton x:Name="rbBollingerBand"
                                         Content="🟡 Bollinger Band (교육용 - 30% 정확도)"
                                         GroupName="Strategy"
                                         Style="{StaticResource ModernRadioButton}"/>
                            
                            <RadioButton x:Name="rbMACross"
                                         Content="⚫ MA Cross (교육용 전용)"
                                         GroupName="Strategy"
                                         Style="{StaticResource ModernRadioButton}"/>
                            
                            <RadioButton x:Name="rbRSI"
                                         Content="⚫ RSI (교육용 전용)"
                                         GroupName="Strategy"
                                         Style="{StaticResource ModernRadioButton}"/>
                        </StackPanel>
                    </Border>

                    <!-- Period Selection -->
                    <Border Style="{StaticResource CardStyle}" 
                            Background="#0F1426" 
                            Padding="16"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="📅 백테스트 기간"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#E0E7FF"
                                       Margin="0,0,0,12"/>
                            
                            <RadioButton x:Name="rb30Days"
                                         Content="30일 (빠른 테스트 - 추천)"
                                         GroupName="Period"
                                         IsChecked="True"
                                         Style="{StaticResource ModernRadioButton}"/>
                            
                            <RadioButton x:Name="rb60Days"
                                         Content="60일 (중간 검증)"
                                         GroupName="Period"
                                         Style="{StaticResource ModernRadioButton}"/>
                            
                            <RadioButton x:Name="rb90Days"
                                         Content="90일 (상세 검증)"
                                         GroupName="Period"
                                         Style="{StaticResource ModernRadioButton}"/>
                            
                            <RadioButton x:Name="rb180Days"
                                         Content="180일 (장기 검증 - 느림)"
                                         GroupName="Period"
                                         Style="{StaticResource ModernRadioButton}"/>
                        </StackPanel>
                    </Border>

                    <!-- Metric Options -->
                    <Border Style="{StaticResource CardStyle}"
                            Background="#0F1426"
                            Padding="16">
                        <StackPanel>
                            <TextBlock Text="📐 지표 계산 옵션"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#E0E7FF"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="무위험수익률(연 %):"
                                       FontSize="13"
                                       Foreground="#C7D2FE"
                                       Margin="0,0,0,6"/>
                            <TextBox x:Name="txtRiskFreeRate"
                                     Text="3.0"
                                     Height="30"
                                     Background="#111827"
                                     Foreground="#E5E7EB"
                                     BorderBrush="#334155"
                                     BorderThickness="1"
                                     Padding="8,4"
                                     Margin="0,0,0,10"/>

                            <TextBlock Text="연율화 기준:"
                                       FontSize="13"
                                       Foreground="#C7D2FE"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="cmbAnnualization"
                                      SelectedIndex="0"
                                      Height="30"
                                      Background="#111827"
                                      Foreground="#E5E7EB"
                                      BorderBrush="#334155"
                                      BorderThickness="1"
                                      Padding="6,2"
                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                                <ComboBoxItem Content="Auto (캔들 간격 자동 감지)" Tag="Auto"/>
                                <ComboBoxItem Content="None (연율화 안 함)" Tag="None"/>
                                <ComboBoxItem Content="TradingDays252 (주식형)" Tag="TradingDays252"/>
                                <ComboBoxItem Content="CalendarDays365" Tag="CalendarDays365"/>
                                <ComboBoxItem Content="Crypto5m (24/7 5분봉)" Tag="Crypto5m"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="취소"
                        Style="{StaticResource SecondaryButton}"
                        Click="Cancel_Click"
                        Width="100"
                        Margin="0,0,12,0"/>
                <Button Content="시작"
                        Style="{StaticResource PrimaryButton}"
                        Click="Start_Click"
                        Width="100"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
